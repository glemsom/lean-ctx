---
import DashboardPage from '../../page-templates/DashboardPage.astro';

export function getStaticPaths() {
  const views = ['overview', 'stats', 'commands', 'knowledge', 'performance', 'models', 'settings'];
  return [
    { params: { view: undefined } },
    ...views.map(v => ({ params: { view: v } })),
  ];
}
---
<DashboardPage />
