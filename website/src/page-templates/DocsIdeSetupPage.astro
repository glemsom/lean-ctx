---
import DocsLayout from '../layouts/DocsLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const sidebar = [
  {
    title: t('docsIdeSetup.sidebarTitle'),
    items: [
      { label: t('docsIdeSetup.sidebarOverview'), href: lp('/docs/ide-setup') },
      { label: t('docsIdeSetup.sidebarOneShot'), href: lp('/docs/ide-setup') + '#one-shot-fix' },
      { label: t('docsIdeSetup.sidebarMatrix'), href: lp('/docs/ide-setup') + '#matrix' },
      { label: t('docsIdeSetup.sidebarTroubleshooting'), href: lp('/docs/ide-setup') + '#troubleshooting' },
    ],
  },
  {
    title: t('docsRemoteSetup.sidebarRelated'),
    items: [
      { label: t('docsRemoteSetup.sidebarGettingStarted'), href: lp('/docs/getting-started') },
      { label: t('nav.docs.remoteSetup'), href: lp('/docs/remote-setup') },
      { label: t('nav.docs.analytics'), href: lp('/docs/analytics') },
      { label: t('nav.docs.cliComplete'), href: lp('/docs/cli-reference') },
    ],
  },
];
---

<DocsLayout title={t('docsIdeSetup.title')} description={t('docsIdeSetup.description')} sidebar={sidebar}>
  <p set:html={t('docsIdeSetup.intro')} />

  <hr />

  <h2 id="one-shot-fix" set:html={t('docsIdeSetup.oneShotTitle')} />
  <p set:html={t('docsIdeSetup.oneShotDesc')} />
  <pre><code>lean-ctx init --global
lean-ctx init --agent cursor
lean-ctx doctor</code></pre>
  <p set:html={t('docsIdeSetup.oneShotNote')} />

  <hr />

  <h2 id="matrix" set:html={t('docsIdeSetup.matrixTitle')} />
  <p set:html={t('docsIdeSetup.matrixDesc')} />

  <table>
    <thead>
      <tr>
        <th>{t('docsIdeSetup.thTool')}</th>
        <th>{t('docsIdeSetup.thMcpConfig')}</th>
        <th>{t('docsIdeSetup.thFixCommand')}</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Cursor</td>
        <td><code>~/.cursor/mcp.json</code></td>
        <td><code>lean-ctx init --agent cursor</code></td>
      </tr>
      <tr>
        <td>Claude Code</td>
        <td><code>~/.claude.json</code></td>
        <td><code>lean-ctx init --agent claude</code></td>
      </tr>
      <tr>
        <td>Windsurf</td>
        <td><code>~/.codeium/windsurf/mcp_config.json</code></td>
        <td><code>lean-ctx init --agent windsurf</code></td>
      </tr>
      <tr>
        <td>VS Code / Copilot</td>
        <td><code>.../Code/User/mcp.json</code></td>
        <td><code>lean-ctx init --agent copilot</code></td>
      </tr>
      <tr>
        <td>Zed</td>
        <td><code>.../zed/settings.json</code></td>
        <td><code>lean-ctx setup</code></td>
      </tr>
      <tr>
        <td>OpenCode</td>
        <td><code>~/.config/opencode/opencode.json</code></td>
        <td><code>lean-ctx setup</code></td>
      </tr>
      <tr>
        <td>Crush</td>
        <td><code>~/.config/crush/crush.json</code></td>
        <td><code>lean-ctx init --agent crush</code></td>
      </tr>
      <tr>
        <td>Pi Coding Agent</td>
        <td><code>~/.pi/agent/mcp.json</code></td>
        <td><code>lean-ctx init --agent pi</code></td>
      </tr>
    </tbody>
  </table>

  <p class="text-sm text-muted mt-2" set:html={t('docsIdeSetup.matrixNote')} />

  <hr />

  <h2 id="troubleshooting" set:html={t('docsIdeSetup.troubleshootingTitle')} />

  <h3 set:html={t('docsIdeSetup.troubleZeroSavedTitle')} />
  <p set:html={t('docsIdeSetup.troubleZeroSavedDesc')} />
  <pre><code>lean-ctx doctor
lean-ctx gain --reset
lean-ctx gain</code></pre>

  <h3 set:html={t('docsIdeSetup.troubleStalePathTitle')} />
  <p set:html={t('docsIdeSetup.troubleStalePathDesc')} />
  <pre><code>lean-ctx init --agent cursor
lean-ctx init --agent claude
lean-ctx setup</code></pre>

  <h3 set:html={t('docsIdeSetup.troubleBrewLinkTitle')} />
  <p set:html={t('docsIdeSetup.troubleBrewLinkDesc')} />
  <pre><code>brew unlink lean-ctx || true
brew link --overwrite lean-ctx
lean-ctx --version</code></pre>
</DocsLayout>

