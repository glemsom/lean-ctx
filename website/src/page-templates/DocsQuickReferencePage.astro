---
import DocsLayout from '../layouts/DocsLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const sidebar = [
  {
    title: t('docs.quickReference.sidebarTitle'),
    items: [
      { label: t('docs.quickReference.sidebarOverview'), href: lp('/docs/quick-reference') },
      { label: t('docs.quickReference.sidebarReadModes'), href: lp('/docs/quick-reference#read-modes') },
      { label: t('docs.quickReference.sidebarContextTools'), href: lp('/docs/quick-reference#context-tools') },
      { label: t('docs.quickReference.sidebarCliCommands'), href: lp('/docs/quick-reference#cli-commands') },
      { label: t('docs.quickReference.sidebarDetailPages'), href: lp('/docs/quick-reference#links') },
    ],
  },
  {
    title: t('docs.common.related'),
    items: [
      { label: t('nav.docs.analytics'), href: lp('/docs/analytics') },
      { label: t('nav.docs.cliComplete'), href: lp('/docs/cli-reference') },
      { label: t('nav.docs.configuration'), href: lp('/docs/configuration') },
      { label: t('nav.docs.installSetup'), href: lp('/docs/getting-started') },
      { label: t('docs.tools.title'), href: lp('/docs/tools') },
    ],
  },
];
---

<DocsLayout title={t('docs.quickReference.title')} description={t('docs.quickReference.description')} sidebar={sidebar}>

  <p><Fragment set:html={t('docs.quickReference.intro')} /></p>

  <hr />

  <h2 id="read-modes">{t('docs.quickReference.readModesTitle')}</h2>

  <p><Fragment set:html={t('docs.quickReference.readModesDesc')} /></p>

  <table>
    <thead>
      <tr><th>{t('docs.quickReference.thSituation')}</th><th>{t('docs.quickReference.thMode')}</th><th>{t('docs.quickReference.thTypicalSavings')}</th></tr>
    </thead>
    <tbody>
      <tr>
        <td>{t('docs.quickReference.sitEdit')}</td>
        <td><code>full</code></td>
        <td>Re-reads: ~99%</td>
      </tr>
      <tr>
        <td>{t('docs.quickReference.sitContext')}</td>
        <td><code>map</code></td>
        <td>~93%</td>
      </tr>
      <tr>
        <td>{t('docs.quickReference.sitApi')}</td>
        <td><code>signatures</code></td>
        <td>~95%</td>
      </tr>
      <tr>
        <td>{t('docs.quickReference.sitAfterEdit')}</td>
        <td><code>diff</code></td>
        <td>~98%</td>
      </tr>
      <tr>
        <td>{t('docs.quickReference.sitBrowse')}</td>
        <td><code>aggressive</code></td>
        <td>~85%</td>
      </tr>
      <tr>
        <td>{t('docs.quickReference.sitLargeFile')}</td>
        <td><code>entropy</code></td>
        <td>~90%</td>
      </tr>
    </tbody>
  </table>

  <p>
    <a href={lp('/docs/tools/core#ctx_read')}>{t('docs.quickReference.fullReadDocs')}</a>
  </p>

  <hr />

  <h2 id="context-tools">{t('docs.quickReference.contextToolsTitle')}</h2>

  <p><Fragment set:html={t('docs.quickReference.contextToolsDesc')} /></p>

  <table>
    <thead>
      <tr><th>{t('docs.quickReference.thTool')}</th><th>{t('docs.quickReference.thPurpose')}</th><th>{t('docs.quickReference.thSavings')}</th></tr>
    </thead>
    <tbody>
      <tr>
        <td><code>ctx_read</code></td>
        <td>{t('docs.quickReference.toolReadDesc')}</td>
        <td>up to 99%</td>
      </tr>
      <tr>
        <td><code>ctx_shell</code></td>
        <td>{t('docs.quickReference.toolShellDesc')}</td>
        <td>60–95%</td>
      </tr>
      <tr>
        <td><code>ctx_search</code></td>
        <td>{t('docs.quickReference.toolSearchDesc')}</td>
        <td>50–80%</td>
      </tr>
      <tr>
        <td><code>ctx_session</code></td>
        <td>{t('docs.quickReference.toolSessionDesc')}</td>
        <td>99% cold-start</td>
      </tr>
      <tr>
        <td><code>ctx_graph</code></td>
        <td>{t('docs.quickReference.toolGraphDesc')}</td>
        <td>—</td>
      </tr>
    </tbody>
  </table>

  <p>
    <a href={lp('/docs/tools')}>{t('docs.quickReference.fullToolsRef')}</a>
  </p>

  <hr />

  <h2 id="cli-commands">{t('docs.quickReference.cliTitle')}</h2>

  <h3 id="essential">{t('docs.quickReference.cliEssential')}</h3>
  <table>
    <thead>
      <tr><th>{t('docs.quickReference.thCliCommand')}</th><th>{t('docs.quickReference.thCliWhat')}</th></tr>
    </thead>
    <tbody>
      <tr><td><code>lean-ctx setup</code></td><td><Fragment set:html={t('docs.quickReference.cliSetup')} /></td></tr>
      <tr><td><code>lean-ctx gain</code></td><td><Fragment set:html={t('docs.quickReference.cliGain')} /></td></tr>
      <tr><td><code>lean-ctx doctor</code></td><td><Fragment set:html={t('docs.quickReference.cliDoctor')} /></td></tr>
      <tr><td><code>lean-ctx dashboard</code></td><td><Fragment set:html={t('docs.quickReference.cliDashboard')} /></td></tr>
      <tr><td><code>lean-ctx benchmark run [path]</code></td><td><Fragment set:html={t('docs.quickReference.cliBenchmark')} /></td></tr>
    </tbody>
  </table>

  <p>
    <a href={lp('/docs/cli')}>{t('docs.quickReference.fullCliRef')}</a>
  </p>

  <hr />

  <h2 id="links">{t('docs.quickReference.detailPagesTitle')}</h2>

  <ul>
    <li><a href={lp('/mcp-server')}>{t('docs.quickReference.linkContextServer')}</a></li>
    <li><a href={lp('/docs/cli')}>{t('docs.quickReference.linkCli')}</a></li>
    <li><a href={lp('/protocols')}>{t('docs.quickReference.linkProtocols')}</a></li>
    <li><a href={lp('/docs/configuration')}>{t('docs.quickReference.linkConfig')}</a></li>
  </ul>

</DocsLayout>
