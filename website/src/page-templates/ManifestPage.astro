---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const sections = [
  { id: 'abstract', label: t('manifest.sectionAbstract') },
  { id: 'the-problem', label: t('manifest.sectionProblem') },
  { id: 'information-density', label: t('manifest.sectionDensity') },
  { id: 'efficiency-multiplier', label: t('manifest.sectionEfficiency') },
  { id: 'architecture', label: t('manifest.sectionArchitecture') },
  { id: 'the-shift', label: t('manifest.sectionShift') },
  { id: 'design-principles', label: t('manifest.sectionPrinciples') },
  { id: 'conclusion', label: t('manifest.sectionConclusion') },
];
---

<BaseLayout title={t('manifest.title')} description={t('manifest.description')}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-20 sm:pt-28">

    <!-- Hero -->
    <div class="max-w-2xl mb-8 sm:mb-14">
      <p class="text-[10px] sm:text-[11px] font-medium uppercase tracking-[0.2em] text-accent mb-2 sm:mb-3">{t('manifest.positionPaper')}</p>
      <h1 class="font-display text-2xl sm:text-[2.75rem] lg:text-[3.25rem] font-bold tracking-tight leading-[1.15] text-text-bright mb-3 sm:mb-4">
        {t('manifest.heroTitle')}<br />
        <span class="gradient-text-green">{t('manifest.heroTitleHighlight')}</span>
      </h1>
      <p class="text-sm sm:text-base text-muted leading-relaxed mb-4">
        {t('manifest.heroDesc')}
      </p>
      <p class="text-xs text-muted font-mono">
        <span class="text-accent">7</span> {t('manifest.sections')}
        <span class="mx-2 text-border-light">/</span>
        <span class="text-accent">5</span> {t('manifest.designPrinciplesCount')}
        <span class="mx-2 text-border-light">/</span>
        <span class="text-accent">4</span> {t('manifest.architectureLayers')}
      </p>
    </div>

    <!-- Mobile TOC -->
    <nav class="lg:hidden mb-8">
      <details class="manifest-mobile-nav group">
        <summary class="flex items-center justify-between px-4 py-3 text-sm cursor-pointer select-none">
          <span class="font-medium text-muted">{t('manifest.onThisPage')}</span>
          <svg class="w-4 h-4 text-muted/60 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-2 pb-3 pt-1">
          {sections.map(s => (
            <a href={`#${s.id}`} class="block text-[13px] py-1.5 px-2 rounded-md text-muted hover:text-text-bright transition-colors duration-150">
              {s.label}
            </a>
          ))}
        </div>
      </details>
    </nav>

    <!-- Grid: Sidebar + Article -->
    <div class="lg:grid lg:grid-cols-[200px_1fr] lg:gap-14 pb-12 sm:pb-20">

      <!-- TOC Sidebar -->
      <aside class="hidden lg:block">
        <nav class="sticky top-24 space-y-0.5">
          <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-4 font-display">{t('manifest.contents')}</p>
          {sections.map(s => (
            <a href={`#${s.id}`} class="block text-sm py-1.5 px-3 rounded-lg text-muted hover:text-text-bright hover:bg-surface-2 transition-all duration-200 manifest-toc-link">
              {s.label}
            </a>
          ))}
        </nav>
      </aside>

      <!-- Article -->
      <article class="min-w-0 max-w-3xl manifest-article">

        <!-- Abstract -->
      <section id="abstract" class="scroll-mt-20 mb-12">
        <h2 class="font-display text-lg sm:text-xl font-semibold text-text-bright tracking-tight mb-5">{t('manifest.sectionAbstract')}</h2>
        <blockquote class="border-l-2 border-accent/40 pl-4 py-0.5 text-muted italic bg-accent/[0.02] rounded-r-lg mb-4">
          <p class="text-sm sm:text-[15px] leading-[1.8]">
            {t('manifest.abstractQuote')}
          </p>
        </blockquote>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4">
          {t('manifest.abstractP1')}
        </p>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.abstractP2')} />
      </section>

      <hr class="border-border/20 my-8" />

      <!-- 1: The Problem -->
      <section id="the-problem" class="scroll-mt-20 mb-12">
        <h2 class="font-display text-lg sm:text-xl font-semibold text-text-bright tracking-tight mb-5">{t('manifest.problemTitle')}</h2>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4">
          {t('manifest.problemP1')}
        </p>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4">
          {t('manifest.problemP2')}
        </p>

        <div class="my-8 flex items-center gap-8 sm:gap-12">
          <div>
            <p class="stat-value text-4xl sm:text-5xl text-accent mb-1">~65%</p>
            <p class="text-xs text-muted">{t('manifest.problemStat1')}</p>
            <p class="text-[10px] text-muted/50 mt-1">{t('manifest.problemStat1Note')}</p>
          </div>
          <div>
            <p class="stat-value text-4xl sm:text-5xl text-muted mb-1">$20–200</p>
            <p class="text-xs text-muted">{t('manifest.problemStat2')}</p>
          </div>
        </div>

        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4">
          {t('manifest.problemP3')}
        </p>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.problemP4')} />
      </section>

      <hr class="border-border/20 my-8" />

      <!-- 2: Information Density -->
      <section id="information-density" class="scroll-mt-20 mb-12">
        <h2 class="font-display text-lg sm:text-xl font-semibold text-text-bright tracking-tight mb-5">{t('manifest.densityTitle')}</h2>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4">
          {t('manifest.densityP1')}
        </p>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4" set:html={t('manifest.densityP2')} />

        <div class="my-8 py-6 text-center">
          <p class="font-display text-2xl sm:text-[2.5rem] font-bold tracking-tight leading-[1.1]">
            <span class="text-accent">10K</span> <span class="text-text-bright">{locale === 'de' ? 'Tokens die' : locale === 'ar' ? 'رمز تتفوق على' : 'tokens that outperform'}</span> <span class="text-danger/70">200K.</span>
          </p>
          <p class="text-xs text-muted mt-3">{t('manifest.densityHighlightSub')}</p>
        </div>

        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4">
          {t('manifest.densityP3')}
        </p>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.densityP4')} />
      </section>

      <hr class="border-border/20 my-8" />

      <!-- 3: Efficiency Multiplier -->
      <section id="efficiency-multiplier" class="scroll-mt-20 mb-12">
        <h2 class="font-display text-lg sm:text-xl font-semibold text-text-bright tracking-tight mb-5">{t('manifest.efficiencyTitle')}</h2>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4" set:html={t('manifest.efficiencyP1')} />

        <div class="my-8 flex items-center gap-8 sm:gap-12">
          <div>
            <p class="stat-value text-4xl sm:text-5xl text-accent-2 mb-1">5x</p>
            <p class="text-xs text-muted">{t('manifest.efficiencyStat1')}</p>
          </div>
          <div>
            <p class="stat-value text-4xl sm:text-5xl text-accent mb-1">80%</p>
            <p class="text-xs text-muted">{t('manifest.efficiencyStat2')}</p>
            <p class="text-[10px] text-muted/50 mt-1">{t('manifest.efficiencyStat2Note')}</p>
          </div>
        </div>

        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4">
          {t('manifest.efficiencyP2')}
        </p>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.efficiencyP3')} />
      </section>

      <hr class="border-border/20 my-8" />

      <!-- 4: Architecture -->
      <section id="architecture" class="scroll-mt-20 mb-12">
        <h2 class="font-display text-lg sm:text-xl font-semibold text-text-bright tracking-tight mb-5">{t('manifest.archTitle')}</h2>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-6">
          {t('manifest.archP1')}
        </p>

        <div class="space-y-6 mb-8">
          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mt-0.5">
              <span class="text-[10px] font-bold text-accent">1</span>
            </div>
            <div>
              <h3 class="text-base font-medium text-text-bright mb-1 font-display">{t('manifest.archLayer1Title')} <span class="text-[10px] font-semibold text-accent bg-accent/10 border border-accent/20 px-1.5 py-0.5 rounded-full ml-2">{t('manifest.archLayer1Status')}</span></h3>
              <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.archLayer1Desc')} />
            </div>
          </div>

          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mt-0.5">
              <span class="text-[10px] font-bold text-accent">2</span>
            </div>
            <div>
              <h3 class="text-base font-medium text-text-bright mb-1 font-display">{t('manifest.archLayer2Title')} <span class="text-[10px] font-semibold text-accent bg-accent/10 border border-accent/20 px-1.5 py-0.5 rounded-full ml-2">{t('manifest.archLayer2Status')}</span></h3>
              <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.archLayer2Desc')} />
            </div>
          </div>

          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mt-0.5">
              <span class="text-[10px] font-bold text-accent">3</span>
            </div>
            <div>
              <h3 class="text-base font-medium text-text-bright mb-1 font-display">{t('manifest.archLayer3Title')} <span class="text-[10px] font-semibold text-accent bg-accent/10 border border-accent/20 px-1.5 py-0.5 rounded-full ml-2">{t('manifest.archLayer3Status')}</span></h3>
              <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.archLayer3Desc')} />
            </div>
          </div>

          <div class="flex gap-4">
            <div class="shrink-0 w-6 h-6 rounded-full bg-accent-3/10 border border-accent-3/20 flex items-center justify-center mt-0.5">
              <span class="text-[10px] font-bold text-accent-3">4</span>
            </div>
            <div>
              <h3 class="text-base font-medium text-text-bright mb-1 font-display">{t('manifest.archLayer4Title')} <span class="text-[10px] font-semibold text-accent-3 bg-accent-3/10 border border-accent-3/20 px-1.5 py-0.5 rounded-full ml-2">{t('manifest.archLayer4Status')}</span></h3>
              <p class="text-sm sm:text-[15px] text-muted leading-[1.8]">
                {t('manifest.archLayer4Desc')}
              </p>
            </div>
          </div>
        </div>

        <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.archP2')} />
      </section>

      <hr class="border-border/20 my-8" />

      <!-- 5: The Shift -->
      <section id="the-shift" class="scroll-mt-20 mb-12">
        <h2 class="font-display text-lg sm:text-xl font-semibold text-text-bright tracking-tight mb-5">{t('manifest.shiftTitle')}</h2>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-6">
          {t('manifest.shiftP1')}
        </p>

        <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0 mb-6">
          <table class="w-full text-xs sm:text-sm mb-0">
            <thead>
              <tr class="border-b border-border/30">
                <th class="text-left text-[11px] sm:text-xs uppercase tracking-wider text-muted pb-3 pr-3 font-display whitespace-nowrap">{t('manifest.tableDimension')}</th>
                <th class="text-left text-[11px] sm:text-xs uppercase tracking-wider text-muted pb-3 pr-3 font-display whitespace-nowrap">{t('manifest.tableBefore')}</th>
                <th class="text-left text-[11px] sm:text-xs uppercase tracking-wider text-accent pb-3 font-display whitespace-nowrap">{t('manifest.tableAfter')}</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-border/15"><td class="py-2.5 pr-3 text-text-bright font-medium">{t('manifest.tableRow1d')}</td><td class="py-2.5 pr-3 text-muted">{t('manifest.tableRow1b')}</td><td class="py-2.5 text-text">{t('manifest.tableRow1a')}</td></tr>
              <tr class="border-b border-border/15"><td class="py-2.5 pr-3 text-text-bright font-medium">{t('manifest.tableRow2d')}</td><td class="py-2.5 pr-3 text-muted">{t('manifest.tableRow2b')}</td><td class="py-2.5 text-text">{t('manifest.tableRow2a')}</td></tr>
              <tr class="border-b border-border/15"><td class="py-2.5 pr-3 text-text-bright font-medium">{t('manifest.tableRow3d')}</td><td class="py-2.5 pr-3 text-muted">{t('manifest.tableRow3b')}</td><td class="py-2.5 text-text">{t('manifest.tableRow3a')}</td></tr>
              <tr class="border-b border-border/15"><td class="py-2.5 pr-3 text-text-bright font-medium">{t('manifest.tableRow4d')}</td><td class="py-2.5 pr-3 text-muted">{t('manifest.tableRow4b')}</td><td class="py-2.5 text-text">{t('manifest.tableRow4a')}</td></tr>
              <tr class="border-b border-border/15"><td class="py-2.5 pr-3 text-text-bright font-medium">{t('manifest.tableRow5d')}</td><td class="py-2.5 pr-3 text-muted">{t('manifest.tableRow5b')}</td><td class="py-2.5 text-text">{t('manifest.tableRow5a')}</td></tr>
              <tr class="border-b border-border/15"><td class="py-2.5 pr-3 text-text-bright font-medium">{t('manifest.tableRow6d')}</td><td class="py-2.5 pr-3 text-muted">{t('manifest.tableRow6b')}</td><td class="py-2.5 text-text">{t('manifest.tableRow6a')}</td></tr>
              <tr><td class="py-2.5 pr-3 text-text-bright font-medium">{t('manifest.tableRow7d')}</td><td class="py-2.5 pr-3 text-muted">{t('manifest.tableRow7b')}</td><td class="py-2.5 text-text">{t('manifest.tableRow7a')}</td></tr>
            </tbody>
          </table>
        </div>

        <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.shiftP2')} />
      </section>

      <hr class="border-border/20 my-8" />

      <!-- 6: Design Principles -->
      <section id="design-principles" class="scroll-mt-20 mb-12">
        <h2 class="font-display text-lg sm:text-xl font-semibold text-text-bright tracking-tight mb-5">{t('manifest.principlesTitle')}</h2>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-6">
          {t('manifest.principlesP1')}
        </p>

        <div class="space-y-6">
          <div>
            <h3 class="text-base font-medium text-text-bright mb-1 font-display">{t('manifest.principle1Title')}</h3>
            <p class="text-sm sm:text-[15px] text-muted leading-[1.8]">
              {t('manifest.principle1Desc')}
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-text-bright mb-1 font-display">{t('manifest.principle2Title')}</h3>
            <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.principle2Desc')} />
          </div>

          <div>
            <h3 class="text-base font-medium text-text-bright mb-1 font-display">{t('manifest.principle3Title')}</h3>
            <p class="text-sm sm:text-[15px] text-muted leading-[1.8]">
              {t('manifest.principle3Desc')}
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-text-bright mb-1 font-display">{t('manifest.principle4Title')}</h3>
            <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.principle4Desc')} />
          </div>

          <div>
            <h3 class="text-base font-medium text-text-bright mb-1 font-display">{t('manifest.principle5Title')}</h3>
            <p class="text-sm sm:text-[15px] text-muted leading-[1.8]" set:html={t('manifest.principle5Desc')} />
          </div>
        </div>
      </section>

      <hr class="border-border/20 my-8" />

      <!-- 7: Conclusion -->
      <section id="conclusion" class="scroll-mt-20 mb-12">
        <h2 class="font-display text-lg sm:text-xl font-semibold text-text-bright tracking-tight mb-5">{t('manifest.conclusionTitle')}</h2>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4">
          {t('manifest.conclusionP1')}
        </p>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-4" set:html={t('manifest.conclusionP2')} />
        <blockquote class="border-l-2 border-accent/40 pl-4 py-0.5 text-muted italic bg-accent/[0.02] rounded-r-lg mb-6">
          <p class="text-sm sm:text-[15px] leading-[1.8]">
            {t('manifest.conclusionQuote')}
          </p>
        </blockquote>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8]">
          {t('manifest.conclusionCta')} <a href={lp('/docs/getting-started')} class="text-accent underline underline-offset-2 decoration-accent/30 hover:decoration-accent">{t('manifest.getStartedLink')}</a>
        </p>
      </section>

      <!-- CTA -->
      <div class="pt-8 border-t border-border/20">
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={lp('/docs/getting-started')} class="btn-glossy inline-flex items-center justify-center px-8 py-3.5 text-sm font-bold rounded-xl text-bg">
            {t('manifest.getStarted')}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="https://github.com/yvgude/lean-ctx" target="_blank" rel="noopener" class="btn-outline-glossy inline-flex items-center justify-center px-8 py-3.5 text-sm font-medium rounded-xl text-text">
            {t('manifest.readTheSource')}
          </a>
        </div>
      </div>

    </article>
    </div>
  </div>
</BaseLayout>

<style>
  .manifest-toc-link.active {
    color: var(--color-accent);
    background: rgba(52, 211, 153, 0.06);
  }
  .manifest-toc-link.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    bottom: 4px;
    width: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }
  .manifest-toc-link {
    position: relative;
  }

  .manifest-mobile-nav {
    background: var(--color-surface);
    border: 1px solid rgba(26, 26, 48, 0.5);
    border-radius: 12px;
  }
  .manifest-mobile-nav summary {
    list-style: none;
  }
  .manifest-mobile-nav summary::-webkit-details-marker {
    display: none;
  }
  .manifest-mobile-nav[open] {
    border-color: rgba(52, 211, 153, 0.15);
  }

  :global(.manifest-article strong) {
    color: var(--color-text-bright);
    font-weight: 600;
  }
  :global(.manifest-article code) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--color-surface-2);
    padding: 0.1rem 0.375rem;
    border-radius: 0.375rem;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
  }
  :global(.manifest-article em) {
    font-style: italic;
  }
</style>

<script>
  const links = document.querySelectorAll('.manifest-toc-link');
  const sections = document.querySelectorAll('article section[id]');

  function updateActive() {
    let current = '';
    sections.forEach(s => {
      const rect = s.getBoundingClientRect();
      if (rect.top <= 120) current = s.id;
    });
    links.forEach(l => {
      l.classList.toggle('active', l.getAttribute('href') === `#${current}`);
    });
  }

  window.addEventListener('scroll', updateActive, { passive: true });
  updateActive();
</script>
