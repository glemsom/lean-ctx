---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalizedPath(path, locale);
---

<BaseLayout title="LeanCTX Cloud Login" description="Complete your LeanCTX Cloud login.">
  <section class="content-grid py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <div class="glass-panel p-8 md:p-10 animate-entrance">
        <h1 class="text-2xl md:text-3xl font-display text-text-bright">Signing you in…</h1>
        <p class="mt-3 text-sm text-muted">
          Wenn du nicht automatisch weitergeleitet wirst, öffne <a class="text-accent underline" href={lp('/dashboard')}>/dashboard</a>.
        </p>
        <div id="authError" class="mt-6 hidden rounded-xl border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-200"></div>
      </div>
    </div>
  </section>

  <script type="module" define:vars={{ cloudUrl: lp('/dashboard') }}>
    const API_BASE = 'https://api.leanctx.com';
    const el = document.getElementById('authError');
    const url = new URL(window.location.href);
    const token = url.searchParams.get('token');

    async function run() {
      if (!token) {
        el.classList.remove('hidden');
        el.textContent = 'Missing token.';
        return;
      }
      try {
        const res = await fetch(API_BASE + '/api/auth/exchange?token=' + encodeURIComponent(token));
        if (!res.ok) {
          const msg = await res.text();
          throw new Error(msg || 'Login failed');
        }
        const data = await res.json();
        if (data?.token) {
          localStorage.setItem('leanctx_token', data.token);
        }
        window.location.replace(cloudUrl);
      } catch (e) {
        el.classList.remove('hidden');
        el.textContent = e?.message || 'Login failed';
      }
    }
    run();
  </script>
</BaseLayout>

