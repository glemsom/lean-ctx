---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);
---

<BaseLayout title={t('shellHook.title')} description={t('shellHook.metaDescription')} breadcrumbs={[{ name: t('common.home'), url: lp('/') }, { name: t('shellHook.heroLabel'), url: lp('/shell-hook/') }]}>

<!-- ═══════ HERO ═══════ -->
<section class="section-hero">
  <div class="content-grid">
    <div class="animate-entrance">
      <p class="fluid-label text-muted" style="margin-bottom: clamp(1.25rem, 1rem + 1vw, 2.5rem);">{t('shellHook.heroLabel')}</p>
    </div>
    <h1 class="font-display fluid-h1 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1.5rem, 1rem + 1.5vw, 3rem);">
      {t('shellHook.heroTitle')}<br/><span class="gradient-text">{t('shellHook.heroTitleHighlight')}</span>
    </h1>
    <p class="fluid-body text-muted animate-entrance stagger-2" style="margin-bottom: clamp(2.5rem, 2rem + 2vw, 5rem); max-width: 44rem;" set:html={t('shellHook.heroDesc')} />
    <div class="animate-entrance stagger-3 flex flex-wrap items-center gap-3">
      <span class="sh-hero-stat"><span class="text-accent font-bold">34+</span> {t('shellHook.heroStatCategories')}</span>
      <span class="sh-hero-stat"><span class="text-accent font-bold">90+</span> {t('shellHook.heroStatPatterns')}</span>
      <span class="sh-hero-stat"><span class="text-accent font-bold">60–90%</span> {t('shellHook.heroStatReduction')}</span>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ HOW IT WORKS ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">{t('shellHook.flowLabel')}</p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('shellHook.flowTitle')} <span class="gradient-text">{t('shellHook.flowTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;" set:html={t('shellHook.flowDesc')} />

    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 sm:gap-0 animate-entrance">
      <div class="sh-flow-step">
        <div class="sh-flow-num">1</div>
        <h3 class="fluid-h3 font-semibold text-text-bright mb-1 font-display">{t('shellHook.flowStep1')}</h3>
        <p class="fluid-sm text-muted" set:html={t('shellHook.flowStep1Desc')} />
      </div>
      <div class="sh-flow-step relative">
        <div class="hidden sm:block sh-flow-arrow" style="left:-16px" aria-hidden="true"></div>
        <div class="sh-flow-num text-accent">2</div>
        <h3 class="fluid-h3 font-semibold text-accent mb-1 font-display">{t('shellHook.flowStep2')}</h3>
        <p class="fluid-sm text-muted" set:html={t('shellHook.flowStep2Desc')} />
      </div>
      <div class="sh-flow-step relative">
        <div class="hidden sm:block sh-flow-arrow" style="left:-16px" aria-hidden="true"></div>
        <div class="sh-flow-num text-accent">3</div>
        <h3 class="fluid-h3 font-semibold text-accent mb-1 font-display">{t('shellHook.flowStep3')}</h3>
        <p class="fluid-sm text-muted">{t('shellHook.flowStep3Desc')}</p>
      </div>
      <div class="sh-flow-step relative">
        <div class="hidden sm:block sh-flow-arrow" style="left:-16px" aria-hidden="true"></div>
        <div class="sh-flow-num">4</div>
        <h3 class="fluid-h3 font-semibold text-text-bright mb-1 font-display">{t('shellHook.flowStep4')}</h3>
        <p class="fluid-sm text-muted">{t('shellHook.flowStep4Desc')}</p>
      </div>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ SUPPORTED CATEGORIES ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">{t('shellHook.categoriesLabel')}</p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('shellHook.categoriesTitle')} <span class="gradient-text">{t('shellHook.categoriesTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('shellHook.categoriesDesc')}
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="sh-category-card card animate-entrance">
        <h3 class="fluid-h3 font-bold font-display text-text-bright mb-3">{t('shellHook.catVersionControl')}</h3>
        <div class="flex flex-wrap gap-1.5">
          <span class="sh-badge">git status</span>
          <span class="sh-badge">git diff</span>
          <span class="sh-badge">git log</span>
          <span class="sh-badge">git branch</span>
          <span class="sh-badge">git stash</span>
          <span class="sh-badge">git remote</span>
        </div>
      </div>
      <div class="sh-category-card card animate-entrance">
        <h3 class="fluid-h3 font-bold font-display text-text-bright mb-3">{t('shellHook.catJavaScript')}</h3>
        <div class="flex flex-wrap gap-1.5">
          <span class="sh-badge">npm install</span>
          <span class="sh-badge">npm run</span>
          <span class="sh-badge">npm test</span>
          <span class="sh-badge">yarn</span>
          <span class="sh-badge">pnpm</span>
          <span class="sh-badge">tsc</span>
        </div>
      </div>
      <div class="sh-category-card card animate-entrance">
        <h3 class="fluid-h3 font-bold font-display text-text-bright mb-3">{t('shellHook.catRust')}</h3>
        <div class="flex flex-wrap gap-1.5">
          <span class="sh-badge">cargo build</span>
          <span class="sh-badge">cargo test</span>
          <span class="sh-badge">cargo clippy</span>
          <span class="sh-badge">cargo check</span>
          <span class="sh-badge">cargo run</span>
        </div>
      </div>
      <div class="sh-category-card card animate-entrance">
        <h3 class="fluid-h3 font-bold font-display text-text-bright mb-3">{t('shellHook.catContainers')}</h3>
        <div class="flex flex-wrap gap-1.5">
          <span class="sh-badge">docker ps</span>
          <span class="sh-badge">docker build</span>
          <span class="sh-badge">docker logs</span>
          <span class="sh-badge">kubectl get</span>
          <span class="sh-badge">kubectl describe</span>
        </div>
      </div>
      <div class="sh-category-card card animate-entrance">
        <h3 class="fluid-h3 font-bold font-display text-text-bright mb-3">{t('shellHook.catPython')}</h3>
        <div class="flex flex-wrap gap-1.5">
          <span class="sh-badge">pip install</span>
          <span class="sh-badge">pytest</span>
          <span class="sh-badge">python -m</span>
          <span class="sh-badge">poetry</span>
          <span class="sh-badge">uv</span>
        </div>
      </div>
      <div class="sh-category-card card animate-entrance">
        <h3 class="fluid-h3 font-bold font-display text-text-bright mb-3">{t('shellHook.catSystem')}</h3>
        <div class="flex flex-wrap gap-1.5">
          <span class="sh-badge">ls / find</span>
          <span class="sh-badge">ps / top</span>
          <span class="sh-badge">curl</span>
          <span class="sh-badge">make</span>
          <span class="sh-badge">env</span>
          <span class="sh-badge">cat / head</span>
        </div>
      </div>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ BEFORE / AFTER ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">{t('shellHook.beforeAfterLabel')}</p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem);">
      {t('shellHook.beforeAfterTitle')} <span class="gradient-text">{t('shellHook.beforeAfterTitleHighlight')}</span>
    </h2>

    <div class="grid md:grid-cols-2 animate-entrance" style="gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);">
      <!-- Before -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-block w-2 h-2 rounded-full bg-danger"></span>
          <span class="text-[12px] font-semibold text-text-bright uppercase tracking-wider font-display">{t('shellHook.withoutHook')}</span>
          <span class="text-[11px] text-muted font-mono ml-auto">~580 tokens</span>
        </div>
        <div class="terminal-chrome">
          <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
            <span class="terminal-dot bg-[#ff5f57]"></span>
            <span class="terminal-dot bg-[#febc2e]"></span>
            <span class="terminal-dot bg-[#28c840]"></span>
            <span class="text-muted text-[11px] ml-2 font-mono">git status</span>
          </div>
          <div class="px-4 py-3">
            <pre class="text-[10px] sm:text-[11px] font-mono leading-relaxed text-muted whitespace-pre">On branch feature/auth
Your branch is ahead of 'origin/feature/auth'
by 3 commits.
  (use "git push" to publish your local
   commits)

Changes to be committed:
  (use "git restore --staged &lt;file&gt;..."
   to unstage)
        new file:   src/session.ts
        modified:   src/login.ts
        modified:   src/api.ts

Changes not staged for commit:
  (use "git add &lt;file&gt;..." to update
   what will be committed)
  (use "git restore &lt;file&gt;..." to
   discard changes in working directory)
        modified:   src/session.ts

Untracked files:
  (use "git add &lt;file&gt;..." to include
   in what will be committed)
        src/session.test.ts</pre>
          </div>
        </div>
      </div>

      <!-- After -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-block w-2 h-2 rounded-full bg-accent"></span>
          <span class="text-[12px] font-semibold text-text-bright uppercase tracking-wider font-display">{t('shellHook.withHook')}</span>
          <span class="text-[11px] text-accent font-mono ml-auto">~75 tokens</span>
        </div>
        <div class="terminal-chrome">
          <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
            <span class="terminal-dot bg-[#ff5f57]"></span>
            <span class="terminal-dot bg-[#febc2e]"></span>
            <span class="terminal-dot bg-[#28c840]"></span>
            <span class="text-muted text-[11px] ml-2 font-mono">git status (compressed)</span>
          </div>
          <div class="px-4 py-3">
            <pre class="text-[10px] sm:text-[11px] font-mono leading-relaxed text-text whitespace-pre"><span class="text-accent">feature/auth</span> <span class="text-muted">↑3</span>
staged: <span class="text-accent">+</span>session.ts <span class="text-[#eab308]">~</span>login.ts <span class="text-[#eab308]">~</span>api.ts
unstaged: <span class="text-[#eab308]">~</span>session.ts
untracked: session.test.ts
<span class="text-muted/50">[534 tok saved (87%)]</span></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ MORE EXAMPLES ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">{t('shellHook.moreExamplesLabel')}</p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem);">
      {t('shellHook.moreExamplesTitle')} <span class="gradient-text">{t('shellHook.moreExamplesTitleHighlight')}</span>
    </h2>

    <div class="grid md:grid-cols-2 animate-entrance" style="gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem); margin-bottom: clamp(2rem, 1.5rem + 1.5vw, 3rem);">
      <!-- npm install Before -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-block w-2 h-2 rounded-full bg-danger"></span>
          <span class="text-[12px] font-semibold text-text-bright uppercase tracking-wider font-display">{t('shellHook.npmRaw')}</span>
          <span class="text-[11px] text-muted font-mono ml-auto">~420 tokens</span>
        </div>
        <div class="terminal-chrome">
          <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
            <span class="terminal-dot bg-[#ff5f57]"></span>
            <span class="terminal-dot bg-[#febc2e]"></span>
            <span class="terminal-dot bg-[#28c840]"></span>
            <span class="text-muted text-[11px] ml-2 font-mono">npm install</span>
          </div>
          <div class="px-4 py-3">
            <pre class="text-[10px] sm:text-[11px] font-mono leading-relaxed text-muted whitespace-pre">npm warn deprecated inflight@1.0.6:
  This module is not supported...
npm warn deprecated glob@7.2.3:
  Glob versions prior to v9...
npm warn deprecated rimraf@3.0.2:
  Rimraf versions prior to v4...

added 847 packages, and audited
848 packages in 12s

127 packages are looking for funding
  run `npm fund` for details

found 0 vulnerabilities</pre>
          </div>
        </div>
      </div>
      <!-- npm install After -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-block w-2 h-2 rounded-full bg-accent"></span>
          <span class="text-[12px] font-semibold text-text-bright uppercase tracking-wider font-display">{t('shellHook.npmCompressed')}</span>
          <span class="text-[11px] text-accent font-mono ml-auto">~35 tokens</span>
        </div>
        <div class="terminal-chrome">
          <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
            <span class="terminal-dot bg-[#ff5f57]"></span>
            <span class="terminal-dot bg-[#febc2e]"></span>
            <span class="terminal-dot bg-[#28c840]"></span>
            <span class="text-muted text-[11px] ml-2 font-mono">npm install (compressed)</span>
          </div>
          <div class="px-4 py-3">
            <pre class="text-[10px] sm:text-[11px] font-mono leading-relaxed text-text whitespace-pre"><span class="text-accent">✓</span> 847 packages <span class="text-muted">12s</span>
<span class="text-[#eab308]">⚠</span> 3 deprecated <span class="text-muted">(inflight, glob, rimraf)</span>
<span class="text-accent">0</span> vulnerabilities
<span class="text-muted/50">[385 tok saved (92%)]</span></pre>
          </div>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 animate-entrance" style="gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);">
      <!-- cargo build Before -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-block w-2 h-2 rounded-full bg-danger"></span>
          <span class="text-[12px] font-semibold text-text-bright uppercase tracking-wider font-display">{t('shellHook.cargoRaw')}</span>
          <span class="text-[11px] text-muted font-mono ml-auto">~310 tokens</span>
        </div>
        <div class="terminal-chrome">
          <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
            <span class="terminal-dot bg-[#ff5f57]"></span>
            <span class="terminal-dot bg-[#febc2e]"></span>
            <span class="terminal-dot bg-[#28c840]"></span>
            <span class="text-muted text-[11px] ml-2 font-mono">cargo build</span>
          </div>
          <div class="px-4 py-3">
            <pre class="text-[10px] sm:text-[11px] font-mono leading-relaxed text-muted whitespace-pre">   Compiling proc-macro2 v1.0.86
   Compiling unicode-ident v1.0.12
   Compiling syn v2.0.72
   Compiling serde_derive v1.0.204
   Compiling serde v1.0.204
   Compiling tokio v1.39.2
   Compiling lean-ctx v2.1.0
    Finished `dev` profile [unoptimized
    + debuginfo] target(s) in 24.3s</pre>
          </div>
        </div>
      </div>
      <!-- cargo build After -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-block w-2 h-2 rounded-full bg-accent"></span>
          <span class="text-[12px] font-semibold text-text-bright uppercase tracking-wider font-display">{t('shellHook.cargoCompressed')}</span>
          <span class="text-[11px] text-accent font-mono ml-auto">~30 tokens</span>
        </div>
        <div class="terminal-chrome">
          <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
            <span class="terminal-dot bg-[#ff5f57]"></span>
            <span class="terminal-dot bg-[#febc2e]"></span>
            <span class="terminal-dot bg-[#28c840]"></span>
            <span class="text-muted text-[11px] ml-2 font-mono">cargo build (compressed)</span>
          </div>
          <div class="px-4 py-3">
            <pre class="text-[10px] sm:text-[11px] font-mono leading-relaxed text-text whitespace-pre"><span class="text-accent">✓</span> build dev <span class="text-muted">24.3s</span>
<span class="text-muted">7 crates compiled</span>
<span class="text-muted/50">[280 tok saved (90%)]</span></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ WORKS WITHOUT MCP ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <div class="animate-entrance" style="max-width: 48rem;">
      <div class="card sh-callout-card">
        <div class="flex items-start gap-4">
          <div class="sh-callout-icon flex-shrink-0">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <h3 class="fluid-h3 font-bold font-display text-text-bright mb-2">{t('shellHook.worksIndependentlyTitle')}</h3>
            <p class="fluid-body text-muted mb-4" set:html={t('shellHook.worksIndependentlyDesc')} />
            <div class="flex flex-wrap gap-2">
              <span class="sh-compat-tag">Cursor</span>
              <span class="sh-compat-tag">Claude Code</span>
              <span class="sh-compat-tag">GitHub Copilot</span>
              <span class="sh-compat-tag">Aider</span>
              <span class="sh-compat-tag">Any shell-based AI</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ STATS ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">{t('shellHook.coverageLabel')}</p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem);">
      {t('shellHook.coverageTitle')} <span class="gradient-text">{t('shellHook.coverageTitleHighlight')}</span>
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 animate-entrance">
      <div class="sh-stat-card card">
        <div class="sh-stat-value">34+</div>
        <div class="fluid-sm text-muted">{t('shellHook.statCategories')}</div>
      </div>
      <div class="sh-stat-card card">
        <div class="sh-stat-value">90+</div>
        <div class="fluid-sm text-muted">{t('shellHook.statPatterns')}</div>
      </div>
      <div class="sh-stat-card card">
        <div class="sh-stat-value">87%</div>
        <div class="fluid-sm text-muted">{t('shellHook.statGitCompression')}</div>
      </div>
      <div class="sh-stat-card card">
        <div class="sh-stat-value">0</div>
        <div class="fluid-sm text-muted">{t('shellHook.statConfigRequired')}</div>
      </div>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ CTA ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('shellHook.rawModeTitle')} <span class="gradient-text">{t('shellHook.rawModeTitleHighlight')}</span>
    </h2>
    <p class="fluid-body text-muted" style="margin-bottom: clamp(1.5rem, 1rem + 1vw, 2.5rem); max-width: 44rem;" set:html={t('shellHook.rawModeDesc')} />
    <pre style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; padding: 1.25rem; overflow-x: auto;"><code style="font-size: 0.85rem;"># CLI flag — skip compression for one command
lean-ctx -c --raw kubectl get pods -o yaml

# Shell function — quick bypass
lean-ctx-raw gh pr view 42

# Kill-switch — disable ALL compression
LEAN_CTX_DISABLED=1 lean-ctx -c git log

# MCP parameter — for AI agents
ctx_shell(command="cat config.json", raw=true)</code></pre>
  </div>
</section>

<section class="section-y">
  <div class="content-grid">
    <h2 class="font-display fluid-h2 font-bold text-text-bright" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('shellHook.ctaTitle')} <span class="gradient-text">{t('shellHook.ctaTitleHighlight')}</span>
    </h2>
    <p class="fluid-body text-muted" style="margin-bottom: clamp(2.5rem, 2rem + 2vw, 5rem); max-width: 44rem;" set:html={t('shellHook.ctaDesc')} />
    <div class="flex flex-wrap items-center gap-3">
      <a href={lp('/docs/getting-started')} class="btn-primary inline-flex items-center font-bold rounded-lg text-bg" style="padding: clamp(0.7rem, 0.55rem + 0.3vw, 0.9rem) clamp(1.5rem, 1rem + 0.75vw, 2.25rem); font-size: clamp(0.8125rem, 0.78rem + 0.15vw, 0.9375rem);">
        {t('common.getStarted')}
