---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: t('howItWorks.faq1Q'),
      acceptedAnswer: { '@type': 'Answer', text: t('howItWorks.faq1A') }
    },
    {
      '@type': 'Question',
      name: t('howItWorks.faq2Q'),
      acceptedAnswer: { '@type': 'Answer', text: t('howItWorks.faq2A') }
    },
    {
      '@type': 'Question',
      name: t('howItWorks.faq3Q'),
      acceptedAnswer: { '@type': 'Answer', text: t('howItWorks.faq3A') }
    },
    {
      '@type': 'Question',
      name: t('howItWorks.faq4Q'),
      acceptedAnswer: { '@type': 'Answer', text: t('howItWorks.faq4A') }
    }
  ]
});
---

<BaseLayout title={t('howItWorks.metaTitle')} description={t('howItWorks.metaDescription')}
  breadcrumbs={[{ name: t('common.home'), url: lp('/') }, { name: t('howItWorks.breadcrumb'), url: lp('/how-it-works/') }]}
  extraJsonLd={faqSchema}>

<!-- ═══════ HERO ═══════ -->
<section class="section-hero">
  <div class="content-grid">
    <div class="animate-entrance">
      <p class="fluid-label text-muted" style="margin-bottom: clamp(1.25rem, 1rem + 1vw, 2.5rem);">
        {t('howItWorks.heroLabel')}
      </p>
    </div>
    <h1 class="font-display fluid-h1 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1.5rem, 1rem + 1.5vw, 3rem);">
      {t('howItWorks.heroTitle')}<br/>
      <span class="gradient-text">{t('howItWorks.heroTitleHighlight')}</span>
    </h1>
    <p class="fluid-body text-muted animate-entrance stagger-2" style="margin-bottom: clamp(2.5rem, 2rem + 2vw, 5rem); max-width: 44rem;" set:html={t('howItWorks.heroDesc')} />
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ DATA FLOW ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.dataFlowLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.dataFlowTitle')} <span class="gradient-text">{t('howItWorks.dataFlowTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('howItWorks.dataFlowDesc')}
    </p>

    <div class="animate-entrance">
      <div class="terminal-chrome">
        <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
          <span class="terminal-dot bg-[#ff5f57]"></span>
          <span class="terminal-dot bg-[#febc2e]"></span>
          <span class="terminal-dot bg-[#28c840]"></span>
          <span class="text-muted text-[11px] ml-2 font-mono">data flow — before vs. after</span>
        </div>
        <div class="px-4 sm:px-6 py-4 sm:py-5">
          <pre class="text-[11px] sm:text-[13px] font-mono leading-[1.8] text-text whitespace-pre"><span class="text-muted/60">Without lean-ctx:</span>

<span class="text-text-bright">You</span>  →  <span class="text-text-bright">AI Tool</span>  →  reads file  <span class="text-muted">(full content)</span>  →  <span class="text-red-400">LLM processes everything</span>

<span class="text-muted/60">With lean-ctx:</span>

<span class="text-text-bright">You</span>  →  <span class="text-text-bright">AI Tool</span>  →  <span class="text-accent font-bold">lean-ctx</span> compresses  →  <span class="text-accent">signal only</span>  →  <span class="text-accent font-bold">LLM: 60–90% less noise</span>
                           <span class="text-muted/40">├─ AST-aware compression</span>
                           <span class="text-muted/40">├─ Session cache (re-read ≈ 13 tok)</span>
                           <span class="text-muted/40">└─ 7 read modes per file type</span></pre>
        </div>
      </div>
    </div>

    <div class="grid sm:grid-cols-4 animate-entrance" style="margin-top: clamp(2.5rem, 2rem + 2vw, 4rem); gap: clamp(1px, 0.1vw, 1px);">
      <div class="layer-card">
        <div class="layer-icon" style="color: var(--color-muted);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
        </div>
        <h3 class="font-display fluid-h3 font-semibold text-text-bright" style="margin: 0.75rem 0 0.25rem;">{t('howItWorks.flowYou')}</h3>
        <p class="fluid-sm text-muted leading-relaxed">{t('howItWorks.flowYouDesc')}</p>
      </div>
      <div class="layer-card">
        <div class="layer-icon" style="color: var(--color-accent-2);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/></svg>
        </div>
        <h3 class="font-display fluid-h3 font-semibold text-text-bright" style="margin: 0.75rem 0 0.25rem;">{t('howItWorks.flowAiTool')}</h3>
        <p class="fluid-sm text-muted leading-relaxed">{t('howItWorks.flowAiToolDesc')}</p>
      </div>
      <div class="layer-card" style="border-color: color-mix(in srgb, var(--color-accent) 22%, transparent);">
        <div class="layer-icon" style="color: var(--color-accent);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
        </div>
        <h3 class="font-display fluid-h3 font-semibold text-accent" style="margin: 0.75rem 0 0.25rem;">lean-ctx</h3>
        <p class="fluid-sm text-muted leading-relaxed">{t('howItWorks.flowLeanCtxDesc')}</p>
      </div>
      <div class="layer-card">
        <div class="layer-icon" style="color: var(--color-accent-3);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
        </div>
        <h3 class="font-display fluid-h3 font-semibold text-text-bright" style="margin: 0.75rem 0 0.25rem;">{t('howItWorks.flowLlm')}</h3>
        <p class="fluid-sm text-muted leading-relaxed">{t('howItWorks.flowLlmDesc')}</p>
      </div>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ YOUR PART ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.yourPartLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.yourPartTitlePre')} <span class="gradient-text">{t('howItWorks.yourPartTitleHighlight')}</span> {t('howItWorks.yourPartTitlePost')}
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('howItWorks.yourPartDesc')}
    </p>

    <div class="grid md:grid-cols-3 mb-14" style="gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);">
      <div class="hiw-step-card card animate-entrance">
        <div class="hiw-step-num">01</div>
        <h3 class="fluid-h3 font-semibold font-display text-text-bright mb-2">{t('howItWorks.step1Title')}</h3>
        <p class="fluid-sm text-muted mb-4">{t('howItWorks.step1Desc')}</p>
        <code class="hiw-step-code">curl -fsSL leanctx.com/install.sh | sh</code>
      </div>
      <div class="hiw-step-card card animate-entrance">
        <div class="hiw-step-num">02</div>
        <h3 class="fluid-h3 font-semibold font-display text-text-bright mb-2">{t('howItWorks.step2Title')}</h3>
        <p class="fluid-sm text-muted mb-4">{t('howItWorks.step2Desc')}</p>
        <code class="hiw-step-code">lean-ctx setup</code>
      </div>
      <div class="hiw-step-card card animate-entrance">
        <div class="hiw-step-num">03</div>
        <h3 class="fluid-h3 font-semibold font-display text-text-bright mb-2">{t('howItWorks.step3Title')}</h3>
        <p class="fluid-sm text-muted mb-4">{t('howItWorks.step3Desc')}</p>
        <span class="hiw-step-code" style="border-color:var(--color-border);color:var(--color-muted);">{t('howItWorks.step3TokensSaved')} <span class="text-accent font-bold">{t('howItWorks.step3Auto')}</span></span>
      </div>
    </div>

    <div class="animate-entrance">
        <p class="fluid-label text-muted font-display mb-4">{t('howItWorks.tableLabel')}</p>
      <div class="rounded-lg border border-border overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface-2">
              <th class="text-left px-4 sm:px-5 py-3 fluid-label text-muted font-display">{t('howItWorks.tableYouCol')}</th>
              <th class="text-left px-4 sm:px-5 py-3 fluid-label text-muted font-display">{t('howItWorks.tableAutoCol')}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border/30">
            <tr>
              <td class="px-4 sm:px-5 py-3 text-text-bright font-mono text-xs">lean-ctx setup</td>
              <td class="px-4 sm:px-5 py-3 text-muted fluid-sm" set:html={t('howItWorks.tableRow1')} />
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"></td>
              <td class="px-4 sm:px-5 py-3 text-muted fluid-sm" set:html={t('howItWorks.tableRow2')} />
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"></td>
              <td class="px-4 sm:px-5 py-3 text-muted fluid-sm" set:html={t('howItWorks.tableRow3')} />
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"></td>
              <td class="px-4 sm:px-5 py-3 text-muted fluid-sm">{t('howItWorks.tableRow4')}</td>
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"></td>
              <td class="px-4 sm:px-5 py-3 text-muted fluid-sm">{t('howItWorks.tableRow5')}</td>
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3 text-muted font-mono text-xs">lean-ctx gain <span class="text-muted/40 font-sans text-[11px]">{t('howItWorks.tableOptional')}</span></td>
              <td class="px-4 sm:px-5 py-3 text-muted fluid-sm">{t('howItWorks.tableRow6')}</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="fluid-sm text-muted/60 mt-4">
        {t('howItWorks.setupGuidePrefix')} <a href={lp('/docs/getting-started')} class="text-accent hover:underline">{t('howItWorks.setupGuideLink')}</a> &nbsp;·&nbsp;
        {t('howItWorks.cliCommandsPrefix')} <a href={lp('/cli')} class="text-accent hover:underline">{t('howItWorks.cliCommandsLink')}</a>
      </p>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ THREE LAYERS ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.layersLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.layersTitle')} <span class="gradient-text">{t('howItWorks.layersTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('howItWorks.layersDesc')}
    </p>

    <div class="grid md:grid-cols-3" style="gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);">

      <a href={lp('/mcp-server')} class="hiw-layer-link card animate-entrance">
        <div class="hiw-layer-badge">{t('howItWorks.layer1Badge')}</div>
        <h3 class="fluid-h3 font-bold font-display text-text-bright mb-2">{t('howItWorks.layer1Title')}</h3>
        <p class="fluid-sm text-muted mb-4">{t('howItWorks.layer1Desc')}</p>
        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="hiw-tool-tag">ctx_read</span>
          <span class="hiw-tool-tag">ctx_shell</span>
          <span class="hiw-tool-tag">ctx_search</span>
          <span class="hiw-tool-tag text-muted/50">+21</span>
        </div>
        <span class="hiw-layer-cta">
          {t('howItWorks.layer1Cta')}
          <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </span>
      </a>

      <a href={lp('/shell-hook')} class="hiw-layer-link card animate-entrance">
        <div class="hiw-layer-badge">{t('howItWorks.layer2Badge')}</div>
        <h3 class="fluid-h3 font-bold font-display text-text-bright mb-2">{t('howItWorks.layer2Title')}</h3>
        <p class="fluid-sm text-muted mb-4">{t('howItWorks.layer2Desc')}</p>
        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="hiw-tool-tag">git</span>
          <span class="hiw-tool-tag">npm</span>
          <span class="hiw-tool-tag">cargo</span>
          <span class="hiw-tool-tag text-muted/50">+85</span>
        </div>
        <span class="hiw-layer-cta">
          {t('howItWorks.layer2Cta')}
          <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </span>
      </a>

      <a href={lp('/protocols')} class="hiw-layer-link card animate-entrance">
        <div class="hiw-layer-badge">{t('howItWorks.layer3Badge')}</div>
        <h3 class="fluid-h3 font-bold font-display text-text-bright mb-2">{t('howItWorks.layer3Title')}</h3>
        <p class="fluid-sm text-muted mb-4">{t('howItWorks.layer3Desc')}</p>
        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="hiw-tool-tag">CEP</span>
          <span class="hiw-tool-tag">CCP</span>
          <span class="hiw-tool-tag">TDD</span>
        </div>
        <p class="fluid-sm text-muted mt-2">{t('howItWorks.layer3Explanation')}</p>
        <span class="hiw-layer-cta">
          {t('howItWorks.layer3Cta')}
          <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </span>
      </a>

    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ SCIENTIFIC COMPRESSION ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.scienceLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.scienceTitle')} <span class="gradient-text">{t('howItWorks.scienceTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('howItWorks.scienceDesc')}
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 animate-entrance stagger-3" style="gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);">
      <div class="card" style="padding: 1.5rem;">
        <h3 class="fluid-h3 font-semibold font-display text-text-bright mb-2">{t('howItWorks.alg1Title')}</h3>
        <p class="fluid-sm text-muted">{t('howItWorks.alg1Desc')}</p>
      </div>
      <div class="card" style="padding: 1.5rem;">
        <h3 class="fluid-h3 font-semibold font-display text-text-bright mb-2">{t('howItWorks.alg2Title')}</h3>
        <p class="fluid-sm text-muted">{t('howItWorks.alg2Desc')}</p>
      </div>
      <div class="card" style="padding: 1.5rem;">
        <h3 class="fluid-h3 font-semibold font-display text-text-bright mb-2">{t('howItWorks.alg3Title')}</h3>
        <p class="fluid-sm text-muted">{t('howItWorks.alg3Desc')}</p>
      </div>
      <div class="card" style="padding: 1.5rem;">
        <h3 class="fluid-h3 font-semibold font-display text-text-bright mb-2">{t('howItWorks.alg4Title')}</h3>
        <p class="fluid-sm text-muted">{t('howItWorks.alg4Desc')}</p>
      </div>
      <div class="card" style="padding: 1.5rem;">
        <h3 class="fluid-h3 font-semibold font-display text-text-bright mb-2">{t('howItWorks.alg5Title')}</h3>
        <p class="fluid-sm text-muted">{t('howItWorks.alg5Desc')}</p>
      </div>
      <div class="card" style="padding: 1.5rem;">
        <h3 class="fluid-h3 font-semibold font-display text-text-bright mb-2">{t('howItWorks.alg6Title')}</h3>
        <p class="fluid-sm text-muted">{t('howItWorks.alg6Desc')}</p>
      </div>
    </div>

    <div class="animate-entrance stagger-4" style="margin-top: clamp(2rem, 1.5rem + 1vw, 3rem);">
      <a href={lp('/docs/intelligence-layer')} class="fluid-sm text-accent hover:underline inline-flex items-center gap-1.5 font-medium">
        {t('howItWorks.scienceLink')}
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ COMPRESSION QUALITY ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.qualityLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('howItWorks.qualityTitle')} <span class="gradient-text">{t('howItWorks.qualityTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('howItWorks.qualityDesc')}
    </p>

    <div class="stats-grid animate-entrance" style="margin-bottom: clamp(2rem, 1.5rem + 1.5vw, 3rem);">
      <div class="stat-item">
        <span class="stat-number font-display text-accent">98%</span>
        <span class="stat-desc">{t('howItWorks.stat1Desc')}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number font-display text-accent-2">97%</span>
        <span class="stat-desc">{t('howItWorks.stat2Desc')}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number font-display text-accent-3">96%</span>
        <span class="stat-desc">{t('howItWorks.stat3Desc')}</span>
      </div>
    </div>

    <div class="animate-entrance">
      <div class="compare-card">
        <div class="compare-header compare-header--good">
