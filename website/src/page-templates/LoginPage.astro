---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);
---

<BaseLayout title={t('dash.loginTitle') + ' — LeanCTX'} description={t('dash.loginSubtitle')}>

<section class="auth-gate">
  <div class="auth-backdrop"></div>
  <div class="auth-center">
    <div class="auth-card animate-entrance">
      <a href={lp('/')} class="auth-logo">
        <svg class="auth-logo-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="7" fill="#0a0a12"/>
          <path d="M6 16L13 9" stroke="#34d399" stroke-width="2.8" stroke-linecap="round"/>
          <path d="M6 16L13 23" stroke="#34d399" stroke-width="2.8" stroke-linecap="round"/>
          <rect x="17" y="10" width="2.2" height="12" rx="1.1" fill="#34d399"/>
          <rect x="22" y="12" width="2.2" height="8" rx="1.1" fill="#34d399" opacity="0.6"/>
          <rect x="27" y="14" width="2.2" height="4" rx="1.1" fill="#34d399" opacity="0.3"/>
        </svg>
        <span class="auth-logo-text font-display"><span class="text-text-bright">Lean</span><span class="text-accent">CTX</span></span>
      </a>

      <div id="authError" class="auth-msg auth-msg--error hidden"></div>
      <div id="authInfo" class="auth-msg auth-msg--success hidden"></div>

      <!-- REGISTER -->
      <div id="formRegister">
        <h1 class="auth-title font-display">{t('dash.registerTitle')}</h1>
        <p class="auth-subtitle">{t('dash.registerSubtitle')}</p>
        <div class="auth-fields">
          <div class="auth-field"><label class="auth-label" for="regEmail">Email</label><input id="regEmail" type="email" autocomplete="email" class="auth-input" placeholder={t('dash.emailPlaceholder')} /></div>
          <div class="auth-field"><label class="auth-label" for="regPassword">{t('dash.passwordLabel')}</label><div class="auth-pw-wrap"><input id="regPassword" type="password" autocomplete="new-password" class="auth-input auth-input--pw" placeholder="••••••••" /><button type="button" class="auth-eye" data-toggle-pw="regPassword" aria-label="Toggle password visibility"><svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button></div></div>
          <div class="auth-field"><label class="auth-label" for="regPasswordConfirm">{t('dash.passwordConfirmLabel')}</label><div class="auth-pw-wrap"><input id="regPasswordConfirm" type="password" autocomplete="new-password" class="auth-input auth-input--pw" placeholder="••••••••" /><button type="button" class="auth-eye" data-toggle-pw="regPasswordConfirm" aria-label="Toggle password visibility"><svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button></div></div>
          <button id="regSubmitBtn" class="auth-submit">{t('dash.registerBtn')}</button>
        </div>
        <p class="auth-switch">{t('dash.haveAccount')} <button class="auth-link" data-goto="login">{t('dash.switchToLogin')}</button></p>
      </div>

      <!-- LOGIN -->
      <div id="formLogin" class="hidden">
        <h1 class="auth-title font-display">{t('dash.loginTitle')}</h1>
        <p class="auth-subtitle">{t('dash.loginSubtitle')}</p>
        <div class="auth-fields">
          <div class="auth-field"><label class="auth-label" for="loginEmail">Email</label><input id="loginEmail" type="email" autocomplete="email" class="auth-input" placeholder={t('dash.emailPlaceholder')} /></div>
          <div class="auth-field"><label class="auth-label" for="loginPassword">{t('dash.passwordLabel')}</label><div class="auth-pw-wrap"><input id="loginPassword" type="password" autocomplete="current-password" class="auth-input auth-input--pw" placeholder="••••••••" /><button type="button" class="auth-eye" data-toggle-pw="loginPassword" aria-label="Toggle password visibility"><svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button></div></div>
          <button id="loginSubmitBtn" class="auth-submit">{t('dash.loginBtn')}</button>
        </div>
        <div class="auth-switch-row">
          <button class="auth-link" data-goto="forgot">{t('dash.forgotPassword')}</button>
          <span class="auth-switch-sep">·</span>
          <span>{t('dash.noAccountYet')} <button class="auth-link" data-goto="register">{t('dash.switchToRegister')}</button></span>
        </div>
      </div>

      <!-- FORGOT -->
      <div id="formForgot" class="hidden">
        <h1 class="auth-title font-display">{t('dash.forgotTitle')}</h1>
        <p class="auth-subtitle">{t('dash.forgotSubtitle')}</p>
        <div class="auth-fields">
          <div class="auth-field"><label class="auth-label" for="forgotEmail">Email</label><input id="forgotEmail" type="email" autocomplete="email" class="auth-input" placeholder={t('dash.emailPlaceholder')} /></div>
          <button id="forgotSubmitBtn" class="auth-submit">{t('dash.forgotBtn')}</button>
        </div>
        <p class="auth-switch"><button class="auth-link" data-goto="login">{t('dash.backToLogin')}</button></p>
      </div>

      <!-- RESET -->
      <div id="formReset" class="hidden">
        <h1 class="auth-title font-display">{t('dash.resetTitle')}</h1>
        <p class="auth-subtitle">{t('dash.resetSubtitle')}</p>
        <div class="auth-fields">
          <div class="auth-field"><label class="auth-label" for="resetPassword">{t('dash.newPasswordLabel')}</label><div class="auth-pw-wrap"><input id="resetPassword" type="password" autocomplete="new-password" class="auth-input auth-input--pw" placeholder="••••••••" /><button type="button" class="auth-eye" data-toggle-pw="resetPassword" aria-label="Toggle password visibility"><svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button></div></div>
          <div class="auth-field"><label class="auth-label" for="resetPasswordConfirm">{t('dash.passwordConfirmLabel')}</label><div class="auth-pw-wrap"><input id="resetPasswordConfirm" type="password" autocomplete="new-password" class="auth-input auth-input--pw" placeholder="••••••••" /><button type="button" class="auth-eye" data-toggle-pw="resetPasswordConfirm" aria-label="Toggle password visibility"><svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button></div></div>
          <button id="resetSubmitBtn" class="auth-submit">{t('dash.resetBtn')}</button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .auth-gate { position: relative; min-height: calc(100vh - 4rem); display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .auth-backdrop { position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 20%, rgba(52,211,153,0.06) 0%, transparent 50%), radial-gradient(ellipse at 70% 80%, rgba(96,165,250,0.04) 0%, transparent 50%); pointer-events: none; }
  .auth-center { position: relative; z-index: 1; width: 100%; max-width: 28rem; padding: 2rem 1rem; }
  .auth-card { background: rgba(255,255,255,0.02); backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px; padding: clamp(2rem, 1.5rem + 2vw, 3rem); box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04); }
  .auth-logo { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 2.5rem; text-decoration: none; }
  .auth-logo-icon { width: 2rem; height: 2rem; flex-shrink: 0; }
  .auth-logo-text { font-size: 1.125rem; font-weight: 700; letter-spacing: -0.02em; }
  .auth-title { font-size: clamp(1.375rem, 1.125rem + 0.75vw, 1.75rem); font-weight: 700; color: var(--color-text-bright); letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 0.5rem; }
  .auth-subtitle { font-size: 0.8125rem; color: var(--color-muted); line-height: 1.6; margin-bottom: 2rem; }
  .auth-fields { display: flex; flex-direction: column; gap: 1.125rem; }
  .auth-field { display: flex; flex-direction: column; gap: 0.375rem; }
  .auth-label { font-size: 0.6875rem; font-weight: 500; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .auth-input { width: 100%; border-radius: 10px; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.06); padding: 0.8125rem 1rem; color: var(--color-text-bright); font-size: 0.875rem; font-family: inherit; transition: border-color 0.2s, box-shadow 0.2s; box-sizing: border-box; }
  .auth-input--pw { padding-right: 2.75rem; }
  .auth-input:focus { outline: none; border-color: var(--color-accent); box-shadow: 0 0 0 3px rgba(52,211,153,0.1); }
  .auth-input::placeholder { color: rgba(255,255,255,0.2); }
  .auth-pw-wrap { position: relative; }
  .auth-eye { position: absolute; right: 0.625rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--color-muted); cursor: pointer; padding: 0.25rem; display: flex; align-items: center; justify-content: center; border-radius: 6px; transition: color 0.15s; }
  .auth-eye:hover { color: var(--color-text-bright); }
  .auth-eye .eye-closed { display: none; }
  .auth-eye.is-visible .eye-open { display: none; }
  .auth-eye.is-visible .eye-closed { display: block; }
  .auth-submit { width: 100%; padding: 0.875rem; font-size: 0.875rem; font-weight: 600; color: #050507; background: linear-gradient(135deg, #34d399 0%, #2dd4bf 100%); border: none; border-radius: 10px; cursor: pointer; font-family: inherit; transition: opacity 0.2s, transform 0.1s; margin-top: 0.25rem; }
  .auth-submit:hover { opacity: 0.92; } .auth-submit:active { transform: scale(0.98); } .auth-submit:disabled { opacity: 0.5; cursor: not-allowed; }
  .auth-switch { font-size: 0.8125rem; color: var(--color-muted); text-align: center; margin-top: 1.75rem; }
  .auth-switch-row { display: flex; align-items: center; justify-content: center; gap: 0.5rem; flex-wrap: wrap; font-size: 0.8125rem; color: var(--color-muted); margin-top: 1.75rem; }
  .auth-switch-sep { color: rgba(255,255,255,0.15); }
  .auth-link { background: none; border: none; color: var(--color-accent); cursor: pointer; font-size: inherit; font-family: inherit; font-weight: 500; padding: 0; } .auth-link:hover { text-decoration: underline; }
  .auth-msg { border-radius: 10px; padding: 0.75rem 1rem; font-size: 0.8125rem; margin-bottom: 1.25rem; }
  .auth-msg--error { border: 1px solid rgba(248,113,113,0.2); background: rgba(248,113,113,0.06); color: #fca5a5; }
  .auth-msg--success { border: 1px solid rgba(52,211,153,0.2); background: rgba(52,211,153,0.06); color: #6ee7b7; }
  .hidden { display: none !important; }
</style>

<script type="module">
  const API = 'https://api.leanctx.com';
  const $ = (id) => document.getElementById(id);
  function show(el, txt) { if (!el) return; el.classList.remove('hidden'); el.textContent = txt; }
  function hide(el) { if (!el) return; el.classList.add('hidden'); el.textContent = ''; }

  document.querySelectorAll('[data-toggle-pw]').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = $(btn.dataset.togglePw);
      if (!input) return;
      const visible = input.type === 'text';
      input.type = visible ? 'password' : 'text';
      btn.classList.toggle('is-visible', !visible);
    });
  });

  async function api(path, opts = {}) {
    const headers = { 'Content-Type': 'application/json', ...(opts.headers || {}) };
    const res = await fetch(API + path, { ...opts, headers });
    const text = await res.text();
    const data = text ? (() => { try { return JSON.parse(text); } catch { return text; } })() : null;
    if (!res.ok) { const msg = typeof data === 'string' ? data : (data?.message || data?.error || res.statusText); const err = new Error(msg || `HTTP ${res.status}`); err.status = res.status; throw err; }
    return data;
  }

  const forms = ['formRegister', 'formLogin', 'formForgot', 'formReset'];
  function showForm(name) { hide($('authError')); hide($('authInfo')); forms.forEach(f => $(f)?.classList.add('hidden')); $('form' + name.charAt(0).toUpperCase() + name.slice(1))?.classList.remove('hidden'); }
  document.querySelectorAll('[data-goto]').forEach(btn => btn.addEventListener('click', () => showForm(btn.dataset.goto)));

  $('regSubmitBtn')?.addEventListener('click', async () => {
    hide($('authError')); const email = $('regEmail')?.value?.trim(); const pw = $('regPassword')?.value; const pwc = $('regPasswordConfirm')?.value;
    if (!email) { show($('authError'), 'Please enter your email.'); return; }
    if (!pw || pw.length < 8) { show($('authError'), 'Password must be at least 8 characters.'); return; }
    if (pw !== pwc) { show($('authError'), 'Passwords do not match.'); return; }
    $('regSubmitBtn').disabled = true;
    try {
      const data = await api('/api/auth/register', { method: 'POST', body: JSON.stringify({ email, password: pw }) });
      if (!data?.api_key) throw new Error('Registration failed');
      localStorage.setItem('leanctx_api_key', data.api_key);
      localStorage.setItem('leanctx_new_user', '1');
      localStorage.setItem('leanctx_user_email', email);
      window.location.href = '/dashboard/overview';
    } catch (e) { show($('authError'), e?.message || 'Registration failed'); } finally { $('regSubmitBtn').disabled = false; }
  });

  $('loginSubmitBtn')?.addEventListener('click', async () => {
    hide($('authError')); const email = $('loginEmail')?.value?.trim(); const pw = $('loginPassword')?.value;
    if (!email || !pw) { show($('authError'), 'Please enter email and password.'); return; }
    $('loginSubmitBtn').disabled = true;
    try {
      const data = await api('/api/auth/login', { method: 'POST', body: JSON.stringify({ email, password: pw }) });
      if (!data?.api_key) throw new Error('Login failed');
      localStorage.setItem('leanctx_api_key', data.api_key);
      localStorage.setItem('leanctx_user_email', email);
      window.location.href = '/dashboard/overview';
    } catch (e) {
      if (e?.status === 403) {
        show($('authInfo'), e?.message || 'Please verify your email first.');
      } else {
        show($('authError'), e?.message || 'Invalid email or password');
      }
    } finally { $('loginSubmitBtn').disabled = false; }
  });

  $('forgotSubmitBtn')?.addEventListener('click', async () => {
    hide($('authError')); const email = $('forgotEmail')?.value?.trim();
    if (!email) { show($('authError'), 'Please enter your email.'); return; }
    $('forgotSubmitBtn').disabled = true;
    try { await api('/api/auth/forgot-password', { method: 'POST', body: JSON.stringify({ email }) }); show($('authInfo'), 'If an account exists, a reset email has been sent.'); } catch (e) { show($('authError'), e?.message || 'Failed'); } finally { $('forgotSubmitBtn').disabled = false; }
  });

  let resetToken = null;
  $('resetSubmitBtn')?.addEventListener('click', async () => {
    hide($('authError')); const pw = $('resetPassword')?.value; const pwc = $('resetPasswordConfirm')?.value;
    if (!pw || pw.length < 8) { show($('authError'), 'Password must be at least 8 characters.'); return; }
    if (pw !== pwc) { show($('authError'), 'Passwords do not match.'); return; }
    if (!resetToken) { show($('authError'), 'Invalid reset token.'); return; }
    $('resetSubmitBtn').disabled = true;
    try { await api('/api/auth/reset-password', { method: 'POST', body: JSON.stringify({ token: resetToken, password: pw }) }); show($('authInfo'), 'Password reset! You can now sign in.'); resetToken = null; setTimeout(() => showForm('login'), 2000); } catch (e) { show($('authError'), e?.message || 'Failed'); } finally { $('resetSubmitBtn').disabled = false; }
  });

  (function init() {
    const params = new URLSearchParams(window.location.search);
    if (params.get('verified') === 'true') { show($('authInfo'), 'Email verified! You can now sign in.'); window.history.replaceState({}, '', window.location.pathname); showForm('login'); return; }
    if (params.get('reset_token')) { resetToken = params.get('reset_token'); window.history.replaceState({}, '', window.location.pathname); showForm('reset'); return; }
    if (params.get('mode') === 'login') { showForm('login'); return; }
    if (localStorage.getItem('leanctx_api_key')) { window.location.href = '/dashboard/overview'; return; }
  })();
</script>

</BaseLayout>
