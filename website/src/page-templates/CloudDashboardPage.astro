---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);
---

<BaseLayout
  title={t('cloud.metaTitle')}
  description={t('cloud.metaDesc')}
  breadcrumbs={[{ name: t('cloud.breadcrumb'), url: '/cloud' }]}
>

<!-- ═══════ HERO ═══════ -->
<section class="section-hero">
  <div class="content-grid">
    <div class="animate-entrance">
      <p class="fluid-label text-accent" style="margin-bottom: clamp(1.25rem, 1rem + 1vw, 2.5rem);">
        {t('cloud.heroLabel')}
      </p>
    </div>
    <h1 class="font-display fluid-display font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1.25rem, 1rem + 1vw, 2rem);">
      {t('cloud.heroTitle')}<br/>
      <span class="gradient-text">{t('cloud.heroTitleHighlight')}</span>
    </h1>
    <p class="fluid-body text-muted animate-entrance stagger-2" style="margin-bottom: clamp(2rem, 1.5rem + 1.5vw, 3.5rem); max-width: 48rem;">
      {t('cloud.heroDesc')}
    </p>
    <div class="flex flex-wrap items-center animate-entrance stagger-3" style="gap: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem);">
      <a href={lp('/dashboard')} class="btn-primary inline-flex items-center gap-2 rounded-lg" style="padding: clamp(0.7rem, 0.55rem + 0.3vw, 0.9rem) clamp(1.5rem, 1rem + 0.75vw, 2.25rem); font-size: clamp(0.8125rem, 0.78rem + 0.15vw, 0.9375rem);">
        {t('cloud.heroLoginCta')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
      <a href={lp('/dashboard')} class="btn-outline inline-flex items-center gap-2 rounded-lg" style="padding: clamp(0.7rem, 0.55rem + 0.3vw, 0.9rem) clamp(1.5rem, 1rem + 0.75vw, 2.25rem); font-size: clamp(0.8125rem, 0.78rem + 0.15vw, 0.9375rem);">
        {t('cloud.heroDashboardCta')}
      </a>
      <a href={lp('/docs/cloud')} class="fluid-sm text-muted hover:text-text-bright transition-colors inline-flex items-center gap-1.5 font-medium">
        {t('cloud.heroDocs')}
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════ HOW IT WORKS ═══════ -->
<section class="section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('cloud.howLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('cloud.howTitle')} <span class="gradient-text">{t('cloud.howTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 5rem); max-width: 48rem;">
      {t('cloud.howDesc')}
    </p>

    <div class="cloud-steps animate-entrance stagger-3">
      <div class="cloud-step">
        <div class="cloud-step-num font-display">01</div>
        <div class="cloud-step-content">
          <h3 class="fluid-h3 font-semibold font-display text-text-bright">{t('cloud.step1Title')}</h3>
          <p class="fluid-sm text-muted" style="margin: 0.5rem 0 1rem;">{t('cloud.step1Desc')}</p>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <code class="cloud-code">{t('cloud.step1OptionWeb')}</code>
            <code class="cloud-code">lean-ctx login you@email.com</code>
          </div>
        </div>
      </div>
      <div class="cloud-step-connector"></div>
      <div class="cloud-step">
        <div class="cloud-step-num font-display">02</div>
        <div class="cloud-step-content">
          <h3 class="fluid-h3 font-semibold font-display text-text-bright">{t('cloud.step2Title')}</h3>
          <p class="fluid-sm text-muted" style="margin: 0.5rem 0 1rem;">{t('cloud.step2Desc')}</p>
          <code class="cloud-code">lean-ctx sync</code>
        </div>
      </div>
      <div class="cloud-step-connector"></div>
      <div class="cloud-step">
        <div class="cloud-step-num font-display">03</div>
        <div class="cloud-step-content">
          <h3 class="fluid-h3 font-semibold font-display text-text-bright">{t('cloud.step3Title')}</h3>
          <p class="fluid-sm text-muted" style="margin: 0.5rem 0;">{t('cloud.step3Desc')}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════ FEATURES ═══════ -->
<section class="section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('cloud.featLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('cloud.featTitle')} <span class="gradient-text">{t('cloud.featTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('cloud.featDesc')}
    </p>

    {[
      { icon: 'stats', title: t('cloud.feat1Title'), desc: t('cloud.feat1Desc'), detail: t('cloud.feat1Detail'), color: 'accent' },
      { icon: 'learn', title: t('cloud.feat2Title'), desc: t('cloud.feat2Desc'), detail: t('cloud.feat2Detail'), color: 'blue' },
      { icon: 'spark', title: t('cloud.feat3Title'), desc: t('cloud.feat3Desc'), detail: t('cloud.feat3Detail'), color: 'purple' },
      { icon: 'bulb', title: t('cloud.feat4Title'), desc: t('cloud.feat4Desc'), detail: t('cloud.feat4Detail'), color: 'accent' },
      { icon: 'people', title: t('cloud.feat5Title'), desc: t('cloud.feat5Desc'), detail: t('cloud.feat5Detail'), color: 'blue' },
      { icon: 'trophy', title: t('cloud.feat6Title'), desc: t('cloud.feat6Desc'), detail: t('cloud.feat6Detail'), color: 'purple' },
    ].map((f, i) => (
      <div class={`cloud-feature animate-entrance stagger-${3 + i}`}>
        <div class={`cloud-feature-icon ${f.color === 'blue' ? 'cloud-feature-icon--blue' : f.color === 'purple' ? 'cloud-feature-icon--purple' : ''}`}>
          {f.icon === 'stats' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>}
          {f.icon === 'learn' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>}
          {f.icon === 'spark' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>}
          {f.icon === 'bulb' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>}
          {f.icon === 'people' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>}
          {f.icon === 'trophy' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-4.5A3.375 3.375 0 0012.75 10.5h-.75V6.75A2.25 2.25 0 009.75 4.5h-.75a2.25 2.25 0 00-2.25 2.25v3.75h-.75A3.375 3.375 0 002.625 14.25v4.5m13.875 0h1.5m-1.5 0h-9m0 0h-1.5"/></svg>}
        </div>
        <div class="cloud-feature-body">
          <h3 class="font-display fluid-h3 font-semibold text-text-bright">{f.title}</h3>
          <p class="fluid-sm text-muted" style="margin: 0.75rem 0;">{f.desc}</p>
          <p class="fluid-sm text-muted">{f.detail}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════ PRIVACY ═══════ -->
<section class="section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('cloud.privacyLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('cloud.privacyTitle')} <span class="gradient-text">{t('cloud.privacyTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 5rem); max-width: 48rem;">
      {t('cloud.privacyDesc')}
    </p>

    <div class="grid md:grid-cols-2 animate-entrance stagger-3" style="gap: clamp(1px, 0.1vw, 1px);">
      <div class="compare-card">
        <div class="compare-header compare-header--good">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {t('cloud.weCollect')}
        </div>
        <div class="compare-body font-mono" style="font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.8125rem);">
          <div class="compare-line"><span class="text-accent">{t('cloud.collect1')}</span></div>
          <div class="compare-line"><span class="text-accent">{t('cloud.collect2')}</span></div>
          <div class="compare-line"><span class="text-accent">{t('cloud.collect3')}</span></div>
          <div class="compare-line"><span class="text-accent">{t('cloud.collect4')}</span></div>
        </div>
      </div>
      <div class="compare-card">
        <div class="compare-header compare-header--bad">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
          {t('cloud.weNeverCollect')}
        </div>
        <div class="compare-body font-mono" style="font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.8125rem);">
          <div class="compare-line"><span class="text-danger">{t('cloud.never1')}</span></div>
          <div class="compare-line"><span class="text-danger">{t('cloud.never2')}</span></div>
          <div class="compare-line"><span class="text-danger">{t('cloud.never3')}</span></div>
          <div class="compare-line"><span class="text-danger">{t('cloud.never4')}</span></div>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap items-center animate-entrance stagger-4" style="gap: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem); margin-top: clamp(2rem, 1.5rem + 1vw, 3rem);">
      <a href={lp('/dashboard')} class="btn-primary inline-flex items-center gap-2 rounded-lg" style="padding: clamp(0.7rem, 0.55rem + 0.3vw, 0.9rem) clamp(1.5rem, 1rem + 0.75vw, 2.25rem); font-size: clamp(0.8125rem, 0.78rem + 0.15vw, 0.9375rem);">
        {t('cloud.heroLoginCta')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .cloud-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 40rem;
  }
  .cloud-step {
    display: flex;
    gap: clamp(1.25rem, 1rem + 0.75vw, 2rem);
    align-items: flex-start;
  }
  .cloud-step-num {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(52, 211, 153, 0.08);
    border: 1px solid rgba(52, 211, 153, 0.2);
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.875rem;
  }
  .cloud-step-content { padding-bottom: 0.5rem; }
  .cloud-step-connector {
    width: 1px;
    height: 2rem;
    background: var(--color-border);
    margin-left: 1.5rem;
  }
  .cloud-code {
    display: block;
    font-family: var(--font-mono, monospace);
    font-size: clamp(0.75rem, 0.7rem + 0.12vw, 0.8125rem);
    color: var(--color-accent);
    background: rgba(52, 211, 153, 0.06);
    border: 1px solid rgba(52, 211, 153, 0.14);
    border-radius: 8px;
    padding: 0.625rem 1rem;
  }
  .cloud-feature {
    display: flex;
    gap: clamp(1.25rem, 1rem + 0.75vw, 2rem);
    align-items: flex-start;
    padding: clamp(1.5rem, 1.25rem + 0.75vw, 2.25rem) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .cloud-feature:last-child { border-bottom: none; }
  .cloud-feature-icon {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(52, 211, 153, 0.08);
    color: var(--color-accent);
  }
  .cloud-feature-icon--blue { background: rgba(96, 165, 250, 0.08); color: #60a5fa; }
  .cloud-feature-icon--purple { background: rgba(168, 85, 247, 0.08); color: #a855f7; }
  .cloud-feature-body { flex: 1; min-width: 0; }
  .compare-card { border: 1px solid var(--color-border); border-radius: clamp(10px, 0.8vw, 14px); overflow: hidden; }
  .compare-header { display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.8125rem); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 1px solid var(--color-border); }
  .compare-header--good { background: rgba(52, 211, 153, 0.04); color: var(--color-accent); }
  .compare-header--bad { background: rgba(248, 113, 113, 0.04); color: var(--color-danger); }
  .compare-body { padding: 1.25rem; background: var(--color-surface); }
  .compare-line { padding: 0.3rem 0; }
</style>

</BaseLayout>
