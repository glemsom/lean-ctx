---
import DocsLayout from '../layouts/DocsLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const sidebar = [
  {
    title: t('docs.gettingStarted.sidebarInstallation'),
    items: [
      { label: t('docs.gettingStarted.sidebarOverview'), href: lp('/docs/getting-started') },
      { label: t('docs.gettingStarted.sidebarInstallBinary'), href: lp('/docs/getting-started#install') },
      { label: t('docs.gettingStarted.sidebarSetup'), href: lp('/docs/getting-started#shell-hook') },
      { label: t('docs.gettingStarted.sidebarVerify'), href: lp('/docs/getting-started#editor-setup') },
    ],
  },
  {
    title: t('docs.gettingStarted.sidebarAdvanced'),
    items: [
      { label: t('docs.gettingStarted.sidebarMonitor'), href: lp('/docs/getting-started#monitor') },
      { label: t('docs.gettingStarted.sidebarMultiAgent'), href: lp('/docs/getting-started#lctx') },
      { label: t('docs.gettingStarted.sidebarUpdating'), href: lp('/docs/getting-started#update') },
      { label: t('docs.gettingStarted.sidebarUninstalling'), href: lp('/docs/getting-started#uninstall') },
      { label: t('docs.gettingStarted.sidebarAgentRules'), href: lp('/docs/getting-started#agent-rules') },
      { label: t('docs.gettingStarted.sidebarTroubleshooting'), href: lp('/docs/getting-started#troubleshooting') },
    ],
  },
  {
    title: t('docs.common.related'),
    items: [
      { label: t('nav.docs.analytics'), href: lp('/docs/analytics') },
      { label: t('nav.docs.cliComplete'), href: lp('/docs/cli-reference') },
      { label: t('nav.docs.configuration'), href: lp('/docs/configuration') },
      { label: t('nav.docs.quickReference'), href: lp('/docs/quick-reference') },
      { label: t('docs.tools.title'), href: lp('/docs/tools') },
    ],
  },
];
---

<DocsLayout title={t('docs.gettingStarted.title')} description={t('docs.gettingStarted.description')} sidebar={sidebar}>
  <p set:html={t('docs.gettingStarted.intro')} />

  <h3 id="prompt-generator">{t('docs.gettingStarted.promptGenTitle')}</h3>
  <p>{t('docs.gettingStarted.promptGenDesc')}</p>

  <div class="not-prose mb-8">
    <div class="flex flex-wrap items-end gap-4 mb-4">
      <div>
        <label class="block text-[10px] font-semibold uppercase tracking-wider text-muted mb-1.5">{t('docs.gettingStarted.labelPlatform')}</label>
        <div class="flex gap-1" id="pg-os">
          <button data-v="macos" class="pg-btn active">macOS</button>
          <button data-v="linux" class="pg-btn">Linux</button>
          <button data-v="windows" class="pg-btn">Windows</button>
        </div>
      </div>
      <div>
        <label class="block text-[10px] font-semibold uppercase tracking-wider text-muted mb-1.5">{t('docs.gettingStarted.labelAiTool')}</label>
        <div class="flex flex-wrap gap-1" id="pg-ed">
          <button data-v="cursor" class="pg-btn active">Cursor</button>
          <button data-v="claude" class="pg-btn">Claude</button>
          <button data-v="copilot" class="pg-btn">Copilot</button>
          <button data-v="windsurf" class="pg-btn">Windsurf</button>
          <button data-v="codex" class="pg-btn">Codex</button>
          <button data-v="crush" class="pg-btn">Crush</button>
          <button data-v="gemini" class="pg-btn">Gemini</button>
          <button data-v="antigravity" class="pg-btn">Antigravity</button>
          <button data-v="zed" class="pg-btn">Zed</button>
          <button data-v="qwen" class="pg-btn">Qwen</button>
          <button data-v="trae" class="pg-btn">Trae</button>
          <button data-v="amazonq" class="pg-btn">Amazon Q</button>
          <button data-v="jetbrains" class="pg-btn">JetBrains</button>
          <button data-v="kiro" class="pg-btn">Kiro</button>
          <button data-v="verdent" class="pg-btn">Verdent</button>
        </div>
      </div>
    </div>

    <div class="terminal-chrome">
      <div class="terminal-header flex items-center gap-1.5 px-4 py-2.5">
        <div class="terminal-dot" style="background:#ef4444;width:7px;height:7px"></div>
        <div class="terminal-dot" style="background:#eab308;width:7px;height:7px"></div>
        <div class="terminal-dot" style="background:#34d399;width:7px;height:7px"></div>
        <span class="text-muted text-[11px] ml-2">{t('docs.gettingStarted.labelGeneratedPrompt')}</span>
        <button id="pg-copy" class="ml-auto px-3 py-1 text-[11px] font-medium rounded-md bg-accent/10 text-accent hover:bg-accent/20 transition-colors cursor-pointer border border-accent/20">{t('docs.gettingStarted.btnCopy')}</button>
      </div>
      <div class="terminal-body px-4 py-3">
        <pre id="pg-out" class="text-[12px] sm:text-[13px] font-mono text-text leading-relaxed whitespace-pre-wrap"></pre>
      </div>
    </div>
  </div>

  <style is:inline>
    .pg-btn {
      padding: 5px 12px;
      font-size: 12px;
      font-weight: 500;
      border-radius: 8px;
      cursor: pointer;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      color: var(--color-muted);
      transition: all 0.15s ease;
    }
    .pg-btn:hover { border-color: rgba(52,211,153,0.3); color: var(--color-text); }
    .pg-btn.active { background: rgba(52,211,153,0.1); border-color: rgba(52,211,153,0.3); color: var(--color-accent); }
  </style>

  <script is:inline>
  (function() {
    var os = 'macos', ed = 'cursor';

    var installs = {
      macos: 'brew tap yvgude/lean-ctx && brew install lean-ctx',
      linux: 'curl -fsSL https://leanctx.com/install.sh | sh',
      windows: 'cargo install lean-ctx'
    };

    var shells = {
      macos: ['lean-ctx setup', 'source ~/.zshrc'],
      linux: ['lean-ctx setup', 'source ~/.bashrc'],
      windows: ['lean-ctx setup', '# Restart PowerShell after this']
    };

    var editors = {
      cursor: {
        name: 'Cursor',
        note: 'lean-ctx setup auto-detects Cursor and creates ~/.cursor/mcp.json for you.',
        manual: [
          'If auto-setup fails, create ~/.cursor/mcp.json manually:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}'
        ],
        agent: 'lean-ctx init --agent cursor',
        restart: 'Restart Cursor completely (Cmd+Q / Ctrl+Q, then reopen).'
      },
      claude: {
        name: 'Claude Code',
        note: 'lean-ctx setup auto-detects Claude Code and configures it.',
        manual: ['Or manually: claude mcp add lean-ctx lean-ctx'],
        agent: 'lean-ctx init --agent claude',
        restart: 'Restart Claude Code.'
      },
      copilot: {
        name: 'GitHub Copilot',
        note: 'Copilot: create .github/copilot/mcp.json per project (below). lean-ctx init --agent copilot also creates .vscode/mcp.json for VS Code native MCP support.',
        manual: [
          'Create .github/copilot/mcp.json in your project:',
          '{',
          '  "servers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}'
        ],
        agent: 'lean-ctx init --agent copilot',
        restart: 'Restart VS Code.'
      },
      windsurf: {
        name: 'Windsurf',
        note: 'lean-ctx setup auto-detects Windsurf. Important: use the FULL binary path.',
        manual: [
          'If auto-setup fails, create ~/.codeium/windsurf/mcp_config.json:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "/FULL/PATH/TO/lean-ctx" }',
          '  }',
          '}',
          '(Get path from: which lean-ctx)'
        ],
        agent: '',
        restart: 'Restart Windsurf completely.'
      },
      codex: {
        name: 'OpenAI Codex',
        note: 'lean-ctx setup auto-detects Codex CLI.',
        manual: ['Or manually: codex mcp add lean-ctx'],
        agent: 'lean-ctx init --agent codex',
        restart: 'Restart Codex CLI.'
      },
      crush: {
        name: 'Crush',
        note: 'Configure via lean-ctx init --agent crush. Crush by Charmbracelet uses ~/.config/crush/crush.json with a "mcp" key.',
        manual: [
          'If auto-setup fails, create ~/.config/crush/crush.json:',
          '{',
          '  "mcp": {',
          '    "lean-ctx": {',
          '      "type": "stdio",',
          '      "command": "lean-ctx"',
          '    }',
          '  }',
          '}'
        ],
        agent: 'lean-ctx init --agent crush',
        restart: 'Restart Crush.'
      },
      gemini: {
        name: 'Gemini CLI',
        note: 'lean-ctx setup auto-detects Gemini CLI.',
        manual: [
          'If auto-setup fails, create ~/.gemini/settings/mcp.json:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}'
        ],
        agent: '',
        restart: 'Restart Gemini CLI.'
      },
      antigravity: {
        name: 'Antigravity',
        note: 'lean-ctx setup auto-detects Antigravity IDE.',
        manual: [
          'If auto-setup fails, create ~/.gemini/antigravity/mcp_config.json:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}',
          '(Get path from: which lean-ctx)'
        ],
        agent: '',
        restart: 'Restart Antigravity IDE.'
      },
      zed: {
        name: 'Zed',
        note: 'lean-ctx setup auto-detects Zed.',
        manual: [
          'If auto-setup fails, add to ~/.config/zed/settings.json:',
          '"context_servers": {',
          '  "lean-ctx": {',
          '    "source": "custom",',
          '    "command": "lean-ctx",',
          '    "args": [], "env": {}',
          '  }',
          '}'
        ],
        agent: '',
        restart: 'Zed auto-restarts MCP servers after saving.'
      },
      qwen: {
        name: 'Qwen Code',
        note: 'Configure via lean-ctx init --agent qwen.',
        manual: [
          'If auto-setup fails, create ~/.qwen/mcp.json:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}',
          '(Get path from: which lean-ctx)'
        ],
        agent: 'qwen',
        restart: 'Restart Qwen Code.'
      },
      trae: {
        name: 'Trae',
        note: 'Configure via lean-ctx init --agent trae.',
        manual: [
          'If auto-setup fails, create ~/.trae/mcp.json:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}',
          '(Get path from: which lean-ctx)'
        ],
        agent: 'trae',
        restart: 'Restart Trae.'
      },
      amazonq: {
        name: 'Amazon Q Developer',
        note: 'Configure via lean-ctx init --agent amazonq.',
        manual: [
          'If auto-setup fails, create ~/.aws/amazonq/mcp.json:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}',
          '(Get path from: which lean-ctx)'
        ],
        agent: 'amazonq',
        restart: 'Restart Amazon Q Developer.'
      },
      jetbrains: {
        name: 'JetBrains IDEs',
        note: 'Configure via lean-ctx init --agent jetbrains. Works with IntelliJ, WebStorm, PyCharm, and other JetBrains IDEs.',
        manual: [
          'If auto-setup fails, create ~/.jb-mcp.json:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}',
          '(Get path from: which lean-ctx)'
        ],
        agent: 'jetbrains',
        restart: 'Restart your JetBrains IDE.'
      },
      kiro: {
        name: 'AWS Kiro',
        note: 'Configure via lean-ctx init --agent kiro. This creates both ~/.kiro/settings/mcp.json (MCP connection) AND .kiro/steering/lean-ctx.md (steering file that makes Kiro prefer lean-ctx tools over native readFile/executeBash).',
        manual: [
          'If auto-setup fails, create ~/.kiro/settings/mcp.json:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}',
          'Then create .kiro/steering/lean-ctx.md with the steering template from:',
          'https://github.com/yvgude/lean-ctx (see KIRO_STEERING_TEMPLATE in hooks.rs)',
          '(The steering file is REQUIRED for Kiro to use lean-ctx tools)'
        ],
        agent: 'kiro',
        restart: 'Restart Kiro.'
      },
      verdent: {
        name: 'Verdent',
        note: 'Configure via lean-ctx init --agent verdent. Verdent uses ~/.verdent/mcp.json for MCP server configuration.',
        manual: [
          'If auto-setup fails, create ~/.verdent/mcp.json:',
          '{',
          '  "mcpServers": {',
          '    "lean-ctx": { "command": "lean-ctx" }',
          '  }',
          '}',
          '(Get path from: which lean-ctx)'
        ],
        agent: 'verdent',
        restart: 'Restart Verdent.'
      }
    };

    function gen() {
      var e = editors[ed], s = shells[os], step = 1;
      var lines = [
        'Install and configure lean-ctx on my machine. Follow these exact steps:',
        '',
        step + '. INSTALL THE BINARY:',
        '   ' + installs[os],
        ''
      ];
      step++;
      lines.push(step + '. VERIFY:');
      lines.push('   lean-ctx --version');
      lines.push('   (Expected: lean-ctx 2.14.3 or newer)');
      lines.push('');
      step++;
      lines.push(step + '. ONE-COMMAND SETUP (shell hooks + editor config):');
      for (var i = 0; i < s.length; i++) lines.push('   ' + s[i]);
      lines.push('');
      lines.push('   ' + e.note);
      lines.push('');
      step++;
      lines.push(step + '. MANUAL FALLBACK (only if step 3 did not configure ' + e.name + '):');
      for (var j = 0; j < e.manual.length; j++) lines.push('   ' + e.manual[j]);
      lines.push('');
      if (e.agent) {
        step++;
        lines.push(step + '. INSTALL AGENT INSTRUCTIONS:');
        lines.push('   ' + e.agent);
        lines.push('');
      }
      step++;
      lines.push(step + '. RESTART:');
      lines.push('   ' + e.restart);
      lines.push('');
      step++;
      lines.push(step + '. VERIFY EVERYTHING:');
      lines.push('   lean-ctx doctor');
      lines.push('   All checks should show green.');

      var el = document.getElementById('pg-out');
      if (el) el.textContent = lines.join('\n');
    }

    function bind(containerId, key) {
      var btns = document.querySelectorAll('#' + containerId + ' .pg-btn');
      for (var i = 0; i < btns.length; i++) {
        (function(btn) {
          btn.addEventListener('click', function() {
            for (var j = 0; j < btns.length; j++) btns[j].classList.remove('active');
            btn.classList.add('active');
            if (key === 'os') os = btn.getAttribute('data-v');
            else ed = btn.getAttribute('data-v');
            gen();
          });
        })(btns[i]);
      }
    }

    bind('pg-os', 'os');
    bind('pg-ed', 'ed');

    var copyBtn = document.getElementById('pg-copy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        var el = document.getElementById('pg-out');
        if (el && navigator.clipboard) {
          navigator.clipboard.writeText(el.textContent || '').then(function() {
            copyBtn.textContent = 'Copied!';
            setTimeout(function() { copyBtn.textContent = 'Copy'; }, 2000);
          });
        }
      });
    }

    gen();
  })();
  </script>

  <h2 id="three-steps">{t('docs.gettingStarted.threeStepsTitle')}</h2>

  <div class="not-prose terminal-chrome mb-8">
    <div class="terminal-header flex items-center gap-1.5 px-4 py-2.5">
      <div class="terminal-dot" style="background:#ef4444;width:7px;height:7px"></div>
      <div class="terminal-dot" style="background:#eab308;width:7px;height:7px"></div>
      <div class="terminal-dot" style="background:#34d399;width:7px;height:7px"></div>
      <span class="text-muted text-[11px] ml-2">{t('docs.gettingStarted.threeStepsTermLabel')}</span>
    </div>
    <div class="terminal-body px-4 py-3 font-mono text-[13px]">
      <pre class="text-text whitespace-pre-wrap"><span class="text-muted"># 1. Install (pick one)</span>
curl -fsSL https://leanctx.com/install.sh | sh          <span class="text-muted"># universal</span>
brew tap yvgude/lean-ctx && brew install lean-ctx        <span class="text-muted"># macOS / Linux</span>
npm install -g lean-ctx-bin                              <span class="text-muted"># Node.js</span>
cargo install lean-ctx                                   <span class="text-muted"># Rust</span>

<span class="text-muted"># 2. Setup (auto-configures shell + ALL detected editors)</span>
lean-ctx setup

<span class="text-muted"># 3. Restart your shell</span>
source ~/.zshrc  <span class="text-muted"># or ~/.bashrc</span></pre>
    </div>
  </div>

  <p set:html={t('docs.gettingStarted.setupAutoDetects')} />

  <details class="mb-8">
    <summary class="cursor-pointer font-semibold text-accent hover:text-accent/80 transition-colors py-2">
      {t('docs.gettingStarted.detailedInstructions')}
    </summary>

  <h2 id="install">{t('docs.gettingStarted.step1Title')}</h2>

  <h3 id="universal">{t('docs.gettingStarted.universalTitle')}</h3>
  <p>{t('docs.gettingStarted.universalDesc')}</p>
  <pre><code>curl -fsSL https://leanctx.com/install.sh | sh</code></pre>
  <p set:html={t('docs.gettingStarted.universalDetails')} />
  <p>{t('docs.gettingStarted.universalManual')}</p>
  <pre><code>curl -fsSL https://leanctx.com/install.sh -o install.sh
chmod +x install.sh
./install.sh --download    # pre-built binary (no Rust)
./install.sh               # build from source (requires Rust)</code></pre>

  <h3 id="npm">{t('docs.gettingStarted.npmTitle')}</h3>
  <p>{t('docs.gettingStarted.npmDesc')}</p>
  <pre><code>npm install -g lean-ctx-bin</code></pre>
  <p set:html={t('docs.gettingStarted.npmDetails')} />

  <h3 id="macos">{t('docs.gettingStarted.macosTitle')}</h3>
  <p set:html={t('docs.gettingStarted.macosOptionA')} />
  <pre><code>brew tap yvgude/lean-ctx
brew install lean-ctx</code></pre>
  <p set:html={t('docs.gettingStarted.macosOptionADesc')} />

  <p set:html={t('docs.gettingStarted.macosOptionB')} />
  <pre><code>cargo install lean-ctx</code></pre>
  <p set:html={t('docs.gettingStarted.macosOptionBDesc')} />
  <pre><code>echo 'export PATH="$HOME/.cargo/bin:$PATH"' >> ~/.zshrc
source ~/.zshrc</code></pre>

  <p set:html={t('docs.gettingStarted.macosOptionC')} />
  <ol>
    <li><span set:html={t('docs.gettingStarted.macosDownload')} />
      <ul>
        <li set:html={t('docs.gettingStarted.macosAppleSilicon')} />
        <li set:html={t('docs.gettingStarted.macosIntel')} />
      </ul>
    </li>
    <li>{t('docs.gettingStarted.macosExtract')}
      <pre><code>tar xzf lean-ctx-aarch64-apple-darwin.tar.gz
chmod +x lean-ctx
sudo mv lean-ctx /usr/local/bin/</code></pre>
    </li>
  </ol>
  <p set:html={t('docs.gettingStarted.macosGatekeeper')} />
  <pre><code>xattr -d com.apple.quarantine /usr/local/bin/lean-ctx</code></pre>

  <h3 id="linux">{t('docs.gettingStarted.linuxTitle')}</h3>
  <p set:html={t('docs.gettingStarted.linuxOptionA')} />
  <pre><code>brew tap yvgude/lean-ctx && brew install lean-ctx</code></pre>

  <p set:html={t('docs.gettingStarted.linuxOptionB')} />
  <pre><code># Source build from crates.io
yay -S lean-ctx

# Or pre-built binary from GitHub
yay -S lean-ctx-bin</code></pre>
  <p set:html={t('docs.gettingStarted.linuxAurHelpers')} />

  <p set:html={t('docs.gettingStarted.linuxOptionC')} />
  <pre><code>cargo install lean-ctx</code></pre>
  <p set:html={t('docs.gettingStarted.linuxCargoReq')} />

  <p set:html={t('docs.gettingStarted.linuxOptionD')} />
  <ol>
    <li set:html={t('docs.gettingStarted.linuxDownload')} />
    <li>{t('docs.gettingStarted.linuxExtract')}
      <pre><code>tar xzf lean-ctx-x86_64-unknown-linux-gnu.tar.gz
chmod +x lean-ctx
sudo mv lean-ctx /usr/local/bin/</code></pre>
    </li>
  </ol>

  <h3 id="windows">{t('docs.gettingStarted.windowsTitle')}</h3>

  <p set:html={t('docs.gettingStarted.windowsOptionA')} />
  <ol>
    <li set:html={t('docs.gettingStarted.windowsStep1')} />
    <li set:html={t('docs.gettingStarted.windowsStep2')} />
    <li set:html={t('docs.gettingStarted.windowsStep3')} />
    <li><span set:html={t('docs.gettingStarted.windowsStep4')} />
      <pre><code>mkdir %USERPROFILE%\bin
move lean-ctx.exe %USERPROFILE%\bin\</code></pre>
    </li>
    <li>{t('docs.gettingStarted.windowsStep5')}
      <ul>
        <li set:html={t('docs.gettingStarted.windowsStep5a')} />
        <li set:html={t('docs.gettingStarted.windowsStep5b')} />
        <li set:html={t('docs.gettingStarted.windowsStep5c')} />
        <li>{t('docs.gettingStarted.windowsStep5d')}</li>
      </ul>
    </li>
    <li><span set:html={t('docs.gettingStarted.windowsStep6')} />
      <pre><code>lean-ctx --version</code></pre>
    </li>
  </ol>

  <p set:html={t('docs.gettingStarted.windowsOptionB')} />
  <ol>
    <li set:html={t('docs.gettingStarted.windowsCargoStep1')} />
    <li>{t('docs.gettingStarted.windowsCargoStep2')}
      <pre><code>cargo install lean-ctx</code></pre>
    </li>
    <li set:html={t('docs.gettingStarted.windowsCargoStep3')} />
  </ol>

  <p set:html={t('docs.gettingStarted.windowsOptionC')} />
  <pre><code>git clone https://github.com/yvgude/lean-ctx.git
cd lean-ctx\rust
cargo build --release
copy target\release\lean-ctx.exe %USERPROFILE%\bin\</code></pre>

  <p set:html={t('docs.gettingStarted.windowsWsl')} />

  <h3 id="build-source">{t('docs.gettingStarted.buildSourceTitle')}</h3>
  <pre><code>git clone https://github.com/yvgude/lean-ctx.git
cd lean-ctx/rust
cargo build --release</code></pre>
  <p set:html={t('docs.gettingStarted.buildSourceDesc')} />

  </details>

  <h2 id="shell-hook">{t('docs.gettingStarted.step2Title')}</h2>
  <p set:html={t('docs.gettingStarted.step2Desc')} />
  <pre><code>lean-ctx setup</code></pre>
