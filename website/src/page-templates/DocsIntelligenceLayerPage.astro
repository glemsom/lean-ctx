---
import DocsLayout from '../layouts/DocsLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const sidebar = [
  {
    title: t('docs.intelligenceLayer.sidebarTitle'),
    items: [
      { label: t('docs.common.overview'), href: lp('/docs/intelligence-layer') },
      { label: t('docs.intelligenceLayer.sidebarSurprise'), href: lp('/docs/intelligence-layer') + '#surprise' },
      { label: t('docs.intelligenceLayer.sidebarSpectral'), href: lp('/docs/intelligence-layer') + '#spectral' },
      { label: t('docs.intelligenceLayer.sidebarBoltzmann'), href: lp('/docs/intelligence-layer') + '#boltzmann' },
      { label: t('docs.intelligenceLayer.sidebarChunking'), href: lp('/docs/intelligence-layer') + '#chunking' },
      { label: t('docs.intelligenceLayer.sidebarMmr'), href: lp('/docs/intelligence-layer') + '#mmr' },
      { label: t('docs.intelligenceLayer.sidebarBpe'), href: lp('/docs/intelligence-layer') + '#bpe' },
    ],
  },
  {
    title: t('docs.common.related'),
    items: [
      { label: t('docs.intelligenceLayer.sidebarAutonomousTools'), href: lp('/docs/tools/intelligence') },
      { label: t('nav.docs.treeSitter'), href: lp('/docs/tree-sitter') },
      { label: t('nav.docs.configuration'), href: lp('/docs/configuration') },
      { label: t('nav.product.benchmark'), href: lp('/benchmark') },
    ],
  },
];
---

<DocsLayout title={t('docs.intelligenceLayer.title')} description={t('docs.intelligenceLayer.description')} sidebar={sidebar}>

  <p set:html={t('docs.intelligenceLayer.intro1')} />
  <p set:html={t('docs.intelligenceLayer.intro2')} />

  <h2>{t('docs.intelligenceLayer.howLayersInteract')}</h2>
  <table>
    <thead>
      <tr><th>{t('docs.intelligenceLayer.thAlgorithm')}</th><th>{t('docs.intelligenceLayer.thDecides')}</th><th>{t('docs.intelligenceLayer.thBasedOn')}</th></tr>
    </thead>
    <tbody>
      <tr><td><a href="#spectral">Spectral Relevance</a></td><td>{t('docs.intelligenceLayer.rowSpectralDecides')}</td><td>{t('docs.intelligenceLayer.rowSpectralBasis')}</td></tr>
      <tr><td><a href="#boltzmann">Boltzmann Allocation</a></td><td>{t('docs.intelligenceLayer.rowBoltzmannDecides')}</td><td>{t('docs.intelligenceLayer.rowBoltzmannBasis')}</td></tr>
      <tr><td><a href="#surprise">Predictive Surprise</a></td><td>{t('docs.intelligenceLayer.rowSurpriseDecides')}</td><td>{t('docs.intelligenceLayer.rowSurpriseBasis')}</td></tr>
      <tr><td><a href="#mmr">MMR Deduplication</a></td><td>{t('docs.intelligenceLayer.rowMmrDecides')}</td><td>{t('docs.intelligenceLayer.rowMmrBasis')}</td></tr>
      <tr><td><a href="#chunking">Semantic Chunking</a></td><td>{t('docs.intelligenceLayer.rowChunkingDecides')}</td><td>{t('docs.intelligenceLayer.rowChunkingBasis')}</td></tr>
      <tr><td><a href="#bpe">BPE Optimization</a></td><td>{t('docs.intelligenceLayer.rowBpeDecides')}</td><td>{t('docs.intelligenceLayer.rowBpeBasis')}</td></tr>
    </tbody>
  </table>

  <hr />

  <h2 id="surprise">{t('docs.intelligenceLayer.surpriseTitle')}</h2>
  <p set:html={t('docs.intelligenceLayer.surpriseIntro')} />

  <h3>{t('docs.common.howItWorks')}</h3>
  <ol>
    <li set:html={t('docs.intelligenceLayer.surpriseStep1')} />
    <li set:html={t('docs.intelligenceLayer.surpriseStep2')} />
    <li set:html={t('docs.intelligenceLayer.surpriseStep3')} />
    <li set:html={t('docs.intelligenceLayer.surpriseStep4')} />
  </ol>

  <h3>{t('docs.common.example')}</h3>
  <pre><code>{`// Low surprise (boilerplate) — candidate for removal:
return Ok(());                    // surprise: 0.12
use std::collections::HashMap;   // surprise: 0.18

// High surprise (unique logic) — always preserved:
let decay = (-alpha * dist as f64).exp();   // surprise: 0.89
scores[j] += heat[i] * decay / degree;      // surprise: 0.94`}</code></pre>

  <h3>{t('docs.intelligenceLayer.whyItMatters')}</h3>
  <p>{t('docs.intelligenceLayer.surpriseImpact')}</p>

  <hr />

  <h2 id="spectral">{t('docs.intelligenceLayer.spectralTitle')}</h2>
  <p set:html={t('docs.intelligenceLayer.spectralIntro')} />

  <h3>{t('docs.common.howItWorks')}</h3>
  <p>{t('docs.intelligenceLayer.spectralGraphIntro')}</p>

  <ol>
    <li>
      <strong>{t('docs.intelligenceLayer.heatDiffusion')}</strong> — <span set:html={t('docs.intelligenceLayer.spectralHeatDesc')} />
    </li>
    <li>
      <strong>{t('docs.intelligenceLayer.pageRankCentrality')}</strong> — <span set:html={t('docs.intelligenceLayer.spectralPageRankDesc')} />
    </li>
  </ol>
  <p set:html={t('docs.intelligenceLayer.spectralFormula')} />

  <h3>{t('docs.common.example')}</h3>
  <pre><code>{`Task: "fix authentication bug"

Direct matches:       auth.ts, login.ts
Heat diffusion adds:  middleware.ts (imports auth.ts)
                      session.ts (imported by auth.ts)
PageRank promotes:    db.ts (imported by 18 files — structural hub)

Result: 5 files preloaded instead of 2, covering the full blast radius.`}</code></pre>

  <h3>{t('docs.intelligenceLayer.zeroConfig')}</h3>
  <p set:html={t('docs.intelligenceLayer.spectralZeroConfig')} />

  <hr />

  <h2 id="boltzmann">{t('docs.intelligenceLayer.boltzmannTitle')}</h2>
  <p set:html={t('docs.intelligenceLayer.boltzmannIntro')} />

  <h3>{t('docs.common.howItWorks')}</h3>
  <ol>
    <li set:html={t('docs.intelligenceLayer.boltzmannStep1')} />
    <li set:html={t('docs.intelligenceLayer.boltzmannStep2')} />
    <li>
      <span set:html={t('docs.intelligenceLayer.boltzmannStep3')} />
      <code>budget<sub>i</sub> = total &times; (e<sup>&beta;&middot;E<sub>i</sub></sup> / &Sigma; e<sup>&beta;&middot;E<sub>j</sub></sup>)</code>
    </li>
    <li set:html={t('docs.intelligenceLayer.boltzmannStep4')} />
  </ol>

  <h3>{t('docs.common.example')}</h3>
  <pre><code>{`Task: "fix the JWT validation in auth middleware"
Task specificity: 0.85 (specific) → β = 4.2

File            | Relevance | Budget | Mode
auth.ts         |      0.92 |  3,200 | full
middleware.ts   |      0.78 |  1,800 | full
session.ts      |      0.45 |    420 | map
db.ts           |      0.31 |    180 | signatures
routes.ts       |      0.22 |    128 | signatures
                                ─────
Total:                         5,728 tokens (within 8,000 budget)`}</code></pre>

  <hr />

  <h2 id="chunking">{t('docs.intelligenceLayer.chunkingTitle')}</h2>
  <p set:html={t('docs.intelligenceLayer.chunkingIntro')} />

  <h3>{t('docs.common.howItWorks')}</h3>
  <ol>
    <li>
      <strong>{t('docs.intelligenceLayer.chunkDetection')}</strong> — <span set:html={t('docs.intelligenceLayer.chunkingStep1')} />
    </li>
    <li>
      <strong>{t('docs.intelligenceLayer.relevanceOrdering')}</strong> — <span set:html={t('docs.intelligenceLayer.chunkingStep2')} />
    </li>
    <li>
      <strong>{t('docs.intelligenceLayer.attentionBridges')}</strong> — <span set:html={t('docs.intelligenceLayer.chunkingStep3')} />
    </li>
    <li>
      <strong>{t('docs.intelligenceLayer.tailAnchors')}</strong> — <span set:html={t('docs.intelligenceLayer.chunkingStep4')} />
    </li>
  </ol>

  <h3>{t('docs.common.example')}</h3>
  <pre><code>{`// Without chunking (flat output):
import { db } from '../pages/docs/db';
import { hash } from '../pages/docs/crypto';
const MAX_RETRIES = 3;
export function createUser(...) { ... }
export function validateToken(...) { ... }    ← lost in the middle
export function deleteUser(...) { ... }

// With semantic chunking (task: "fix token validation"):
export function validateToken(...) { ... }    ← promoted to top
---
export function createUser(...) { ... }
export function deleteUser(...) { ... }
---
import { db } from '../pages/docs/db';
const MAX_RETRIES = 3;
---
// anchor: validateToken signature                ← tail anchor`}</code></pre>

  <hr />

  <h2 id="mmr">{t('docs.intelligenceLayer.mmrTitle')}</h2>
  <p set:html={t('docs.intelligenceLayer.mmrIntro')} />

  <h3>{t('docs.common.howItWorks')}</h3>
  <ol>
    <li set:html={t('docs.intelligenceLayer.mmrStep1')} />
    <li>
      <span set:html={t('docs.intelligenceLayer.mmrStep2')} />
      <code>MMR(l) = &lambda; &times; relevance(l) - (1 - &lambda;) &times; max_similarity(l, selected)</code>
    </li>
    <li set:html={t('docs.intelligenceLayer.mmrStep3')} />
  </ol>

  <h3>{t('docs.common.impact')}</h3>
  <p>{t('docs.intelligenceLayer.mmrImpact')}</p>

  <hr />

  <h2 id="bpe">{t('docs.intelligenceLayer.bpeTitle')}</h2>
  <p set:html={t('docs.intelligenceLayer.bpeIntro')} />

  <h3>{t('docs.intelligenceLayer.optimizationRules')}</h3>
  <table>
    <thead>
      <tr><th>{t('docs.intelligenceLayer.thBefore')}</th><th>{t('docs.intelligenceLayer.thAfter')}</th><th>{t('docs.intelligenceLayer.thTokenSavings')}</th></tr>
    </thead>
    <tbody>
      <tr><td><code>function </code></td><td><code>fn </code></td><td>{t('docs.intelligenceLayer.bpeRule1Savings')}</td></tr>
      <tr><td><code>{' -> '}</code></td><td><code>{'->'}</code></td><td>{t('docs.intelligenceLayer.bpeRule2Savings')}</td></tr>
      <tr><td><code>{' => '}</code></td><td><code>{'=> '}</code></td><td>{t('docs.intelligenceLayer.bpeRule2Savings')}</td></tr>
      <tr><td><code>{'{ }'}</code></td><td><code>{'{}'}</code></td><td>{t('docs.intelligenceLayer.bpeRule2Savings')}</td></tr>
      <tr><td><code>{'    '}</code> {t('docs.intelligenceLayer.bpeRule5Before')}</td><td><code>{'  '}</code> {t('docs.intelligenceLayer.bpeRule5After')}</td><td>{t('docs.intelligenceLayer.bpeRule5Savings')}</td></tr>
      <tr><td><code>'static </code> {t('docs.intelligenceLayer.bpeRule6Before')}</td><td>{t('docs.intelligenceLayer.bpeRule6After')}</td><td>{t('docs.intelligenceLayer.bpeRule6Savings')}</td></tr>
    </tbody>
  </table>

  <h3>{t('docs.common.howItWorks')}</h3>
  <p>{t('docs.intelligenceLayer.bpeHowItWorks')}</p>

  <h3>{t('docs.common.impact')}</h3>
  <p>{t('docs.intelligenceLayer.bpeImpact')}</p>

  <hr />

  <h2>{t('docs.intelligenceLayer.verifyingImpact')}</h2>
  <p set:html={t('docs.intelligenceLayer.verifyingDesc')} />
  <pre><code>{`$ lean-ctx benchmark run
──────────────────────────────────────────
BENCHMARK — /Users/you/project
──────────────────────────────────────────
Files:       143
Total:       285,401 → 42,810 tokens (85% reduction)
Avg/file:    1,997 → 300 tokens

Preservation:
  AST:         98.2%
  Identifiers: 97.4%
  Lines:       96.1%

Mode breakdown:
  full:        68% of files
  map:         22% of files
  signatures:   8% of files
  aggressive:   2% of files`}</code></pre>

  <h2>{t('docs.common.seeAlso')}</h2>
  <ul>
    <li><a href={lp('/docs/tools/intelligence')}>{t('docs.intelligenceLayer.seeAlsoTools')}</a></li>
    <li><a href={lp('/docs/tree-sitter')}>{t('docs.intelligenceLayer.seeAlsoTreeSitter')}</a></li>
    <li><a href={lp('/docs/configuration')}>{t('docs.intelligenceLayer.seeAlsoConfig')}</a></li>
    <li><a href={lp('/benchmark')}>{t('docs.intelligenceLayer.seeAlsoBenchmark')}</a></li>
  </ul>

</DocsLayout>
