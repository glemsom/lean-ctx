---
import '../styles/global.css';
import '../styles/dashboard.css';
import { getLocaleFromUrl, useTranslations } from '../i18n/utils';
import Sidebar from '../components/dashboard/Sidebar.astro';
import Onboarding from '../components/dashboard/Onboarding.astro';
import Overview from '../components/dashboard/Overview.astro';
import Stats from '../components/dashboard/Stats.astro';
import Commands from '../components/dashboard/Commands.astro';
import Models from '../components/dashboard/Models.astro';
import Knowledge from '../components/dashboard/Knowledge.astro';
import Performance from '../components/dashboard/Performance.astro';
import Settings from '../components/dashboard/Settings.astro';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---
<html lang={locale}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#050507" />
  <title>{t('dash.metaTitle')}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" is:inline></script>
</head>
<body class="dash-body">

<Onboarding t={t} />

<div class="dash-app">
  <Sidebar t={t} />

  <main class="dash-main">
    <div class="dash-header">
      <h1 class="dash-page-title font-display" id="viewTitle">{t('dash.viewOverview')}</h1>
      <button id="refreshBtn" class="dash-icon-btn" title={t('dash.refresh')}>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.185"/></svg>
      </button>
    </div>
    <div id="dashError" class="dash-alert dash-alert--error hidden"></div>
    <div id="verifyBanner" class="dash-alert dash-alert--warn hidden"></div>

    <Overview t={t} />
    <Stats t={t} />
    <Commands t={t} />
    <Knowledge t={t} />
    <Performance t={t} />
    <Models t={t} />
    <Settings t={t} />
  </main>
</div>

<script type="module">
  const API = 'https://api.leanctx.com';
  const $ = (id) => document.getElementById(id);
  const show = (el, txt) => { if (!el) return; el.classList.remove('hidden'); el.textContent = txt; };
  const hide = (el) => { if (!el) return; el.classList.add('hidden'); el.textContent = ''; };
  const getApiKey = () => localStorage.getItem('leanctx_api_key');

  function fmt(n) {
    if (n == null) return '—';
    if (n >= 1e9) return (n / 1e9).toFixed(1) + 'B';
    if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
    if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
    return Number(n).toLocaleString('en-US');
  }

  const CM = { i: 2.50, o: 10.0, v: 450, c: 120 };

  function computeCost(inp, out, calls) {
    const iW = inp / 1e6 * CM.i, iC = out / 1e6 * CM.i;
    const saved = inp - out;
    const rate = inp > 0 ? saved / inp : 0;
    const eW = calls * CM.v;
    const eC = rate > 0.01 ? calls * CM.c : eW;
    const oW = eW / 1e6 * CM.o, oC = eC / 1e6 * CM.o;
    return { iW, iC, oW, oC, tW: iW + oW, tC: iC + oC, sv: iW + oW - iC - oC, os: eW - eC };
  }

  function fmtDollar(a) {
    return a >= 1 ? '$' + a.toFixed(2) : '$' + a.toFixed(4);
  }

  function fmtCost(tokens) {
    const cost = (tokens / 1e6) * 2.5;
    return cost >= 1 ? '$' + cost.toFixed(2) : '$' + cost.toFixed(4);
  }

  function escHtml(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  async function api(path, opts = {}) {
    const apiKey = getApiKey();
    const headers = { 'Content-Type': 'application/json', ...(opts.headers || {}) };
    if (apiKey) headers['Authorization'] = 'Bearer ' + apiKey;
    const res = await fetch(API + path, { ...opts, headers });
    const text = await res.text();
    const data = text ? (() => { try { return JSON.parse(text); } catch { return text; } })() : null;
    if (!res.ok) {
      const msg = typeof data === 'string' ? data : (data?.message || data?.error || res.statusText);
      const err = new Error(msg || `HTTP ${res.status}`);
      err.status = res.status;
      throw err;
    }
    return data;
  }

  async function apiOpt(path) {
    try { return await api(path); } catch (e) { if ([403, 404, 405].includes(e?.status)) return null; throw e; }
  }

  /* ── Global state ── */
  let dashState = { stats: [], commands: [], cepData: [], knowledge: [], gotchas: [], buddy: null, me: null, models: null };

  /* ── Timeframe helpers ── */
  function filterByDays(arr, days, dateField = 'date') {
    if (!days) return arr;
    const cutoff = new Date();
    cutoff.setDate(cutoff.getDate() - days);
    const cutStr = cutoff.toISOString().slice(0, 10);
    return arr.filter(item => (item[dateField] || '') >= cutStr);
  }

  function setupTimeframeBar(barId, onChange) {
    const bar = $(barId);
    if (!bar) return;
    bar.querySelectorAll('.dash-tf-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        bar.querySelectorAll('.dash-tf-btn').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        onChange(Number(btn.dataset.tf));
      });
    });
  }

  /* ── Onboarding ── */
  if (localStorage.getItem('leanctx_new_user') === '1') {
    const email = localStorage.getItem('leanctx_user_email');
    if (email) { const cmd = $('onboardCmd'); if (cmd) cmd.textContent = `lean-ctx login ${email}`; }
    $('onboardingOverlay')?.classList.remove('hidden');
  }
  $('onboardDismiss')?.addEventListener('click', () => {
    $('onboardingOverlay')?.classList.add('hidden');
    localStorage.removeItem('leanctx_new_user');
  });

  /* ── View switching with URL routing ── */
  const viewLabels = {
    overview: 'Overview', stats: 'Stats', commands: 'Commands',
    knowledge: 'Knowledge', performance: 'Performance',
    models: 'Adaptive Models', settings: 'Settings'
  };
  const validViews = new Set(Object.keys(viewLabels));
  let currentView = 'overview';

  function getViewFromUrl() {
    const seg = window.location.pathname.replace(/\/$/, '').split('/').pop();
    return validViews.has(seg) ? seg : 'overview';
  }

  function switchView(name, pushState = true) {
    if (!validViews.has(name)) name = 'overview';
    currentView = name;
    document.querySelectorAll('.dash-view').forEach(v => v.classList.remove('is-active'));
    document.querySelector(`.dash-view[data-panel="${name}"]`)?.classList.add('is-active');
    document.querySelectorAll('.dash-nav-item[data-view]').forEach(n => n.classList.toggle('is-active', n.dataset.view === name));
    document.querySelectorAll('.dash-mob-btn[data-view]').forEach(n => n.classList.toggle('is-active', n.dataset.view === name));
    if ($('viewTitle')) $('viewTitle').textContent = viewLabels[name] || name;
    if (pushState) {
      const url = '/dashboard/' + name;
      if (window.location.pathname !== url) history.pushState({ view: name }, '', url);
    }
  }

  window.addEventListener('popstate', (e) => {
    switchView(e.state?.view || getViewFromUrl(), false);
  });

  document.querySelectorAll('.dash-nav-item[data-view]').forEach(btn =>
    btn.addEventListener('click', () => switchView(btn.dataset.view))
  );
  document.querySelectorAll('.dash-mob-btn[data-view]').forEach(btn =>
    btn.addEventListener('click', () => switchView(btn.dataset.view))
  );
  document.querySelectorAll('.dash-quick-link[data-view]').forEach(btn =>
    btn.addEventListener('click', () => switchView(btn.dataset.view))
  );

  $('logoutBtn')?.addEventListener('click', () => {
    localStorage.removeItem('leanctx_api_key');
    localStorage.removeItem('leanctx_token');
    localStorage.removeItem('leanctx_user_email');
    localStorage.removeItem('leanctx_new_user');
    window.location.href = '/';
  });
  $('refreshBtn')?.addEventListener('click', loadDashboard);

  /* ── Chart theme ── */
  const C = {
    accent: '#34d399', accentFaded: 'rgba(52,211,153,0.10)',
    blue: '#60a5fa', blueFaded: 'rgba(96,165,250,0.10)',
    purple: '#a78bfa', purpleFaded: 'rgba(167,139,250,0.10)',
    pink: '#f472b6', yellow: '#fbbf24', red: '#f87171',
    grid: 'rgba(255,255,255,0.025)', muted: '#6b6b82',
    surface: 'rgba(255,255,255,0.03)', tooltipBg: '#111118',
    tooltipBorder: '#1e1e28'
  };

  const tooltipStyle = {
    backgroundColor: C.tooltipBg, titleColor: '#f0f0f5', bodyColor: '#b4b4c8',
    borderColor: C.tooltipBorder, borderWidth: 1, cornerRadius: 8,
    padding: { top: 8, bottom: 8, left: 12, right: 12 },
    titleFont: { size: 11, weight: '600' }, bodyFont: { size: 11 },
    displayColors: true, boxPadding: 4
  };

  const scaleDefaults = {
    x: { grid: { color: C.grid }, ticks: { color: C.muted, font: { size: 10 } } },
    y: { grid: { color: C.grid }, ticks: { color: C.muted, font: { size: 10 }, callback: v => fmt(v) }, beginAtZero: true }
  };

  /* ── Charts ── */
  let charts = {};

  function destroyChart(key) { if (charts[key]) { charts[key].destroy(); delete charts[key]; } }

  function createLineChart(canvasId, key, data, color, label, yCallback) {
    const ctx = $(canvasId)?.getContext('2d');
    if (!ctx || !data.labels.length) return;
    destroyChart(key);
    const gradient = ctx.createLinearGradient(0, 0, 0, 200);
    const rgb = color === C.accent ? '52,211,153' : color === C.pink ? '244,114,182' : color === C.blue ? '96,165,250' : color === C.purple ? '167,139,250' : color === C.yellow ? '251,191,36' : '52,211,153';
    gradient.addColorStop(0, `rgba(${rgb},0.15)`);
    gradient.addColorStop(1, `rgba(${rgb},0)`);
    charts[key] = new Chart(ctx, {
      type: 'line',
      data: { labels: data.labels, datasets: [{ data: data.values, borderColor: color, backgroundColor: gradient, fill: true, tension: 0.4, pointRadius: data.values.length < 30 ? 3 : 0, pointHoverRadius: 5, borderWidth: 2 }] },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { display: false }, tooltip: { ...tooltipStyle, callbacks: { label: ctx => (yCallback ? yCallback(ctx.raw) : fmt(ctx.raw) + ' ' + (label || '')) } } },
        scales: {
          x: { grid: { color: C.grid }, ticks: { color: C.muted, font: { size: 9 }, maxTicksLimit: 10 } },
          y: { grid: { color: C.grid }, ticks: { color: C.muted, font: { size: 9 }, callback: yCallback || (v => fmt(v)) }, beginAtZero: true }
        }
      }
    });
  }

  function createCompressionGauge(pct) {
    const ctx = $('chartCompression')?.getContext('2d');
    if (!ctx) return;
    pct = Math.min(Math.max(pct || 0, 0), 100);
    destroyChart('compression');
    charts.compression = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: ['Saved', 'Used'],
        datasets: [{ data: [pct, 100 - pct], backgroundColor: [C.accent, C.surface], borderWidth: 0, borderRadius: 2 }]
      },
      options: {
        responsive: true, maintainAspectRatio: true, cutout: '78%',
        plugins: { legend: { display: false }, tooltip: { enabled: false } }
      },
      plugins: [{
        id: 'centerText',
        afterDraw(chart) {
          const { ctx: c, chartArea: { width, height, top, left } } = chart;
          c.save();
          c.font = "bold clamp(1.125rem, 1vw + 0.5rem, 1.5rem) 'Space Grotesk', system-ui";
          c.fillStyle = C.accent;
          c.textAlign = 'center';
          c.textBaseline = 'middle';
          c.fillText(pct.toFixed(0) + '%', left + width / 2, top + height / 2);
          c.restore();
        }
      }]
    });
  }

  /* ── Aggregate stats for timeframe ── */
  function computeStatsAggregates(stats) {
    const totalSaved = stats.reduce((a, s) => a + (Number(s?.tokens_saved) || 0), 0);
    const totalCalls = stats.reduce((a, s) => a + (Number(s?.tool_calls) || 0), 0);
    const totalOrig = stats.reduce((a, s) => a + (Number(s?.tokens_original) || 0), 0);
    const totalComp = stats.reduce((a, s) => a + (Number(s?.tokens_compressed) || 0), 0);
    const totalHits = stats.reduce((a, s) => a + (Number(s?.cache_hits) || 0), 0);
    const totalMisses = stats.reduce((a, s) => a + (Number(s?.cache_misses) || 0), 0);
    const compressionPct = totalOrig > 0 ? ((totalOrig - totalComp) / totalOrig) * 100 : 0;
    const savingsRate = totalOrig > 0 ? (totalSaved / totalOrig * 100) : 0;
    const cacheRate = (totalHits + totalMisses) > 0 ? (totalHits / (totalHits + totalMisses) * 100) : 0;
    const avgDaily = stats.length > 0 ? totalSaved / stats.length : 0;
    return { totalSaved, totalCalls, totalOrig, totalComp, compressionPct, savingsRate, cacheRate, avgDaily };
  }

  /* ── Render: Overview ── */
  function renderOverview(days = 30) {
    const stats = days ? filterByDays(dashState.stats, days) : dashState.stats;
    const agg = computeStatsAggregates(stats);
    const chartStats = stats.slice(0, 90).reverse();
    const cost = computeCost(agg.totalOrig, agg.totalComp, agg.totalCalls);

    if ($('kpiTokens')) $('kpiTokens').textContent = fmt(agg.totalSaved);
    if ($('kpiCostSaved')) $('kpiCostSaved').textContent = fmtDollar(cost.sv);
    if ($('kpiCostSub')) $('kpiCostSub').textContent = 'input ' + fmtDollar(cost.iW - cost.iC) + ' · output ' + fmtDollar(cost.oW - cost.oC);
    if ($('kpiDays')) $('kpiDays').textContent = stats.length.toString();
    if ($('kpiToolCalls')) $('kpiToolCalls').textContent = fmt(agg.totalCalls);
    if ($('kpiCompression')) $('kpiCompression').textContent = agg.compressionPct > 0 ? agg.compressionPct.toFixed(0) + '%' : '—';
    if ($('kpiAvgDaily')) $('kpiAvgDaily').textContent = fmt(Math.round(agg.avgDaily));

    createLineChart('chartTokens', 'tokens',
      { labels: chartStats.map(s => s.date?.slice(5) || ''), values: chartStats.map(s => s.tokens_saved || 0) },
      C.accent, 'tokens'
    );
    createCompressionGauge(agg.compressionPct);
  }

  setupTimeframeBar('overviewTimeframe', (days) => renderOverview(days));

  function computeCepCacheByDay(cepData) {
    const map = {};
    const list = Array.isArray(cepData) ? cepData : [];
    for (const s of list) {
      const date = (s.recorded_at || '').slice(0, 10);
      if (!date) continue;
      if (!map[date]) map[date] = { calls: 0, hits: 0 };
      const calls = Math.max(s.tool_calls || 1, 1);
      const rate = s.cache_hit_rate || 0;
      map[date].calls += calls;
      map[date].hits += Math.round(calls * rate);
    }
    return map;
  }

  function enrichStatsWithCep(stats, cepByDay) {
    return stats.map(s => {
      const hasCache = (s.cache_hits || 0) + (s.cache_misses || 0) > 0;
      if (hasCache) return s;
      const cep = cepByDay[s.date];
      if (!cep) return s;
      return { ...s, cache_hits: cep.hits, cache_misses: cep.calls - cep.hits };
    });
  }

  /* ── Render: Stats ── */
  function renderStats(days = 30) {
    const rawStats = days ? filterByDays(dashState.stats, days) : dashState.stats;
    const cepByDay = computeCepCacheByDay(dashState.cepData);
    const stats = enrichStatsWithCep(rawStats, cepByDay);
    const agg = computeStatsAggregates(stats);
    const chartStats = stats.slice(0, 90).reverse();

    const cost = computeCost(agg.totalOrig, agg.totalComp, agg.totalCalls);
    if ($('statsTfTokens')) $('statsTfTokens').textContent = fmt(agg.totalSaved);
    if ($('statsTfCost')) $('statsTfCost').textContent = fmtDollar(cost.sv);
    if ($('statsTfCostSub')) $('statsTfCostSub').textContent = 'without ' + fmtDollar(cost.tW) + ' · with ' + fmtDollar(cost.tC);
    if ($('statsTfCalls')) $('statsTfCalls').textContent = fmt(agg.totalCalls);
    if ($('statsTfRate')) $('statsTfRate').textContent = agg.savingsRate > 0 ? agg.savingsRate.toFixed(0) + '%' : '—';
    if ($('statsTfCacheHit')) $('statsTfCacheHit').textContent = agg.cacheRate > 0 ? agg.cacheRate.toFixed(0) + '%' : '—';

    createDailyChart(chartStats);
    createSavingsRateChart(chartStats);
    createCacheChart(chartStats);
    createTokenDistChart(agg.totalOrig, agg.totalComp, agg.totalSaved);
    renderStatsTable(stats);
  }

  setupTimeframeBar('statsTimeframe', (days) => renderStats(days));

  function createDailyChart(stats) {
    const ctx = $('chartDaily')?.getContext('2d');
    if (!ctx || !stats.length) return;
    destroyChart('daily');
    charts.daily = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: stats.map(s => s.date?.slice(5) || ''),
        datasets: [
          { label: 'Tokens Saved', data: stats.map(s => s.tokens_saved || 0), backgroundColor: C.accent, borderRadius: 3, barPercentage: 0.7 },
          { label: 'Original', data: stats.map(s => s.tokens_original || 0), backgroundColor: 'rgba(96,165,250,0.25)', borderRadius: 3, barPercentage: 0.7 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { labels: { color: C.muted, font: { size: 10 }, boxWidth: 8, boxHeight: 8 } }, tooltip: tooltipStyle },
        scales: { ...scaleDefaults, x: { ...scaleDefaults.x, stacked: false } }
      }
    });
  }

  function createSavingsRateChart(stats) {
    createLineChart('chartSavingsRate', 'savingsRate',
      { labels: stats.map(s => s.date?.slice(5) || ''), values: stats.map(s => { const orig = s.tokens_original || 1; return ((s.tokens_saved || 0) / orig * 100).toFixed(1); }) },
      C.pink, '', v => v + '%'
    );
  }

  function createCacheChart(stats) {
    const ctx = $('chartCache')?.getContext('2d');
    if (!ctx || !stats.length) return;
    destroyChart('cache');
    charts.cache = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: stats.map(s => s.date?.slice(5) || ''),
        datasets: [
          { label: 'Hits', data: stats.map(s => s.cache_hits || 0), backgroundColor: C.accent, borderRadius: 2, barPercentage: 0.8 },
          { label: 'Misses', data: stats.map(s => s.cache_misses || 0), backgroundColor: 'rgba(248,113,113,0.4)', borderRadius: 2, barPercentage: 0.8 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { labels: { color: C.muted, font: { size: 9 }, boxWidth: 6, boxHeight: 6 } }, tooltip: tooltipStyle },
        scales: {
          x: { stacked: true, grid: { display: false }, ticks: { color: C.muted, font: { size: 9 }, maxTicksLimit: 8 } },
          y: { stacked: true, grid: { color: C.grid }, ticks: { color: C.muted, font: { size: 9 } }, beginAtZero: true }
        }
      }
    });
  }

  function createTokenDistChart(totalOrig, totalComp, totalSaved) {
    const ctx = $('chartTokenDist')?.getContext('2d');
    if (!ctx || !totalOrig) return;
    destroyChart('tokenDist');
    charts.tokenDist = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: ['Saved', 'Compressed'],
        datasets: [{ data: [totalSaved, totalComp], backgroundColor: [C.accent, C.blue], borderWidth: 0, borderRadius: 2 }]
      },
      options: {
        responsive: true, maintainAspectRatio: true, cutout: '70%',
        plugins: { legend: { position: 'bottom', labels: { color: C.muted, font: { size: 9 }, boxWidth: 6, boxHeight: 6, padding: 10 } }, tooltip: { ...tooltipStyle, callbacks: { label: ctx => fmt(ctx.raw) + ' tokens' } } }
      }
    });
  }

  /* ── Render: Stats Table ── */
  function renderStatsTable(stats) {
    const el = $('statsTable');
    if (!el) return;
    if (!stats.length) {
      el.innerHTML = `<div class="dash-empty"><svg class="dash-empty-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75z"/></svg><p class="dash-empty-text">No stats yet — sync your data first.</p><div class="dash-empty-action"><code class="dash-code" style="display:inline-block">lean-ctx sync</code></div></div>`;
      return;
    }
    const cnt = $('statsCount');
    if (cnt) cnt.textContent = `${stats.length} days`;

    let maxVisible = 30;
    const renderRows = (limit) => stats.slice(0, limit).map(r => {
      const rate = r.tokens_original ? ((r.tokens_saved || 0) / r.tokens_original * 100) : 0;
      const cacheTotal = (r.cache_hits || 0) + (r.cache_misses || 0);
      const cacheRate = cacheTotal ? ((r.cache_hits || 0) / cacheTotal * 100) : 0;
      return `<tr>
        <td class="td-date">${r.date}</td>
        <td class="td-num">${fmt(r.tokens_original)}</td>
        <td class="td-num">${fmt(r.tokens_compressed)}</td>
        <td class="td-num td-accent">${fmt(r.tokens_saved)}</td>
        <td><div class="dash-rate"><div class="dash-rate-track"><div class="dash-rate-fill" style="width:${rate.toFixed(0)}%"></div></div><span class="dash-rate-text">${rate.toFixed(0)}%</span></div></td>
        <td class="td-num">${r.tool_calls || 0}</td>
        <td class="td-num">${r.cache_hits || 0}</td>
        <td><div class="dash-rate"><div class="dash-rate-track"><div class="dash-rate-fill" style="width:${cacheRate.toFixed(0)}%"></div></div><span class="dash-rate-text">${cacheRate.toFixed(0)}%</span></div></td>
      </tr>`;
    }).join('');

    el.innerHTML = `<div class="dash-table-wrap"><table class="dash-table"><thead><tr>
      <th>Date</th><th class="text-right">Original</th><th class="text-right">Compressed</th>
      <th class="text-right">Saved</th><th>Rate</th><th class="text-right">Calls</th>
      <th class="text-right">Cache Hits</th><th>Hit Rate</th>
    </tr></thead><tbody id="statsRows">${renderRows(maxVisible)}</tbody></table></div>${stats.length > maxVisible ? '<button class="dash-show-more" id="statsMore">Show all ' + stats.length + ' days</button>' : ''}`;

    $('statsMore')?.addEventListener('click', () => {
      $('statsRows').innerHTML = renderRows(stats.length);
      $('statsMore')?.remove();
    });
  }

  /* ── CSV Export ── */
  $('exportCsvBtn')?.addEventListener('click', () => {
    const stats = dashState.stats;
    if (!stats.length) return;
    const headers = ['date','tokens_original','tokens_compressed','tokens_saved','tool_calls','cache_hits','cache_misses'];
    const rows = stats.map(r => headers.map(h => r[h] ?? '').join(','));
    const csv = [headers.join(','), ...rows].join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'lean-ctx-stats.csv';
    a.click();
    URL.revokeObjectURL(url);
  });

  /* ── Render: Models ── */
  const CATEGORY_COLORS = {
    ARCHITECTURE: 'green', BUG: 'red', DEBUGGING: 'red', PERFORMANCE: 'blue',
    SECURITY: 'yellow', TESTING: 'purple', WORKFLOW: 'indigo', DECISION: 'pink',
    FINDING: 'teal', 'E2E': 'blue', TEST: 'purple'
  };

  function renderModels(models) {
    const el = $('modelsContent');
    if (!el) return;
    const list = models?.models || [];
    if (!list.length) {
      el.innerHTML = `<div class="dash-empty"><svg class="dash-empty-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12"/></svg><p class="dash-empty-text">No model recommendations yet. Keep using lean-ctx to build personalized compression models.</p></div>`;
      return;
    }
    const cnt = $('modelsCount');
    if (cnt) cnt.textContent = `${list.length} models`;
    el.innerHTML = `<div class="dash-models-grid">${list.map(m => {
      const conf = ((m.confidence || 0) * 100).toFixed(0);
      return `<div class="dash-model-card">
        <div class="dash-model-ext">${m.file_ext || '?'}</div>
        <div class="dash-model-meta">
          <span class="dash-model-tag dash-model-tag--mode">${m.recommended_mode || '—'}</span>
          <span class="dash-model-tag">${m.size_bucket || '—'}</span>
        </div>
        <div class="dash-model-bar-wrap">
          <div class="dash-model-bar-track"><div class="dash-model-bar-fill" style="width:${conf}%"></div></div>
          <span class="dash-model-bar-text">${conf}%</span>
        </div>
      </div>`;
    }).join('')}</div>`;
  }

  /* ── Render: Knowledge ── */
  let allKnowledge = [];

  function renderKnowledge(entries) {
    const el = $('knowledgeList');
    if (!el) return;
    allKnowledge = Array.isArray(entries) ? entries : [];

    if ($('knowledgeKpiCount')) $('knowledgeKpiCount').textContent = allKnowledge.length.toString();

    if (!allKnowledge.length) {
      $('knowledgeFilters').style.display = 'none';
      el.innerHTML = `<div class="dash-empty"><svg class="dash-empty-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292"/></svg><p class="dash-empty-text">No knowledge entries synced yet. Run <code style="color:#34d399">lean-ctx sync</code> to upload your project knowledge.</p></div>`;
      return;
    }

    const cnt = $('knowledgeCount');
    if (cnt) cnt.textContent = `${allKnowledge.length} entries`;

    const categories = [...new Set(allKnowledge.map(e => e.category || 'OTHER'))].sort();
    const filtersEl = $('knowledgeFilters');
    filtersEl.style.display = 'flex';
    const existingPills = filtersEl.querySelectorAll('.dash-filter-pill');
    if (!existingPills.length) {
      const allPill = document.createElement('button');
      allPill.className = 'dash-filter-pill is-active';
      allPill.textContent = 'All';
      allPill.dataset.cat = '';
      filtersEl.appendChild(allPill);
      categories.forEach(cat => {
        const pill = document.createElement('button');
        pill.className = 'dash-filter-pill';
        pill.textContent = cat;
        pill.dataset.cat = cat;
        filtersEl.appendChild(pill);
      });
      filtersEl.querySelectorAll('.dash-filter-pill').forEach(pill => {
        pill.addEventListener('click', () => {
          filtersEl.querySelectorAll('.dash-filter-pill').forEach(p => p.classList.remove('is-active'));
          pill.classList.add('is-active');
          filterKnowledge();
        });
      });
    }

    filterKnowledge();
  }

  function filterKnowledge() {
    const el = $('knowledgeList');
    if (!el) return;
    const activePill = document.querySelector('.dash-filter-pill.is-active');
    const cat = activePill?.dataset.cat || '';
    const query = ($('knowledgeSearch')?.value || '').toLowerCase();

    let filtered = allKnowledge;
    if (cat) filtered = filtered.filter(e => e.category === cat);
    if (query) filtered = filtered.filter(e =>
      (e.key || '').toLowerCase().includes(query) ||
      (e.value || '').toLowerCase().includes(query) ||
      (e.category || '').toLowerCase().includes(query)
    );

    if (!filtered.length) {
      el.innerHTML = '<p style="color:var(--color-muted);padding:1rem 0;text-align:center;font-size:0.8125rem">No matching entries.</p>';
      return;
    }

    el.innerHTML = `<div class="dash-table-wrap"><table class="dash-table dash-knowledge-table">
      <thead><tr><th>Category</th><th>Key</th><th>Value</th><th class="text-right">Confidence</th></tr></thead>
      <tbody>${filtered.slice(0, 50).map(e => {
        const color = CATEGORY_COLORS[e.category?.toUpperCase()] || 'muted';
        const conf = e.confidence ? Math.min(Math.round(e.confidence), 5) : 0;
        const stars = conf > 0 ? '★'.repeat(conf) + '☆'.repeat(5 - conf) : '';
        return `<tr>
          <td><span class="dash-badge dash-badge--${color}">${e.category || 'OTHER'}</span></td>
          <td class="dash-knowledge-key">${escHtml(e.key || '')}</td>
          <td class="dash-knowledge-value">${escHtml(e.value || '')}</td>
          <td class="text-right dash-knowledge-confidence">${stars}</td>
        </tr>`;
      }).join('')}</tbody></table></div>${filtered.length > 50 ? `<p style="color:var(--color-muted);font-size:0.75rem;text-align:center;padding:0.5rem">Showing 50 of ${filtered.length}</p>` : ''}`;
  }

  $('knowledgeSearch')?.addEventListener('input', filterKnowledge);

  /* ── Render: Gotchas ── */
  function renderGotchas(gotchas) {
    const el = $('gotchaList');
    if (!el) return;
    const list = Array.isArray(gotchas) ? gotchas : [];

    const totalDetected = list.reduce((a, g) => a + (Number(g.occurrences) || 0), 0);
    const totalPrevented = list.reduce((a, g) => a + (Number(g.prevented_count) || 0), 0);
    if ($('gotchaKpiDetected')) $('gotchaKpiDetected').textContent = fmt(totalDetected);
    if ($('gotchaKpiPrevented')) $('gotchaKpiPrevented').textContent = fmt(totalPrevented);

    if (!list.length) {
      el.innerHTML = `<div style="padding:1.125rem"><div class="dash-empty"><svg class="dash-empty-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/></svg><p class="dash-empty-text">No gotchas synced yet. Bug memory builds as you code.</p></div></div>`;
      return;
    }

    const cnt = $('gotchaCount');
    if (cnt) cnt.textContent = `${list.length} patterns`;

    el.innerHTML = `<div class="dash-table-wrap"><table class="dash-table"><thead><tr>
      <th>Category</th><th>Pattern</th><th>Fix</th><th class="text-right">Seen</th><th class="text-right">Prevented</th>
    </tr></thead><tbody>${list.slice(0, 50).map(g => `<tr>
      <td><span class="dash-badge dash-badge--${g.category === 'build' ? 'red' : g.category === 'runtime' ? 'yellow' : g.category === 'test' ? 'blue' : 'muted'}">${escHtml(g.category || '—')}</span></td>
      <td style="font-family:var(--font-mono);font-size:0.6875rem;max-width:16rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${escHtml(g.pattern)}">${escHtml(g.pattern)}</td>
      <td style="font-size:0.75rem;max-width:14rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${escHtml(g.fix)}">${escHtml(g.fix)}</td>
      <td class="td-num">${g.occurrences || 0}</td>
      <td class="td-num td-accent">${g.prevented_count || 0}</td>
    </tr>`).join('')}</tbody></table></div>`;
  }

  /* ── Render: Commands ── */
  function renderCommands(commands) {
    const el = $('cmdTable');
    if (!el) return;
    const list = Array.isArray(commands) ? commands : [];

    const totalCmds = list.reduce((a, c) => a + (Number(c.count) || 0), 0);
    const totalInp = list.reduce((a, c) => a + (Number(c.input_tokens) || 0), 0);
    const totalOut = list.reduce((a, c) => a + (Number(c.output_tokens) || 0), 0);
    const totalSaved = totalInp - totalOut;
    const sorted = [...list].sort((a, b) => (Number(b.tokens_saved) || 0) - (Number(a.tokens_saved) || 0));
    const topSaver = sorted.length ? sorted[0].command : '—';
    const cmdCost = computeCost(totalInp, totalOut, totalCmds);

    if ($('cmdTotal')) $('cmdTotal').textContent = fmt(totalCmds);
    if ($('cmdTokensSaved')) $('cmdTokensSaved').textContent = fmt(totalSaved);
    if ($('cmdCostSaved')) $('cmdCostSaved').textContent = fmtDollar(cmdCost.sv);
    if ($('cmdTopSaver')) $('cmdTopSaver').textContent = topSaver;
    if ($('cmdUniqueCount')) $('cmdUniqueCount').textContent = list.length.toString();

    if (!list.length) {
      el.innerHTML = `<div style="padding:1.125rem"><div class="dash-empty"><svg class="dash-empty-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3"/></svg><p class="dash-empty-text">No command data synced yet. Run <code style="color:#34d399">lean-ctx sync</code> to upload.</p></div></div>`;
      return;
    }

    const cnt = $('cmdCount');
    if (cnt) cnt.textContent = `${list.length} commands`;

    el.innerHTML = `<div class="dash-table-wrap"><table class="dash-table"><thead><tr>
      <th>Command</th><th>Source</th><th class="text-right">Count</th>
      <th class="text-right">Input</th><th class="text-right">Output</th>
      <th class="text-right">Saved</th><th>Rate</th>
    </tr></thead><tbody>${sorted.map(c => {
      const inputTokens = Number(c.input_tokens) || 0;
      const saved = Number(c.tokens_saved) || 0;
      const rate = inputTokens ? ((saved / inputTokens) * 100) : 0;
      return `<tr>
        <td style="font-family:var(--font-mono);font-size:0.6875rem">${escHtml(c.command)}</td>
        <td><span class="dash-badge dash-badge--${c.source === 'mcp' ? 'green' : 'blue'}">${c.source || '—'}</span></td>
        <td class="td-num">${fmt(c.count)}</td>
        <td class="td-num">${fmt(inputTokens)}</td>
        <td class="td-num">${fmt(Number(c.output_tokens) || 0)}</td>
        <td class="td-num td-accent">${fmt(saved)}</td>
        <td><div class="dash-rate"><div class="dash-rate-track"><div class="dash-rate-fill" style="width:${Math.min(rate, 100).toFixed(0)}%"></div></div><span class="dash-rate-text">${rate.toFixed(0)}%</span></div></td>
      </tr>`;
    }).join('')}</tbody></table></div>`;

    renderSourceDistChart(list);
    renderTopSavers(sorted);
    renderMostExpensive(list);
  }

  function renderTopSavers(sorted) {
    const el = $('cmdTopSavers');
    if (!el) return;
    const top5 = sorted.slice(0, 5);
    if (!top5.length) { el.innerHTML = '<p style="color:var(--color-muted);padding:0.75rem;font-size:0.8125rem">No data</p>'; return; }
    const maxSaved = Number(top5[0]?.tokens_saved) || 1;
    el.innerHTML = `<div style="padding:0.75rem 1rem">${top5.map(c => {
      const saved = Number(c.tokens_saved) || 0;
      const pct = (saved / maxSaved * 100).toFixed(0);
      return `<div style="margin-bottom:0.625rem">
        <div style="display:flex;justify-content:space-between;font-size:0.75rem;margin-bottom:0.25rem">
          <span style="font-family:var(--font-mono);font-size:0.6875rem">${escHtml(c.command)}</span>
          <span style="color:#34d399;font-weight:500">${fmt(saved)}</span>
        </div>
        <div class="dash-rate-track" style="height:4px"><div class="dash-rate-fill" style="width:${pct}%"></div></div>
      </div>`;
    }).join('')}</div>`;
  }

  function renderMostExpensive(list) {
    const el = $('cmdMostExpensive');
    if (!el) return;
    const sorted = [...list].sort((a, b) => (Number(b.input_tokens) || 0) - (Number(a.input_tokens) || 0));
    const top5 = sorted.slice(0, 5);
    if (!top5.length) { el.innerHTML = '<p style="color:var(--color-muted);padding:0.75rem;font-size:0.8125rem">No data</p>'; return; }
    const maxInput = Number(top5[0]?.input_tokens) || 1;
    el.innerHTML = `<div style="padding:0.75rem 1rem">${top5.map(c => {
      const input = Number(c.input_tokens) || 0;
      const pct = (input / maxInput * 100).toFixed(0);
      return `<div style="margin-bottom:0.625rem">
        <div style="display:flex;justify-content:space-between;font-size:0.75rem;margin-bottom:0.25rem">
          <span style="font-family:var(--font-mono);font-size:0.6875rem">${escHtml(c.command)}</span>
          <span style="color:#f87171;font-weight:500">${fmt(input)}</span>
        </div>
        <div class="dash-rate-track" style="height:4px"><div class="dash-rate-fill" style="width:${pct}%;background:#f87171"></div></div>
      </div>`;
    }).join('')}</div>`;
  }

  function renderSourceDistChart(commands) {
    const ctx = $('chartSourceDist')?.getContext('2d');
    if (!ctx) return;
    destroyChart('sourceDist');
    const mcpCount = commands.filter(c => c.source === 'mcp').reduce((a, c) => a + (Number(c.count) || 0), 0);
    const hookCount = commands.filter(c => c.source === 'hook').reduce((a, c) => a + (Number(c.count) || 0), 0);
    const otherCount = commands.filter(c => c.source !== 'mcp' && c.source !== 'hook').reduce((a, c) => a + (Number(c.count) || 0), 0);
    const data = [mcpCount, hookCount];
    const labels = ['MCP', 'Hook'];
    const colors = [C.accent, C.blue];
    if (otherCount > 0) { data.push(otherCount); labels.push('Other'); colors.push(C.purple); }
    charts.sourceDist = new Chart(ctx, {
      type: 'doughnut',
      data: { labels, datasets: [{ data, backgroundColor: colors, borderWidth: 0, borderRadius: 2 }] },
      options: {
        responsive: true, maintainAspectRatio: true, cutout: '65%',
        plugins: { legend: { position: 'bottom', labels: { color: C.muted, font: { size: 9 }, boxWidth: 6, boxHeight: 6, padding: 10 } }, tooltip: { ...tooltipStyle, callbacks: { label: ctx => fmt(ctx.raw) + ' calls' } } }
      }
    });
  }

  /* ── Render: Performance (CEP) ── */
  function renderPerformance(cepData) {
    const list = Array.isArray(cepData) ? cepData.slice().reverse() : [];

    if ($('cepSessions')) $('cepSessions').textContent = list.length.toString();

    if (!list.length) {
      ['cepLatest', 'cepAvg', 'cepBest', 'cepCacheRate'].forEach(id => { if ($(id)) $(id).textContent = '—'; });
      return;
    }

    const latest = list[list.length - 1];
    const avgScore = (list.reduce((a, s) => a + (s.score || 0), 0) / list.length);
    const bestScore = Math.max(...list.map(s => s.score || 0));
    const avgCache = list.filter(s => s.cache_hit_rate != null);
    const avgCacheRate = avgCache.length ? (avgCache.reduce((a, s) => a + s.cache_hit_rate, 0) / avgCache.length * 100) : 0;

    if ($('cepLatest')) $('cepLatest').textContent = (latest.score || 0).toFixed(1);
    if ($('cepAvg')) $('cepAvg').textContent = avgScore.toFixed(1);
    if ($('cepBest')) $('cepBest').textContent = bestScore.toFixed(1);
    if ($('cepCacheRate')) $('cepCacheRate').textContent = avgCacheRate.toFixed(0) + '%';

    const labels = list.map((s, i) => {
      const d = s.recorded_at?.slice(5, 10) || `#${i + 1}`;
      return d;
    });

    createLineChart('chartCepScore', 'cepScore',
      { labels, values: list.map(s => (s.score || 0).toFixed(2)) },
      C.accent, '', v => Number(v).toFixed(1)
    );
    createLineChart('chartCepCache', 'cepCache',
      { labels, values: list.map(s => ((s.cache_hit_rate || 0) * 100).toFixed(1)) },
      C.blue, '', v => v + '%'
    );
    createLineChart('chartCepCompression', 'cepCompression',
      { labels, values: list.map(s => ((s.compression_rate || 0) * 100).toFixed(1)) },
      C.pink, '', v => v + '%'
    );
    createLineChart('chartCepDiversity', 'cepDiversity',
      { labels, values: list.map(s => ((s.mode_diversity || 0) * 100).toFixed(1)) },
      C.purple, '', v => v + '%'
    );
  }

  function renderFeedbackThresholds(data) {
    const el = $('feedbackTable');
    if (!el || !data || !data.length) {
      if (el) el.innerHTML = '<p style="color:var(--color-muted);font-size:0.75rem">No learned thresholds yet. Use lean-ctx more to build personalized models.</p>';
      return;
    }
    const sorted = data.slice().sort((a, b) => b.sample_count - a.sample_count);
    const rows = sorted.map(t => {
      const effPct = (t.avg_efficiency * 100).toFixed(0);
      const effColor = t.avg_efficiency > 0.8 ? C.accent : t.avg_efficiency > 0.5 ? C.yellow : C.pink;
      return `<tr>
        <td style="font-weight:600;color:var(--color-text-bright)">${escHtml(t.language || 'default')}</td>
        <td>${t.entropy.toFixed(2)}</td>
        <td>${t.jaccard.toFixed(2)}</td>
        <td>${t.sample_count}</td>
        <td><span style="color:${effColor};font-weight:600">${effPct}%</span>
          <div class="dash-rate-track" style="height:3px;margin-top:2px"><div class="dash-rate-fill" style="width:${effPct}%;background:${effColor}"></div></div>
        </td>
      </tr>`;
    }).join('');
    el.innerHTML = `<table class="dash-table" style="width:100%">
      <thead><tr><th>Language</th><th>Entropy θ</th><th>Jaccard θ</th><th>Samples</th><th>Efficiency</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
  }

  /* ── Render: Buddy ── */
  let buddyAnimTimer = null;

  function renderBuddy(buddy) {
    const el = $('buddyWidget');
    if (!el) return;
    if (buddyAnimTimer) { clearInterval(buddyAnimTimer); buddyAnimTimer = null; }

    if (!buddy || !buddy.name) {
      el.innerHTML = `<div class="dash-empty" style="padding:0.75rem 0"><p class="dash-empty-text" style="font-size:0.8125rem">No buddy yet. Keep using lean-ctx to hatch your companion!</p></div>`;
      return;
    }

    const rarityColors = { Egg: C.muted, Common: C.muted, Uncommon: C.accent, Rare: C.blue, Epic: C.purple, Legendary: C.yellow };
    const moodEmoji = { Ecstatic: '🤩', Happy: '😊', Content: '😌', Worried: '😰', Sleeping: '😴' };
    const rarityCol = rarityColors[buddy.rarity] || C.muted;
    const xpPct = buddy.xp_next_level > 0 ? Math.min(100, Math.round(buddy.xp / buddy.xp_next_level * 100)) : 0;
    const streak = buddy.streak_days ?? buddy.streak ?? 0;

    const hasAscii = buddy.ascii_art && buddy.ascii_art.length;
    const asciiHtml = hasAscii ? `<div class="dash-buddy-sprite"><pre id="buddyAsciiPre">${buddy.ascii_art.map(l => escHtml(l)).join('\n')}</pre></div>` : '';

    const st = buddy.stats || {};
    const rpgStats = [
      { label: 'CMP', val: st.compression ?? 0, color: C.accent },
      { label: 'VIG', val: st.vigilance ?? 0, color: C.yellow },
      { label: 'END', val: st.endurance ?? 0, color: C.purple },
      { label: 'WIS', val: st.wisdom ?? 0, color: C.blue },
      { label: 'EXP', val: st.experience ?? 0, color: '#e2e2ef' },
    ];
    const hasRpg = rpgStats.some(s => s.val > 0);

    el.innerHTML = `
      <div class="dash-buddy">
        ${asciiHtml}
        <div class="dash-buddy-info">
          <div class="dash-buddy-header">
            <span class="dash-buddy-name">${escHtml(buddy.name)}</span>
            <span class="dash-buddy-rarity" style="color:${rarityCol};border-color:${rarityCol}">${escHtml(buddy.rarity || 'Egg')}</span>
          </div>
          <div class="dash-buddy-meta">${escHtml(buddy.species || '?')} · Lv.${buddy.level} · ${moodEmoji[buddy.mood] || '😐'} ${buddy.mood || '—'} · ${streak}d streak</div>
          ${buddy.speech ? `<div class="dash-buddy-speech">"${escHtml(buddy.speech)}"</div>` : ''}
          ${hasRpg ? `<div class="dash-buddy-rpg">${rpgStats.map(s => `
            <div class="dash-buddy-stat">
              <div class="dash-buddy-stat-label">${s.label}</div>
              <div class="dash-buddy-stat-val" style="color:${s.color}">${s.val}</div>
              <div class="dash-buddy-stat-bar"><div class="dash-buddy-stat-fill" style="width:${s.val}%;background:${s.color}"></div></div>
            </div>`).join('')}</div>` : ''}
          <div class="dash-buddy-xp">
            <div style="display:flex;justify-content:space-between;font-size:0.6875rem;color:${C.muted}">
              <span>XP ${fmt(buddy.xp)}</span>
              <span>Next Lv. ${fmt(buddy.xp_next_level || 0)}</span>
            </div>
            <div class="dash-rate-track" style="height:6px"><div class="dash-rate-fill" style="width:${xpPct}%;background:${C.accent}"></div></div>
          </div>
          <div class="dash-buddy-kvs">
            <div class="dash-kv"><span class="dash-kv-key">Tokens Saved</span><span class="dash-kv-val" style="color:${C.accent}">${fmt(buddy.tokens_saved || 0)}</span></div>
            <div class="dash-kv"><span class="dash-kv-key">Bugs Prevented</span><span class="dash-kv-val" style="color:${C.blue}">${fmt(buddy.bugs_prevented || 0)}</span></div>
          </div>
        </div>
      </div>`;

    const frames = (buddy.ascii_frames && buddy.ascii_frames.length) ? buddy.ascii_frames : (hasAscii ? [buddy.ascii_art] : []);
    if (frames.length > 1) {
      let i = 0;
      const ms = buddy.anim_ms || 850;
      buddyAnimTimer = setInterval(() => {
        i = (i + 1) % frames.length;
        const pre = $('buddyAsciiPre');
        if (pre) pre.textContent = frames[i].join('\n');
      }, ms);
    }
  }

  /* ── Render: Settings ── */
  function renderSettings(me) {
    const el = $('settingsProfile');
    if (!el) return;
    el.innerHTML = `
      <div class="dash-kv"><span class="dash-kv-key">Email</span><span class="dash-kv-val">${escHtml(me?.email || '—')}</span></div>
      <div class="dash-kv"><span class="dash-kv-key">User ID</span><span class="dash-kv-val" style="font-family:var(--font-mono);font-size:0.75rem">${me?.user_id || '—'}</span></div>
      <div class="dash-kv"><span class="dash-kv-key">Plan</span><span class="dash-kv-val">${me?.plan || '—'}</span></div>
      <div class="dash-kv"><span class="dash-kv-key">Verified</span><span class="dash-kv-val ${me?.email_verified ? 'dash-verified-yes' : 'dash-verified-no'}">${me?.email_verified ? '✓ Verified' : '✗ Not verified'}</span></div>`;

    const keyInput = $('apiKeyDisplay');
    if (keyInput) keyInput.value = getApiKey() || '';
  }

  /* ── API Key toggle/copy ── */
  $('toggleApiKey')?.addEventListener('click', () => {
    const input = $('apiKeyDisplay');
    const btn = $('toggleApiKey');
    if (!input || !btn) return;
    if (input.type === 'password') { input.type = 'text'; btn.textContent = 'Hide'; }
    else { input.type = 'password'; btn.textContent = 'Show'; }
  });

  $('copyApiKey')?.addEventListener('click', async () => {
    const key = getApiKey();
    if (!key) return;
    await navigator.clipboard.writeText(key);
    const btn = $('copyApiKey');
    if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 1500); }
  });

  /* ── Render: Overview Profile ── */
  function renderOverviewProfile(me, stats) {
    const el = $('overviewProfile');
    if (!el) return;
    const totalOrig = stats.reduce((a, s) => a + (Number(s?.tokens_original) || 0), 0);
    const totalComp = stats.reduce((a, s) => a + (Number(s?.tokens_compressed) || 0), 0);
    const totalCalls = stats.reduce((a, s) => a + (Number(s?.tool_calls) || 0), 0);
    const totalSaved = totalOrig - totalComp;
    const co = computeCost(totalOrig, totalComp, totalCalls);
    el.innerHTML = `
      <div class="dash-kv"><span class="dash-kv-key">Email</span><span class="dash-kv-val">${escHtml(me?.email || '—')}</span></div>
      <div class="dash-kv"><span class="dash-kv-key">Plan</span><span class="dash-kv-val">${me?.plan || '—'}</span></div>
      <div class="dash-kv"><span class="dash-kv-key">Verified</span><span class="dash-kv-val ${me?.email_verified ? 'dash-verified-yes' : 'dash-verified-no'}">${me?.email_verified ? '✓ Verified' : '✗ Not verified'}</span></div>
      <div class="dash-kv"><span class="dash-kv-key">Est. Cost Saved</span><span class="dash-kv-val" style="color:#34d399">${fmtDollar(co.sv)}</span></div>
      <div class="dash-kv"><span class="dash-kv-key">Without lean-ctx</span><span class="dash-kv-val">${fmtDollar(co.tW)}</span></div>
      <div class="dash-kv"><span class="dash-kv-key">With lean-ctx</span><span class="dash-kv-val">${fmtDollar(co.tC)}</span></div>
      <div class="dash-kv"><span class="dash-kv-key">Active Days</span><span class="dash-kv-val">${stats.length}</span></div>`;
  }

  /* ── Load Dashboard ── */
  async function loadDashboard() {
    hide($('dashError'));
    hide($('verifyBanner'));
    try {
      const [statsData, me, knowledge, models, commands, cepData, gotchas, buddy, feedback] = await Promise.all([
        apiOpt('/api/stats'), api('/api/auth/me'),
        apiOpt('/api/sync/knowledge'), apiOpt('/api/pro/models'),
        apiOpt('/api/sync/commands'), apiOpt('/api/sync/cep'),
        apiOpt('/api/sync/gotchas'), apiOpt('/api/sync/buddy'),
        apiOpt('/api/sync/feedback')
      ]);

      if (me?.email_verified === false) {
        show($('verifyBanner'), 'Please verify your email address. Check your inbox.');
      }

      dashState.stats = Array.isArray(statsData) ? statsData : [];
      dashState.commands = commands;
      dashState.cepData = cepData;
      dashState.knowledge = knowledge;
      dashState.gotchas = gotchas;
      dashState.buddy = buddy;
      dashState.me = me;
      dashState.models = models;

      const dn = (me?.email || 'User').toString();
      if ($('sidebarEmail')) $('sidebarEmail').textContent = dn;
      if ($('sidebarAvatar')) $('sidebarAvatar').textContent = (dn[0] || '?').toUpperCase();
      if ($('sidebarPlan')) $('sidebarPlan').textContent = (me?.plan || 'free').toUpperCase();
      const verEl = $('sidebarVerified');
      if (verEl) {
        verEl.textContent = me?.email_verified ? '✓' : '✗';
        verEl.className = 'dash-profile-verified ' + (me?.email_verified ? 'dash-profile-verified--yes' : 'dash-profile-verified--no');
      }

      renderOverview(30);
      renderOverviewProfile(me, dashState.stats);
      renderBuddy(buddy);
      renderStats(30);
      renderCommands(commands);
      renderPerformance(cepData);
      renderFeedbackThresholds(Array.isArray(feedback) ? feedback : []);
      renderModels(models);
      renderKnowledge(knowledge);
      renderGotchas(gotchas);
      renderSettings(me);

    } catch (e) {
      if (e?.status === 401) {
        localStorage.removeItem('leanctx_api_key');
        window.location.href = '/login?mode=login';
        return;
      }
      show($('dashError'), e?.message || 'Request failed');
    }
  }

  /* ── Init ── */
  (async function init() {
    const apiKey = getApiKey();
    if (!apiKey) { window.location.href = '/login?mode=login'; return; }
    const initialView = getViewFromUrl();
    switchView(initialView, false);
    if (!validViews.has(window.location.pathname.replace(/\/$/, '').split('/').pop())) {
      history.replaceState({ view: initialView }, '', '/dashboard/' + initialView);
    }
    try {
      await api('/api/auth/me');
      loadDashboard();
    } catch (e) {
      if (e?.status === 401) {
        localStorage.removeItem('leanctx_api_key');
        window.location.href = '/login?mode=login';
      }
    }
  })();
</script>

</body>
</html>
