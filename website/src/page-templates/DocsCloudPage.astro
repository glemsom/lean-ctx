---
import DocsLayout from '../layouts/DocsLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const sidebar = [
  {
    title: t('docs.cloud.title'),
    items: [
      { label: t('docs.common.overview'), href: lp('/docs/cloud') },
      { label: t('docs.cloud.login'), href: lp('/docs/cloud') + '#login' },
      { label: t('docs.cloud.statsSync'), href: lp('/docs/cloud') + '#sync' },
      { label: t('docs.cloud.yourData'), href: lp('/docs/cloud') + '#your-data' },
    ],
  },
];
---

<DocsLayout title={t('docs.cloud.title')} sidebar={sidebar}>

<h1>{t('docs.cloud.title')}</h1>

<p class="lead">{t('docs.cloud.lead')}</p>

<h2 id="login">{t('docs.cloud.login')}</h2>

<pre><code>lean-ctx login your@email.com</code></pre>

<p>{t('docs.cloud.loginDesc')}</p>

<h2 id="sync">{t('docs.cloud.statsSync')}</h2>

<pre><code>lean-ctx sync</code></pre>

<p>{t('docs.cloud.statsSyncDesc')}</p>

<h2 id="your-data">{t('docs.cloud.yourData')}</h2>

<p>{t('docs.cloud.yourDataIntro')}</p>

<table>
  <thead>
    <tr>
      <th>{t('docs.cloud.thWeCollect')}</th>
      <th>{t('docs.cloud.thWeNeverCollect')}</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>{t('docs.cloud.collectExtension')}</td>
      <td>{t('docs.cloud.neverCollectNames')}</td>
    </tr>
    <tr>
      <td>{t('docs.cloud.collectSize')}</td>
      <td>{t('docs.cloud.neverCollectContents')}</td>
    </tr>
    <tr>
      <td>{t('docs.cloud.collectMode')}</td>
      <td>{t('docs.cloud.neverCollectPersonal')}</td>
    </tr>
    <tr>
      <td>{t('docs.cloud.collectRatio')}</td>
      <td>{t('docs.cloud.neverCollectStructure')}</td>
    </tr>
  </tbody>
</table>

<p set:html={t('docs.cloud.optInNote')} />

</DocsLayout>
