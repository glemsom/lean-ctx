---
import DocsLayout from '../layouts/DocsLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const sidebar = [
  {
    title: t('docs.cliReference.sidebarTitle'),
    items: [
      { label: t('docs.common.overview'), href: lp('/docs/cli-reference') },
      { label: t('docs.cliReference.sidebarShellCompression'), href: lp('/docs/cli-reference#shell-compression') },
      { label: t('docs.cliReference.sidebarRawMode'), href: lp('/docs/cli-reference#raw-mode') },
      { label: t('docs.cliReference.sidebarFileOps'), href: lp('/docs/cli-reference#file-operations') },
      { label: t('docs.cliReference.sidebarReadModes'), href: lp('/docs/cli-reference#read-modes') },
      { label: t('docs.cliReference.sidebarSetupConfig'), href: lp('/docs/cli-reference#setup-config') },
      { label: t('docs.cliReference.sidebarAnalytics'), href: lp('/docs/cli-reference#analytics') },
      { label: t('docs.cliReference.sidebarSessions'), href: lp('/docs/cli-reference#sessions') },
      { label: t('docs.cliReference.sidebarBenchmarking'), href: lp('/docs/cli-reference#benchmarking') },
      { label: t('docs.cliReference.sidebarTeeFilters'), href: lp('/docs/cli-reference#tee-filters') },
      { label: t('docs.cliReference.sidebarUtilities'), href: lp('/docs/cli-reference#utilities') },
      { label: t('docs.cliReference.sidebarProjectGraph'), href: lp('/docs/cli-reference#project-graph') },
      { label: t('docs.cliReference.sidebarHeatmap'), href: lp('/docs/cli-reference#heatmap') },
      { label: t('docs.cliReference.sidebarShellAliases'), href: lp('/docs/cli-reference#shell-aliases') },
    ],
  },
  {
    title: t('docs.common.related'),
    items: [
      { label: t('docs.cliReference.sidebarAnalyticsGuide'), href: lp('/docs/analytics') },
      { label: t('docs.cliReference.sidebarQuickRef'), href: lp('/docs/quick-reference') },
      { label: t('docs.cliReference.sidebarConfiguration'), href: lp('/docs/configuration') },
      { label: t('docs.cliReference.sidebarGettingStarted'), href: lp('/docs/getting-started') },
    ],
  },
];
---

<DocsLayout title={t('docs.cliReference.title')} description={t('docs.cliReference.description')} sidebar={sidebar}>

  <p><Fragment set:html={t('docs.cliReference.intro', { quickRefPath: lp('/docs/quick-reference'), analyticsPath: lp('/docs/analytics') })} /></p>

  <hr />

  <h2 id="shell-compression">{t('docs.cliReference.shellCompressionTitle')}</h2>

  <p><Fragment set:html={t('docs.cliReference.shellCompressionDesc')} /></p>

  <h3 id="exec"><code>lean-ctx -c "&lt;command&gt;"</code></h3>
  <p><Fragment set:html={t('docs.cliReference.execDesc')} /></p>
  <pre><code>lean-ctx -c "git status"
lean-ctx -c "kubectl get pods -A"
lean-ctx -c "cargo build 2>&amp;1"
lean-ctx exec "docker ps"</code></pre>
  <p><Fragment set:html={t('docs.cliReference.execNote')} /></p>

  <h3 id="shell"><code>lean-ctx shell</code></h3>
  <p><Fragment set:html={t('docs.cliReference.shellDesc')} /></p>
  <pre><code>lean-ctx shell
# Now every command output is compressed automatically
git log --oneline -20
docker compose logs
# Exit with Ctrl+D or 'exit'</code></pre>

  <hr />

  <h2 id="raw-mode">{t('docs.cliReference.rawModeTitle')}</h2>

  <p>{t('docs.cliReference.rawModeDesc')}</p>

  <pre><code># CLI flag
lean-ctx -c --raw git log --stat

# Shell function (after lean-ctx init --global)
lean-ctx-raw kubectl get pods -o yaml

# MCP parameter
ctx_shell(command="cat package.json", raw=true)

# Environment variable
LEAN_CTX_RAW=1 lean-ctx -c npm list

# Kill-switch: disable ALL compression
LEAN_CTX_DISABLED=1 lean-ctx -c git status</code></pre>

  <hr />

  <h2 id="file-operations">{t('docs.cliReference.fileOpsTitle')}</h2>

  <p>{t('docs.cliReference.fileOpsDesc')}</p>

  <h3 id="read"><code>lean-ctx read &lt;file&gt; [-m &lt;mode&gt;]</code></h3>
  <p><Fragment set:html={t('docs.cliReference.readDesc')} /></p>
  <pre><code>lean-ctx read src/main.rs                    # full content (cached)
lean-ctx read src/main.rs -m map             # dependency graph + exports
lean-ctx read src/main.rs -m signatures      # tree-sitter AST extraction
lean-ctx read src/main.rs -m aggressive      # syntax-stripped
lean-ctx read src/main.rs -m entropy         # Shannon entropy filtered
lean-ctx read src/main.rs -m diff            # changed lines only
lean-ctx read src/main.rs -m lines:10-50     # specific line range
lean-ctx read src/main.rs -m lines:10-50,80  # multiple ranges</code></pre>

  <h3 id="diff"><code>lean-ctx diff &lt;file1&gt; &lt;file2&gt;</code></h3>
  <p>{t('docs.cliReference.diffDesc')}</p>
  <pre><code>lean-ctx diff old.rs new.rs</code></pre>

  <h3 id="grep"><code>lean-ctx grep &lt;pattern&gt; [path]</code></h3>
  <p>{t('docs.cliReference.grepDesc')}</p>
  <pre><code>lean-ctx grep "pub fn" src/
lean-ctx grep "TODO" .
lean-ctx grep "async fn.*Result" rust/src/</code></pre>

  <h3 id="find"><code>lean-ctx find &lt;pattern&gt; [path]</code></h3>
  <p><Fragment set:html={t('docs.cliReference.findDesc')} /></p>
  <pre><code>lean-ctx find "*.rs" src/
lean-ctx find "test_*" .</code></pre>

  <h3 id="ls"><code>lean-ctx ls [path]</code></h3>
  <p>{t('docs.cliReference.lsDesc')}</p>
  <pre><code>lean-ctx ls
lean-ctx ls src/components/</code></pre>

  <h3 id="deps"><code>lean-ctx deps [path]</code></h3>
  <p>{t('docs.cliReference.depsDesc')}</p>
  <pre><code>lean-ctx deps .
lean-ctx deps frontend/</code></pre>

  <hr />

  <h2 id="read-modes">{t('docs.cliReference.readModesTitle')}</h2>

  <p><Fragment set:html={t('docs.cliReference.readModesDesc')} /></p>

  <table>
    <thead>
      <tr><th>{t('docs.cliReference.thMode')}</th><th>{t('docs.cliReference.thOutput')}</th><th>{t('docs.cliReference.thUseCase')}</th><th>{t('docs.cliReference.thSavings')}</th></tr>
    </thead>
    <tbody>
      <tr><td><code>full</code></td><td>{t('docs.cliReference.modeFull')}</td><td>{t('docs.cliReference.modeFullUse')}</td><td>{t('docs.cliReference.modeFullSavings')}</td></tr>
      <tr><td><code>map</code></td><td>{t('docs.cliReference.modeMap')}</td><td>{t('docs.cliReference.modeMapUse')}</td><td>{t('docs.cliReference.modeMapSavings')}</td></tr>
      <tr><td><code>signatures</code></td><td>{t('docs.cliReference.modeSignatures')}</td><td>{t('docs.cliReference.modeSignaturesUse')}</td><td>{t('docs.cliReference.modeSignaturesSavings')}</td></tr>
      <tr><td><code>aggressive</code></td><td>{t('docs.cliReference.modeAggressive')}</td><td>{t('docs.cliReference.modeAggressiveUse')}</td><td>{t('docs.cliReference.modeAggressiveSavings')}</td></tr>
      <tr><td><code>entropy</code></td><td>{t('docs.cliReference.modeEntropy')}</td><td>{t('docs.cliReference.modeEntropyUse')}</td><td>{t('docs.cliReference.modeEntropySavings')}</td></tr>
      <tr><td><code>diff</code></td><td>{t('docs.cliReference.modeDiff')}</td><td>{t('docs.cliReference.modeDiffUse')}</td><td>{t('docs.cliReference.modeDiffSavings')}</td></tr>
      <tr><td><code>lines:N-M</code></td><td>{t('docs.cliReference.modeLines')}</td><td><Fragment set:html={t('docs.cliReference.modeLinesUse')} /></td><td>{t('docs.cliReference.modeLinesSavings')}</td></tr>
    </tbody>
  </table>

  <p><Fragment set:html={t('docs.cliReference.modesSupportedLangs')} /></p>

  <hr />

  <h2 id="setup-config">{t('docs.cliReference.setupConfigTitle')}</h2>

  <h3 id="setup"><code>lean-ctx setup</code></h3>
  <p>{t('docs.cliReference.setupDesc')}</p>
  <pre><code>lean-ctx setup</code></pre>
  <p>{t('docs.cliReference.setupStepsIntro')}</p>
  <ol>
    <li><Fragment set:html={t('docs.cliReference.setupStep1')} /></li>
    <li>{t('docs.cliReference.setupStep2')}</li>
    <li><Fragment set:html={t('docs.cliReference.setupStep3')} /></li>
  </ol>

  <h3 id="init"><code>lean-ctx init [--global]</code></h3>
  <p>{t('docs.cliReference.initDesc')}</p>
  <pre><code>lean-ctx init           # install for current shell
lean-ctx init --global  # same, explicit flag</code></pre>
  <p><Fragment set:html={t('docs.cliReference.initNote')} /></p>

  <h3 id="init-agent"><code>lean-ctx init --agent &lt;name&gt;</code></h3>
  <p>{t('docs.cliReference.initAgentDesc')}</p>
  <pre><code>lean-ctx init --agent cursor
lean-ctx init --agent claude
lean-ctx init --agent codex
lean-ctx init --agent gemini
lean-ctx init --agent antigravity  # alias for gemini
lean-ctx init --agent windsurf
lean-ctx init --agent copilot
lean-ctx init --agent cline
lean-ctx init --agent roo
lean-ctx init --agent pi        # installs pi-lean-ctx npm package</code></pre>

  <h3 id="config"><code>lean-ctx config [set &lt;key&gt; &lt;value&gt;]</code></h3>
  <p><Fragment set:html={t('docs.cliReference.configDesc')} /></p>
  <pre><code>lean-ctx config                        # show current config
lean-ctx config set ultra_compact true # enable ultra-compact mode
lean-ctx config set tee_on_error true  # log errors to ~/.lean-ctx/tee/
lean-ctx config set checkpoint_interval 20</code></pre>

  <h3 id="doctor"><code>lean-ctx doctor</code></h3>
  <p>{t('docs.cliReference.doctorDesc')}</p>
  <ul>
    <li>{t('docs.cliReference.doctorCheck1')}</li>
    <li>{t('docs.cliReference.doctorCheck2')}</li>
    <li>{t('docs.cliReference.doctorCheck3')}</li>
    <li>{t('docs.cliReference.doctorCheck4')}</li>
    <li>{t('docs.cliReference.doctorCheck5')}</li>
    <li>{t('docs.cliReference.doctorCheck6')}</li>
    <li>{t('docs.cliReference.doctorCheck7')}</li>
    <li>{t('docs.cliReference.doctorCheck8')}</li>
  </ul>
  <pre><code>lean-ctx doctor</code></pre>

  <h3 id="update"><code>lean-ctx update [--check]</code></h3>
  <p>{t('docs.cliReference.updateDesc')}</p>
  <pre><code>lean-ctx update         # download and install latest version
lean-ctx update --check # check if a newer version is available (no install)</code></pre>

  <h3 id="uninstall"><code>lean-ctx uninstall</code></h3>
  <p><Fragment set:html={t('docs.cliReference.uninstallDesc')} /></p>
  <pre><code>lean-ctx uninstall</code></pre>

  <hr />

  <h2 id="analytics">{t('docs.cliReference.analyticsTitle')}</h2>

  <p><Fragment set:html={t('docs.cliReference.analyticsIntro', { analyticsPath: lp('/docs/analytics') })} /></p>

  <h3 id="gain"><code>lean-ctx gain [flags]</code></h3>
  <p>{t('docs.cliReference.gainDesc')}</p>

  <table>
    <thead><tr><th>{t('docs.cliReference.thFlag')}</th><th>{t('docs.cliReference.thOutput')}</th></tr></thead>
    <tbody>
      <tr><td><code>(none)</code></td><td>{t('docs.cliReference.gainNoneDesc')}</td></tr>
      <tr><td><code>--live</code></td><td><Fragment set:html={t('docs.cliReference.gainLiveDesc')} /></td></tr>
      <tr><td><code>--graph</code></td><td>{t('docs.cliReference.gainGraphDesc')}</td></tr>
      <tr><td><code>--daily</code></td><td>{t('docs.cliReference.gainDailyDesc')}</td></tr>
      <tr><td><code>--json</code></td><td>{t('docs.cliReference.gainJsonDesc')}</td></tr>
    </tbody>
  </table>

  <pre><code>lean-ctx gain
lean-ctx gain --live
lean-ctx gain --graph
lean-ctx gain --daily
lean-ctx gain --json &gt; stats.json</code></pre>

  <h3 id="cep"><code>lean-ctx cep</code></h3>
  <p>{t('docs.cliReference.cepDesc')}</p>
  <pre><code>lean-ctx cep</code></pre>

  <h3 id="dashboard"><code>lean-ctx dashboard [--port=N]</code></h3>
  <p><Fragment set:html={t('docs.cliReference.dashboardDesc')} /></p>
  <pre><code>lean-ctx dashboard              # opens at localhost:3333
lean-ctx dashboard --port=8080  # custom port</code></pre>

  <h3 id="wrapped"><code>lean-ctx wrapped [--week|--month|--all]</code></h3>
  <p>{t('docs.cliReference.wrappedDesc')}</p>

  <table>
    <thead><tr><th>{t('docs.cliReference.thFlag')}</th><th>{t('docs.cliReference.thPeriod')}</th></tr></thead>
    <tbody>
      <tr><td><code>(none)</code></td><td>{t('docs.cliReference.wrappedNone')}</td></tr>
      <tr><td><code>--week</code></td><td>{t('docs.cliReference.wrappedWeek')}</td></tr>
      <tr><td><code>--month</code></td><td>{t('docs.cliReference.wrappedMonth')}</td></tr>
      <tr><td><code>--all</code></td><td>{t('docs.cliReference.wrappedAll')}</td></tr>
    </tbody>
  </table>

  <pre><code>lean-ctx wrapped
lean-ctx wrapped --month
lean-ctx wrapped --all</code></pre>

  <hr />

  <h2 id="sessions">{t('docs.cliReference.sessionMgmtTitle')}</h2>

  <h3 id="sessions-cmd"><code>lean-ctx sessions [list|show|cleanup]</code></h3>
  <p><Fragment set:html={t('docs.cliReference.sessionsMgmtDesc')} /></p>

  <table>
    <thead><tr><th>{t('docs.cliReference.thSubcommand')}</th><th>{t('docs.cliReference.thAction')}</th></tr></thead>
    <tbody>
      <tr><td><code>list</code></td><td>{t('docs.cliReference.sessionsListAction')}</td></tr>
      <tr><td><code>show</code></td><td>{t('docs.cliReference.sessionsShowAction')}</td></tr>
      <tr><td><code>cleanup</code></td><td>{t('docs.cliReference.sessionsCleanupAction')}</td></tr>
    </tbody>
  </table>

  <pre><code>lean-ctx sessions list
lean-ctx sessions show
lean-ctx sessions cleanup</code></pre>

  <h3 id="session"><code>lean-ctx session</code></h3>
  <p>{t('docs.cliReference.sessionAdoptionDesc')}</p>
  <pre><code>lean-ctx session</code></pre>

  <hr />

  <h2 id="benchmarking">{t('docs.cliReference.benchmarkingTitle')}</h2>

  <h3 id="benchmark-run"><code>lean-ctx benchmark run [path] [--json]</code></h3>
  <p>{t('docs.cliReference.benchmarkRunDesc')}</p>
  <pre><code>lean-ctx benchmark run                # benchmark current directory
lean-ctx benchmark run src/           # benchmark specific path
lean-ctx benchmark run . --json       # output as JSON</code></pre>

  <h3 id="benchmark-report"><code>lean-ctx benchmark report [path]</code></h3>
  <p>{t('docs.cliReference.benchmarkReportDesc')}</p>
  <pre><code>lean-ctx benchmark report             # generate report for current directory
lean-ctx benchmark report src/ &gt; BENCHMARK.md</code></pre>

  <hr />

  <h2 id="tee-filters">{t('docs.cliReference.teeFiltersTitle')}</h2>

  <h3><code>lean-ctx tee [list|clear|show &lt;file&gt;|last]</code></h3>
  <p><Fragment set:html={t('docs.cliReference.teeDesc')} /></p>

  <h3><code>lean-ctx filter [list|validate|init]</code></h3>
  <p><Fragment set:html={t('docs.cliReference.filterDesc')} /></p>
  <pre><code># Create example filter
lean-ctx filter init

# List loaded filters
lean-ctx filter list

# Validate filter syntax
lean-ctx filter validate</code></pre>

  <hr />

  <h2 id="utilities">{t('docs.cliReference.utilitiesTitle')}</h2>

  <h3 id="discover"><code>lean-ctx discover</code></h3>
  <p>{t('docs.cliReference.discoverDesc')}</p>
  <pre><code>lean-ctx discover</code></pre>

  <h3 id="cheatsheet"><code>lean-ctx cheatsheet</code></h3>
  <p>{t('docs.cliReference.cheatsheetDesc')}</p>
  <pre><code>lean-ctx cheatsheet</code></pre>

  <h3 id="tee"><code>lean-ctx tee [list|clear|show &lt;file&gt;]</code></h3>
  <p><Fragment set:html={t('docs.cliReference.teeManageDesc')} /></p>

  <table>
    <thead><tr><th>{t('docs.cliReference.thSubcommand')}</th><th>{t('docs.cliReference.thAction')}</th></tr></thead>
    <tbody>
      <tr><td><code>list</code></td><td>{t('docs.cliReference.teeListAction')}</td></tr>
      <tr><td><code>clear</code></td><td>{t('docs.cliReference.teeClearAction')}</td></tr>
      <tr><td><code>show &lt;file&gt;</code></td><td>{t('docs.cliReference.teeShowAction')}</td></tr>
    </tbody>
  </table>

  <pre><code>lean-ctx tee list
lean-ctx tee show 2026-03-29_10-30.log
lean-ctx tee clear</code></pre>

  <h3 id="slow-log"><code>lean-ctx slow-log [list|clear]</code></h3>
  <p><Fragment set:html={t('docs.cliReference.slowLogDesc')} /></p>
  <pre><code>lean-ctx slow-log list
lean-ctx slow-log clear</code></pre>

  <hr />

  <h2 id="project-graph">{t('docs.cliReference.graphTitle')}</h2>

  <p>{t('docs.cliReference.graphDesc')}</p>

  <h3 id="graph-build"><code>lean-ctx graph build</code></h3>
  <p>{t('docs.cliReference.graphBuildDesc')}</p>
  <pre><code>lean-ctx graph build</code></pre>

  <hr />

  <h2 id="heatmap">{t('docs.cliReference.heatmapTitle')}</h2>

  <p>{t('docs.cliReference.heatmapDesc')}</p>

  <h3 id="heatmap-cmd"><code>lean-ctx heatmap</code></h3>
  <p>{t('docs.cliReference.heatmapCliDesc')}</p>
  <pre><code>lean-ctx heatmap</code></pre>

  <hr />

  <h2 id="shell-aliases">{t('docs.cliReference.shellAliasesTitle')}</h2>

  <p><Fragment set:html={t('docs.cliReference.shellAliasesDesc')} /></p>

  <table>
    <thead><tr><th>{t('docs.cliReference.thAlias')}</th><th>{t('docs.cliReference.thAction')}</th></tr></thead>
    <tbody>
      <tr><td><code>lean-ctx-on</code></td><td>{t('docs.cliReference.aliasOnAction')}</td></tr>
      <tr><td><code>lean-ctx-off</code></td><td>{t('docs.cliReference.aliasOffAction')}</td></tr>
      <tr><td><code>lean-ctx-status</code></td><td>{t('docs.cliReference.aliasStatusAction')}</td></tr>
      <tr><td><code>lean-ctx-raw &lt;cmd&gt;</code></td><td>{t('docs.cliReference.aliasRawAction')}</td></tr>
    </tbody>
  </table>

  <pre><code>lean-ctx-status    # check current state
lean-ctx-off       # temporarily disable for human reading
git log            # now shows full, uncompressed output
lean-ctx-on        # re-enable for AI sessions</code></pre>

  <p><Fragment set:html={t('docs.cliReference.whenToDisable')} /></p>

</DocsLayout>
