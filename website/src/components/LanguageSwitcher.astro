---
import { locales, localeNames, localeFlags, type Locale } from '../i18n/config';
import { getLocaleFromUrl, getLocalizedPath, removeLocalePrefix } from '../i18n/utils';

const currentLocale = getLocaleFromUrl(Astro.url);
const currentPath = removeLocalePrefix(Astro.url.pathname);
---

<div class="lang-switcher" data-lang-switcher>
  <button class="lang-trigger" aria-label="Change language" aria-expanded="false">
    <svg class="lang-globe" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <path d="M2 12h20"/>
      <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
    </svg>
    <span class="lang-current">{currentLocale.toUpperCase()}</span>
    <svg class="lang-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </button>

  <div class="lang-dropdown" role="menu">
    {locales.map((locale: Locale) => (
      <a
        href={getLocalizedPath(currentPath, locale)}
        class:list={['lang-option', locale === currentLocale ? 'is-active' : '']}
        role="menuitem"
        hreflang={locale}
      >
        <span class="lang-option-flag">{localeFlags[locale]}</span>
        <span class="lang-option-name">{localeNames[locale]}</span>
        {locale === currentLocale && (
          <svg class="lang-check" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        )}
      </a>
    ))}
  </div>
</div>

<style>
  .lang-switcher {
    position: relative;
    z-index: 60;
  }

  .lang-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px 8px;
    font-size: 0.6875rem;
    font-weight: 500;
    font-family: inherit;
    color: var(--color-muted);
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    line-height: 1;
    letter-spacing: 0.04em;
  }

  .lang-trigger:hover {
    color: var(--color-text-bright);
    border-color: var(--color-border-light);
  }

  .lang-globe {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .lang-chevron {
    transition: transform 0.2s;
    opacity: 0.5;
  }

  .lang-switcher.is-open .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    width: 280px;
    padding: 6px;
    background: var(--color-surface-3);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    animation: langDropIn 0.15s ease;
    display: none;
  }

  .lang-switcher.is-open .lang-dropdown {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  @keyframes langDropIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 10px;
    font-size: 0.8125rem;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .lang-option:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text-bright);
  }

  .lang-option.is-active {
    color: var(--color-accent);
    font-weight: 500;
  }

  .lang-option-flag {
    font-size: 0.875rem;
    line-height: 1;
  }

  .lang-option-name {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lang-check {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .lang-dropdown {
      width: 220px;
    }

    .lang-switcher.is-open .lang-dropdown {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-lang-switcher]').forEach(switcher => {
    const trigger = switcher.querySelector('.lang-trigger');

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      switcher.classList.toggle('is-open');
      trigger.setAttribute('aria-expanded',
        switcher.classList.contains('is-open') ? 'true' : 'false'
      );
    });

    switcher.querySelectorAll('.lang-option').forEach(option => {
      option.addEventListener('click', () => {
        const hreflang = option.getAttribute('hreflang');
        if (hreflang) {
          localStorage.setItem('leanctx-locale', hreflang);
        }
      });
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll('[data-lang-switcher].is-open').forEach(s => {
      s.classList.remove('is-open');
      s.querySelector('.lang-trigger')?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
