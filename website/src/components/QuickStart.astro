---
const steps = [
  {
    num: '1',
    title: 'Clone & Build',
    subtitle: 'One-liner for any system with Node.js',
    code: `git clone https://gitlab.pounce.ch/root/lean-ctx.git
cd lean-ctx && npm install && npm run build`,
  },
  {
    num: '2',
    title: 'Configure Your Editor',
    subtitle: 'Add to your MCP config',
    code: `// Cursor: ~/.cursor/mcp.json
// Copilot: .github/copilot-mcp.json
// Claude Code: ~/.claude/mcp.json
{
  "mcpServers": {
    "lean-ctx": {
      "command": "node",
      "args": ["/path/to/lean-ctx/dist/index.js"]
    }
  }
}`,
  },
  {
    num: '3',
    title: 'Watch Your Savings',
    subtitle: 'Every read is now optimized',
    code: `$ ctx_metrics

lean-ctx session
files: 12 tracked, 34 reads, 22 hits (65%)
tokens: 28,450 original → 4,120 sent
saved: -24,330 tokens (85%)`,
  },
];
---

<section class="relative py-28 overflow-hidden">
  <div class="orb w-[300px] h-[300px] bg-accent-2/10 bottom-[10%] right-[10%]" style="animation-delay: -5s;"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-surface/20 to-bg pointer-events-none"></div>

  <div class="relative max-w-5xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-5">Get started in <span class="gradient-text">60 seconds</span></h2>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        No cloud account. No API keys. No subscription. Just clone, build, and go.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      {steps.map(step => (
        <div class="card-premium rounded-2xl overflow-hidden group flex flex-col">
          <div class="flex items-center gap-3 px-6 py-4 border-b border-border/30">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/20 to-accent-2/10 border border-accent/20 flex items-center justify-center text-sm font-bold gradient-text">{step.num}</span>
            <div>
              <p class="text-sm font-bold text-text-bright">{step.title}</p>
              <p class="text-xs text-muted/50">{step.subtitle}</p>
            </div>
          </div>
          <pre class="flex-1 p-5 text-xs font-mono text-muted leading-relaxed overflow-x-auto"><code>{step.code}</code></pre>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/docs/getting-started" class="btn-glossy inline-flex items-center px-8 py-3.5 text-sm font-bold rounded-xl text-bg">
        Full Installation Guide
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</section>
