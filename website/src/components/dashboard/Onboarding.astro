---
interface Props {
  t: (key: string) => string;
}
const { t } = Astro.props;
---

<div id="onboardingOverlay" class="onboard-overlay hidden">
  <div class="onboard-card">
    <div class="onboard-icon">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
      </svg>
    </div>
    <h2 class="onboard-title font-display">{t('dash.onboardTitle')}</h2>
    <p class="onboard-desc">{t('dash.onboardDesc')}</p>
    <div class="onboard-steps">
      <div class="onboard-step">
        <div class="onboard-num font-display">1</div>
        <div><p class="onboard-step-t">{t('dash.onboardStep1Title')}</p><code class="onboard-code">brew install yvgude/tap/lean-ctx</code></div>
      </div>
      <div class="onboard-step">
        <div class="onboard-num font-display">2</div>
        <div><p class="onboard-step-t">{t('dash.onboardStep2Title')}</p><code class="onboard-code" id="onboardCmd">lean-ctx login you@email.com</code></div>
      </div>
      <div class="onboard-step">
        <div class="onboard-num font-display">3</div>
        <div><p class="onboard-step-t">{t('dash.onboardStep3Title')}</p><code class="onboard-code">lean-ctx sync</code></div>
      </div>
    </div>
    <button id="onboardDismiss" class="dash-btn-primary" style="margin-top:1.25rem;width:100%">{t('dash.onboardDismiss')}</button>
  </div>
</div>
