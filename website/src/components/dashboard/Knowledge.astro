---
interface Props {
  t: (key: string) => string;
}
const { t } = Astro.props;
---

<div class="dash-view" data-panel="knowledge">
  <div class="dash-kpis" style="grid-template-columns: repeat(3, 1fr)">
    <div class="dash-kpi" style="--kpi-color:#34d399">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292"/></svg></div>
      <span class="dash-kpi-val font-display" id="knowledgeKpiCount">—</span>
      <span class="dash-kpi-label">Knowledge Entries</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#f87171">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/></svg></div>
      <span class="dash-kpi-val font-display" id="gotchaKpiDetected">—</span>
      <span class="dash-kpi-label">Errors Detected</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#60a5fa">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
      <span class="dash-kpi-val font-display" id="gotchaKpiPrevented">—</span>
      <span class="dash-kpi-label">Errors Prevented</span>
    </div>
  </div>

  <!-- Knowledge Entries -->
  <div class="dash-card">
    <div class="dash-card-head">
      <span>{t('dash.knowledgeTitle')}</span>
      <span id="knowledgeCount" style="font-weight:400;text-transform:none;letter-spacing:0"></span>
    </div>
    <div class="dash-card-body" id="knowledgeContent">
      <div class="dash-knowledge-filters" id="knowledgeFilters" style="display:none">
        <input type="text" class="dash-knowledge-search" id="knowledgeSearch" placeholder="Search knowledge…" />
      </div>
      <div id="knowledgeList">
        <div class="dash-skeleton dash-skeleton-line"></div>
        <div class="dash-skeleton dash-skeleton-line" style="width:80%"></div>
        <div class="dash-skeleton dash-skeleton-line" style="width:60%"></div>
      </div>
    </div>
  </div>

  <!-- Bug Memory / Gotchas -->
  <div class="dash-card">
    <div class="dash-card-head">
      <span>Bug Memory</span>
      <span id="gotchaCount" style="font-weight:400;text-transform:none;letter-spacing:0"></span>
    </div>
    <div class="dash-card-body" id="gotchaList" style="padding:0">
      <div style="padding:1.125rem">
        <div class="dash-skeleton dash-skeleton-line"></div>
        <div class="dash-skeleton dash-skeleton-line" style="width:70%"></div>
      </div>
    </div>
  </div>
</div>
