---
interface Props {
  t: (key: string) => string;
}
const { t } = Astro.props;
---

<div class="dash-view" data-panel="performance">
  <div class="dash-kpis">
    <div class="dash-kpi" style="--kpi-color:#34d399">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3"/></svg></div>
      <span class="dash-kpi-val font-display" id="cepLatest">—</span>
      <span class="dash-kpi-label">Latest CEP Score</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#60a5fa">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22"/></svg></div>
      <span class="dash-kpi-val font-display" id="cepAvg">—</span>
      <span class="dash-kpi-label">Avg Score</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#fbbf24">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg></div>
      <span class="dash-kpi-val font-display" id="cepBest">—</span>
      <span class="dash-kpi-label">Best Score</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#a78bfa">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg></div>
      <span class="dash-kpi-val font-display" id="cepCacheRate">—</span>
      <span class="dash-kpi-label">Avg Cache Hit Rate</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#f472b6">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25"/></svg></div>
      <span class="dash-kpi-val font-display" id="cepSessions">—</span>
      <span class="dash-kpi-label">Sessions Tracked</span>
    </div>
  </div>

  <div class="dash-card">
    <div class="dash-card-head">CEP Score Over Time</div>
    <div class="dash-card-body dash-chart-wrap"><canvas id="chartCepScore" height="220"></canvas></div>
  </div>

  <div class="dash-grid-3">
    <div class="dash-card">
      <div class="dash-card-head">Cache Hit Rate Trend</div>
      <div class="dash-card-body dash-chart-wrap"><canvas id="chartCepCache" height="160"></canvas></div>
    </div>
    <div class="dash-card">
      <div class="dash-card-head">Compression Rate Trend</div>
      <div class="dash-card-body dash-chart-wrap"><canvas id="chartCepCompression" height="160"></canvas></div>
    </div>
    <div class="dash-card">
      <div class="dash-card-head">Mode Diversity Over Time</div>
      <div class="dash-card-body dash-chart-wrap"><canvas id="chartCepDiversity" height="160"></canvas></div>
    </div>
  </div>

  <div class="dash-card">
    <div class="dash-card-head">Learned Compression Thresholds</div>
    <div class="dash-card-body" id="feedbackContent" style="font-size:0.8125rem;color:var(--color-muted)">
      <p style="margin-bottom:0.5rem;font-size:0.75rem">These are personalized thresholds lean-ctx learned from your usage patterns. Higher efficiency = better compression for that file type.</p>
      <div id="feedbackTable" style="overflow-x:auto"></div>
    </div>
  </div>
</div>
