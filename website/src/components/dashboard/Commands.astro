---
interface Props {
  t: (key: string) => string;
}
const { t } = Astro.props;
---

<div class="dash-view" data-panel="commands">
  <div class="dash-kpis">
    <div class="dash-kpi" style="--kpi-color:#34d399">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3M3.75 4.5h16.5c.621 0 1.125.504 1.125 1.125v12.75c0 .621-.504 1.125-1.125 1.125H3.75a1.125 1.125 0 01-1.125-1.125V5.625c0-.621.504-1.125 1.125-1.125z"/></svg></div>
      <span class="dash-kpi-val font-display" id="cmdTotal">—</span>
      <span class="dash-kpi-label">Total Calls</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#60a5fa">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22"/></svg></div>
      <span class="dash-kpi-val font-display" id="cmdTokensSaved">—</span>
      <span class="dash-kpi-label">Tokens Saved</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#fbbf24">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
      <span class="dash-kpi-val font-display" id="cmdCostSaved">—</span>
      <span class="dash-kpi-label">Cost Saved</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#a78bfa">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg></div>
      <span class="dash-kpi-val font-display" id="cmdTopSaver">—</span>
      <span class="dash-kpi-label">Top Saver</span>
    </div>
    <div class="dash-kpi" style="--kpi-color:#f87171">
      <div class="dash-kpi-icon"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z"/></svg></div>
      <span class="dash-kpi-val font-display" id="cmdUniqueCount">—</span>
      <span class="dash-kpi-label">Unique Commands</span>
    </div>
  </div>

  <div class="dash-grid-2">
    <div class="dash-card dash-card--span">
      <div class="dash-card-head">
        <span>Command Breakdown</span>
        <span id="cmdCount" style="font-weight:400;text-transform:none;letter-spacing:0"></span>
      </div>
      <div class="dash-card-body" id="cmdTable" style="padding:0">
        <div style="padding:1.125rem">
          <div class="dash-skeleton dash-skeleton-line"></div>
          <div class="dash-skeleton dash-skeleton-line" style="width:80%"></div>
          <div class="dash-skeleton dash-skeleton-line" style="width:60%"></div>
        </div>
      </div>
    </div>
    <div class="dash-card">
      <div class="dash-card-head">MCP vs Hook</div>
      <div class="dash-card-body" style="display:flex;align-items:center;justify-content:center;padding:1.5rem">
        <canvas id="chartSourceDist" height="180" width="180"></canvas>
      </div>
    </div>
  </div>

  <!-- Top savers and most expensive -->
  <div class="dash-grid-2" style="grid-template-columns:1fr 1fr">
    <div class="dash-card">
      <div class="dash-card-head" style="color:#34d399">Top Savers</div>
      <div class="dash-card-body" id="cmdTopSavers" style="padding:0">
        <div style="padding:1rem"><div class="dash-skeleton dash-skeleton-line"></div></div>
      </div>
    </div>
    <div class="dash-card">
      <div class="dash-card-head" style="color:#f87171">Most Expensive</div>
      <div class="dash-card-body" id="cmdMostExpensive" style="padding:0">
        <div style="padding:1rem"><div class="dash-skeleton dash-skeleton-line"></div></div>
      </div>
    </div>
  </div>
</div>
